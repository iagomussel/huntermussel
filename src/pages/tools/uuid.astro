---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="UUID Generator | HunterMussel Tools"
  description="Generate UUID v4 values instantly. Bulk generation up to 100 UUIDs, with/without hyphens, one-click copy. Fully client-side using the Web Crypto API."
  canonicalPath="/tools/uuid/"
>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">tool / encoding</p>
      <h1>UUID Generator</h1>
      <p class="lead">
        Generate one or many UUID v4 values instantly. Toggle hyphens, copy
        all, or download as a text file. Uses the browser's built-in crypto —
        no library, no server.
      </p>
      <a class="back-link" href="/tools/">← Back to tools</a>
    </section>

    <!-- Controls -->
    <div class="card uu-controls">
      <div class="uu-controls-left">
        <div class="uu-count-group">
          <label class="uu-label" for="countSlider">Count: <span id="countDisplay">1</span></label>
          <input id="countSlider" type="range" min="1" max="100" value="1" class="uu-slider" />
        </div>
        <label class="uu-toggle-label">
          <input type="checkbox" id="noHyphens" />
          <span>No hyphens (32 hex chars)</span>
        </label>
        <label class="uu-toggle-label">
          <input type="checkbox" id="uppercase" />
          <span>Uppercase</span>
        </label>
      </div>
      <div class="actions">
        <button id="genBtn" type="button">Generate</button>
        <button id="copyAllBtn" type="button" class="secondary">Copy all</button>
        <button id="downloadBtn" type="button" class="secondary">Download .txt</button>
      </div>
    </div>

    <!-- Output -->
    <div class="card uu-output-card">
      <div class="uu-output-head">
        <span id="outputLabel">UUIDs</span>
        <button id="regenBtn" type="button" class="uu-regen-btn" title="Regenerate (Space or Enter)">↻ Regenerate</button>
      </div>
      <div id="uuidList" class="uu-list"></div>
    </div>

    <section class="article">
      <article class="card">
        <h2>UUID v4</h2>
        <p>Version 4 UUIDs are randomly generated. With 122 bits of randomness, the probability of a collision across a trillion UUIDs is negligible. Use them for database primary keys, idempotency keys, file names, and test fixtures.</p>
      </article>
      <article class="card">
        <h2>Keyboard Shortcut</h2>
        <p>Press <kbd>Space</kbd> or <kbd>Enter</kbd> anywhere on the page to regenerate. Useful when you just need one UUID quickly.</p>
      </article>
      <article class="card">
        <h2>Click to Copy</h2>
        <p>Click any UUID in the list to copy it to the clipboard individually. The copied value flashes green as confirmation.</p>
      </article>
    </section>
  </main>
</BaseLayout>

<style>
  .uu-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    margin-bottom: 0.75rem;
  }

  .uu-controls-left {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 1rem;
  }

  .uu-count-group {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .uu-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    font-weight: 700;
    color: hsl(var(--muted-foreground));
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .uu-slider {
    width: 160px;
    accent-color: hsl(var(--primary));
    cursor: pointer;
  }

  .uu-toggle-label {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    color: hsl(var(--muted-foreground));
    cursor: pointer;
  }

  .uu-toggle-label input[type="checkbox"] {
    width: auto;
    accent-color: hsl(var(--primary));
    cursor: pointer;
  }

  .uu-toggle-label:has(input:checked) {
    color: hsl(var(--foreground));
  }

  /* ── Output ── */
  .uu-output-card {
    padding: 0;
    overflow: hidden;
    margin-bottom: 1.4rem;
  }

  .uu-output-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid hsl(var(--border));
    background: hsl(var(--muted) / 0.5);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: hsl(var(--muted-foreground));
  }

  .uu-regen-btn {
    padding: 0.1rem 0.55rem;
    font-size: 0.72rem;
    font-family: "JetBrains Mono", monospace;
    font-weight: 700;
    background: hsl(var(--muted));
    border: 1px solid hsl(var(--border));
    border-radius: 0.3rem;
    color: hsl(var(--foreground));
    cursor: pointer;
    transition: border-color 0.12s;
  }

  .uu-regen-btn:hover {
    border-color: hsl(var(--primary) / 0.4);
    color: hsl(var(--primary));
  }

  .uu-list {
    padding: 0.5rem 0;
    max-height: 500px;
    overflow-y: auto;
  }

  .uu-item {
    display: flex;
    align-items: center;
    padding: 0.35rem 0.75rem;
    gap: 0.6rem;
    cursor: pointer;
    transition: background 0.1s;
    border-radius: 0;
  }

  .uu-item:hover {
    background: hsl(var(--muted) / 0.4);
  }

  .uu-item.copied {
    background: hsl(145 70% 15% / 0.5);
  }

  .uu-num {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.68rem;
    color: hsl(var(--muted-foreground));
    min-width: 1.8rem;
    text-align: right;
    user-select: none;
  }

  .uu-val {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.85rem;
    color: hsl(var(--foreground));
    flex: 1;
    letter-spacing: 0.03em;
  }

  .uu-item.copied .uu-val {
    color: hsl(145 70% 55%);
  }

  .uu-copy-hint {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.65rem;
    color: hsl(var(--muted-foreground));
    opacity: 0;
    transition: opacity 0.15s;
    user-select: none;
  }

  .uu-item:hover .uu-copy-hint {
    opacity: 1;
  }

  .uu-item.copied .uu-copy-hint {
    color: hsl(145 70% 55%);
    opacity: 1;
  }

  kbd {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8rem;
    padding: 0.1rem 0.4rem;
    background: hsl(var(--muted));
    border: 1px solid hsl(var(--border));
    border-radius: 0.3rem;
    color: hsl(var(--foreground));
  }
</style>

<script>
  const $ = (id) => document.getElementById(id);

  function genUUID() {
    return crypto.randomUUID();
  }

  function format(uuid) {
    let result = uuid;
    if ($("noHyphens").checked) result = result.replace(/-/g, "");
    if ($("uppercase").checked) result = result.toUpperCase();
    return result;
  }

  let currentUUIDs = [];

  function generate() {
    const count = Number($("countSlider").value);
    currentUUIDs = Array.from({ length: count }, genUUID);
    renderList();
  }

  function renderList() {
    const list = $("uuidList");
    const count = currentUUIDs.length;
    $("outputLabel").textContent = `${count} UUID${count !== 1 ? "s" : ""}`;

    list.innerHTML = currentUUIDs.map((uuid, i) => {
      const val = format(uuid);
      return `<div class="uu-item" data-uuid="${val}" data-idx="${i}">
        <span class="uu-num">${i + 1}</span>
        <span class="uu-val">${val}</span>
        <span class="uu-copy-hint">click to copy</span>
      </div>`;
    }).join("");

    list.querySelectorAll(".uu-item").forEach(item => {
      item.addEventListener("click", async () => {
        const val = item.dataset.uuid;
        await navigator.clipboard.writeText(val);
        item.classList.add("copied");
        item.querySelector(".uu-copy-hint").textContent = "copied!";
        setTimeout(() => {
          item.classList.remove("copied");
          item.querySelector(".uu-copy-hint").textContent = "click to copy";
        }, 1500);
      });
    });
  }

  $("countSlider").addEventListener("input", () => {
    $("countDisplay").textContent = $("countSlider").value;
  });

  $("noHyphens").addEventListener("change", renderList);
  $("uppercase").addEventListener("change", renderList);

  $("genBtn").addEventListener("click", generate);
  $("regenBtn").addEventListener("click", generate);

  $("copyAllBtn").addEventListener("click", async () => {
    const all = currentUUIDs.map(u => format(u)).join("\n");
    if (!all) return;
    await navigator.clipboard.writeText(all);
    const btn = $("copyAllBtn");
    btn.textContent = "Copied!";
    setTimeout(() => { btn.textContent = "Copy all"; }, 1600);
  });

  $("downloadBtn").addEventListener("click", () => {
    const all = currentUUIDs.map(u => format(u)).join("\n");
    if (!all) return;
    const blob = new Blob([all], { type: "text/plain" });
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = "uuids.txt";
    a.click();
    setTimeout(() => URL.revokeObjectURL(a.href), 5000);
  });

  // Keyboard shortcut
  document.addEventListener("keydown", (e) => {
    const tag = document.activeElement?.tagName?.toLowerCase();
    if (tag === "input" || tag === "textarea" || tag === "select") return;
    if (e.code === "Space" || e.code === "Enter") {
      e.preventDefault();
      generate();
    }
  });

  // Generate one on load
  generate();
</script>
