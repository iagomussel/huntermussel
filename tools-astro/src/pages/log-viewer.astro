---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Log Viewer | HunterMussel Tools"
  description="Filter, summarize, and inspect logs with quick in-browser analysis."
  canonicalPath="/tools/log-viewer/"
>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">tool / observability</p>
      <h1>Log Viewer</h1>
      <p class="lead">
        Parse plain logs, filter by level/keyword, and generate quick counts for
        incident triage.
      </p>
      <a class="back-link" href="/tools/">Back to tools index</a>
    </section>

    <section class="tool-layout">
      <article class="card stack">
        <label class="label" for="logsInput">Raw logs</label>
        <textarea id="logsInput" placeholder='2026-01-01T12:01:02Z INFO service started
2026-01-01T12:01:04Z WARN cache miss key=user:2
2026-01-01T12:01:08Z ERROR db timeout'></textarea>
        <label class="label" for="logLevelFilter">Level filter</label>
        <select id="logLevelFilter">
          <option value="ALL" selected>ALL</option>
          <option value="INFO">INFO</option>
          <option value="WARN">WARN</option>
          <option value="ERROR">ERROR</option>
          <option value="DEBUG">DEBUG</option>
        </select>
        <label class="label" for="logTextFilter">Text filter</label>
        <input id="logTextFilter" type="text" placeholder="timeout" />
        <button id="analyzeLogsBtn" type="button">Analyze logs</button>
      </article>

      <aside class="card stack">
        <div class="result">
          Summary
          <pre id="logSummary" class="small"></pre>
        </div>
        <div class="result">
          Filtered lines
          <pre id="logFiltered" class="mono"></pre>
        </div>
      </aside>
    </section>
  </main>
</BaseLayout>

<script>
  const $ = (id) => document.getElementById(id);

  function extractLevel(line) {
    const m = line.match(/\b(INFO|WARN|ERROR|DEBUG|TRACE)\b/i);
    return m ? m[1].toUpperCase() : "UNKNOWN";
  }

  $("analyzeLogsBtn").addEventListener("click", () => {
    const lines = (($("logsInput")).value || "")
      .split(/\r?\n/)
      .map((l) => l.trim())
      .filter(Boolean);

    const levelFilter = $("logLevelFilter").value;
    const textFilter = (($("logTextFilter")).value || "").toLowerCase();

    const counts = { INFO: 0, WARN: 0, ERROR: 0, DEBUG: 0, TRACE: 0, UNKNOWN: 0 };
    lines.forEach((line) => {
      const level = extractLevel(line);
      counts[level] = (counts[level] || 0) + 1;
    });

    const filtered = lines.filter((line) => {
      const level = extractLevel(line);
      const levelOk = levelFilter === "ALL" ? true : level === levelFilter;
      const textOk = textFilter ? line.toLowerCase().includes(textFilter) : true;
      return levelOk && textOk;
    });

    $("logSummary").textContent = [
      `Total lines: ${lines.length}`,
      `INFO: ${counts.INFO}`,
      `WARN: ${counts.WARN}`,
      `ERROR: ${counts.ERROR}`,
      `DEBUG: ${counts.DEBUG}`,
      `TRACE: ${counts.TRACE}`,
      `UNKNOWN: ${counts.UNKNOWN}`,
      `Filtered lines: ${filtered.length}`,
    ].join("\n");

    $("logFiltered").textContent = filtered.join("\n") || "No matching log lines.";
  });
</script>
