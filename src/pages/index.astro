---
import Layout from "@/layouts/Layout.astro";
import HomePage from "@/components/react/HomePage";
import { homeFAQ } from "@/data/faq";
import { ORGANIZATION_ID, WEBSITE_ID, organizationSchema, websiteSchema } from "@/lib/schema";

const homepageUrl = "https://huntermussel.com/";
const homepageSchema = [
  organizationSchema({
    description:
      "HunterMussel helps companies build scalable software, AI automation workflows, cloud infrastructure, and technical SEO systems.",
    email: "contact@huntermussel.com",
    founder: {
      "@type": "Person",
      name: "Iago Mussel",
      url: "https://huntermussel.com/about/",
    },
    sameAs: [
      "https://www.linkedin.com/in/iago-mussel/",
      "https://github.com/iagomussel",
    ],
    areaServed: "Worldwide",
    knowsAbout: [
      "AI automation",
      "custom software development",
      "DevOps engineering",
      "cloud infrastructure",
      "technical SEO",
    ],
    contactPoint: {
      "@type": "ContactPoint",
      contactType: "sales",
      email: "contact@huntermussel.com",
      availableLanguage: ["English", "Portuguese"],
    },
  }),
  websiteSchema(),
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "AI Automation, DevOps, and Custom Software Development",
    url: homepageUrl,
    description:
      "HunterMussel helps companies build scalable software, AI automation workflows, cloud infrastructure, and technical SEO systems.",
    isPartOf: {
      "@id": WEBSITE_ID,
    },
    mainEntity: {
      "@id": ORGANIZATION_ID,
    },
    about: [
      "AI automation",
      "DevOps engineering",
      "custom software development",
      "technical SEO",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: homeFAQ.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<Layout
  title="AI Automation, DevOps & Custom Software Development"
  description="HunterMussel helps companies build scalable software, AI automation workflows, cloud infrastructure, and technical SEO systems."
  canonicalUrl={homepageUrl}
  keywords={[
    "ai automation agency",
    "custom software development company",
    "devops consulting",
    "devops practices",
    "devops best practices",
    "cloud infrastructure engineering",
    "technical seo services",
    "ai integration company",
    "workflow automation consulting",
    "scalable software architecture",
    "custom software development",
    "devops engineering",
    "continuous integration tools",
    "containerization technologies",
    "best it firms to work for",
    "HunterMussel",
  ]}
  schema={homepageSchema}
  pageData={{ pageType: 'home' }}
>
  <HomePage lang="en" client:load />
</Layout>
