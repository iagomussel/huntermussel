---
import Layout from "@/layouts/Layout.astro";
import HeroSection from "@/components/react/HeroSection";
import ServicesSection from "@/components/react/ServicesSection";
import CasesSection from "@/components/react/CasesSection";
import AboutSection from "@/components/react/AboutSection";
import TechSection from "@/components/react/TechSection";
import ContactSection from "@/components/react/ContactSection";
import ToolsSection from "@/components/react/ToolsSection";
import { ORGANIZATION_ID, WEBSITE_ID, organizationSchema, websiteSchema } from "@/lib/schema";

const homepageUrl = "https://huntermussel.com/";
const homepageSchema = [
  organizationSchema({
    description:
      "HunterMussel helps companies build scalable software, AI automation workflows, cloud infrastructure, and technical SEO systems.",
    email: "contact@huntermussel.com",
    founder: {
      "@type": "Person",
      name: "Iago Mussel",
      url: "https://huntermussel.com/about/",
    },
    sameAs: [
      "https://www.linkedin.com/in/iago-mussel/",
      "https://github.com/iagomussel",
    ],
    areaServed: "Worldwide",
    knowsAbout: [
      "AI automation",
      "custom software development",
      "DevOps engineering",
      "cloud infrastructure",
      "technical SEO",
    ],
    contactPoint: {
      "@type": "ContactPoint",
      contactType: "sales",
      email: "contact@huntermussel.com",
      availableLanguage: ["English", "Portuguese"],
    },
  }),
  websiteSchema(),
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "AI Automation, DevOps, and Custom Software Development",
    url: homepageUrl,
    description:
      "HunterMussel helps companies build scalable software, AI automation workflows, cloud infrastructure, and technical SEO systems.",
    isPartOf: {
      "@id": WEBSITE_ID,
    },
    mainEntity: {
      "@id": ORGANIZATION_ID,
    },
    about: [
      "AI automation",
      "DevOps engineering",
      "custom software development",
      "technical SEO",
    ],
  },
];
---

<Layout
  title="AI Automation, DevOps & Custom Software Development"
  description="HunterMussel helps companies build scalable software, AI automation workflows, cloud infrastructure, and technical SEO systems."
  canonicalUrl={homepageUrl}
  keywords={[
    "ai automation agency",
    "custom software development company",
    "devops consulting",
    "cloud infrastructure engineering",
    "technical seo services",
    "ai integration company",
    "workflow automation consulting",
    "scalable software architecture",
    "custom software development",
    "devops engineering",
    "HunterMussel",
  ]}
  schema={homepageSchema}
>
  <HeroSection client:load />
  <ServicesSection client:load />
  <CasesSection client:load />
  <AboutSection client:load />
  <TechSection client:load />
  <ToolsSection client:load />
  <ContactSection client:load />
</Layout>
