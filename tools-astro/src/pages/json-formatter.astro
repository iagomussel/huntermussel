---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="JSON Formatter / Validator | HunterMussel Tools"
  description="Validate, format, and minify JSON payloads with parser feedback."
  canonicalPath="/tools/json-formatter/"
>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">tool / validation</p>
      <h1>JSON Formatter / Validator</h1>
      <p class="lead">
        Clean and validate JSON payloads before shipping API configs, templates,
        or deployment manifests.
      </p>
      <a class="back-link" href="/tools/">Back to tools index</a>
    </section>

    <section class="tool-layout">
      <article class="card stack">
        <div>
          <label class="label" for="jsonInput">Input JSON</label>
          <textarea id="jsonInput" placeholder='{"name":"hunter","enabled":true}'></textarea>
        </div>
        <div class="actions">
          <button id="jsonValidateBtn" type="button">Validate</button>
          <button id="jsonFormatBtn" type="button">Format (2 spaces)</button>
          <button id="jsonMinifyBtn" class="secondary" type="button">Minify</button>
          <button id="jsonCopyBtn" class="secondary" type="button">Copy output</button>
        </div>
      </article>

      <aside class="card stack">
        <div class="result">
          Status
          <strong id="jsonStatus">Waiting input</strong>
          <span id="jsonHint" class="small">Run validate to check syntax.</span>
        </div>
        <div class="result">
          Output
          <pre id="jsonOutput" class="mono"></pre>
        </div>
      </aside>
    </section>

    <section class="article">
      <article class="card">
        <h2>What It Does</h2>
        <p>
          Validates JSON syntax, prettifies payloads for readability, and
          minifies for transport/storage efficiency.
        </p>
      </article>
      <article class="card">
        <h2>Why It Matters</h2>
        <p>
          Invalid JSON is a high-frequency source of integration failures in
          APIs, IaC files, and environment configs. Fast parser feedback reduces
          avoidable debugging time.
        </p>
      </article>
      <article class="card">
        <h2>How To Use</h2>
        <ul>
          <li>Paste raw JSON payload.</li>
          <li>Run <code>Validate</code> for syntax checks.</li>
          <li>Use <code>Format</code> during editing/review.</li>
          <li>Use <code>Minify</code> for compact transport output.</li>
        </ul>
      </article>
    </section>
  </main>
</BaseLayout>

<script>
  const $ = (id) => document.getElementById(id);

  function parseInput() {
    const raw = $("jsonInput").value || "";
    return JSON.parse(raw);
  }

  function setJsonResult(status, hint, output = "") {
    $("jsonStatus").textContent = status;
    $("jsonHint").textContent = hint;
    $("jsonOutput").textContent = output;
  }

  $("jsonValidateBtn").addEventListener("click", () => {
    try {
      parseInput();
      setJsonResult("Valid JSON", "Parser accepted payload.");
    } catch (error) {
      setJsonResult("Invalid JSON", String(error), "");
    }
  });

  $("jsonFormatBtn").addEventListener("click", () => {
    try {
      const parsed = parseInput();
      const formatted = JSON.stringify(parsed, null, 2);
      setJsonResult("Formatted", "Payload formatted with 2-space indentation.", formatted);
    } catch (error) {
      setJsonResult("Invalid JSON", String(error), "");
    }
  });

  $("jsonMinifyBtn").addEventListener("click", () => {
    try {
      const parsed = parseInput();
      const minified = JSON.stringify(parsed);
      setJsonResult("Minified", "Payload minified successfully.", minified);
    } catch (error) {
      setJsonResult("Invalid JSON", String(error), "");
    }
  });

  $("jsonCopyBtn").addEventListener("click", async () => {
    const out = $("jsonOutput").textContent || "";
    if (!out) return;
    await navigator.clipboard.writeText(out);
    $("jsonHint").textContent = "Output copied to clipboard.";
  });
</script>
