    padding: 0.45rem 0.75rem;
    background: #090b11;
    color: #8f9aa6;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    border-bottom: 1px solid #1c2535;
  }

