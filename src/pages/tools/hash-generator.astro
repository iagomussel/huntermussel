---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ServiceCTA from "@/components/ServiceCTA.astro";
---

<BaseLayout
  title="Hash Generator | HunterMussel Tools"
  description="Generate and verify MD5/SHA hashes for text payloads."
  canonicalPath="/tools/hash-generator/"
  keywords={[
    "hash generator online",
    "md5 hash generator",
    "sha256 generator",
    "sha-512 hash tool",
    "sha-1 generator online",
    "checksum generator",
    "hash verification tool",
    "cryptographic hash online",
    "free hash generator",
  ]}
>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">tool / hashing</p>
      <h1>Hash Generator</h1>
      <p class="lead">
        Generate and verify hashes for payload integrity checks and release
        validation workflows.
      </p>
      <a class="back-link" href="/tools/">Back to tools index</a>
    </section>

    <section class="tool-layout">
      <article class="card stack">
        <div>
          <label class="label" for="hashInput">Input text</label>
          <textarea id="hashInput" placeholder="Paste the exact text payload here..."></textarea>
        </div>
        <div>
          <label class="label" for="hashAlgorithm">Algorithm</label>
          <select id="hashAlgorithm">
            <option value="MD5">MD5</option>
            <option value="SHA-1">SHA-1</option>
            <option value="SHA-256" selected>SHA-256</option>
            <option value="SHA-384">SHA-384</option>
            <option value="SHA-512">SHA-512</option>
          </select>
        </div>
        <div>
          <label class="label" for="expectedHash">Expected hash (optional)</label>
          <input id="expectedHash" type="text" placeholder="Paste expected hash to verify..." />
        </div>
        <div class="actions">
          <button id="genHashBtn" type="button">Generate hash</button>
        </div>
      </article>

      <aside class="card stack">
        <div class="result">
          Status
          <strong id="hashStatus">Waiting input</strong>
          <span id="hashHint" class="small">Select algorithm and generate.</span>
        </div>
        <div class="result">
          Hash output
          <pre id="hashOutput" class="mono"></pre>
        </div>
      </aside>
    </section>

    <section class="article">
      <article class="card">
        <h2>What It Does</h2>
        <p>
          Produces deterministic hashes from text input using MD5, SHA-1,
          SHA-256, SHA-384, or SHA-512, and compares output against an expected
          hash when provided.
        </p>
      </article>
      <article class="card">
        <h2>Why It Matters</h2>
        <p>
          Hashes are core for integrity verification in CI/CD artifacts, API
          signatures, and environment consistency checks.
        </p>
      </article>
      <article class="card">
        <h2>How To Use</h2>
        <ul>
          <li>Paste exact input content (including line breaks).</li>
          <li>Select required algorithm from your target system.</li>
          <li>Optional: provide expected hash to instantly verify match/mismatch.</li>
        </ul>
      </article>
      <ServiceCTA
        service="security-compliance"
        title="Need a security audit for your data integrity systems?"
        description="HunterMussel helps teams implement secure hashing, encryption, and compliance frameworks — covering GDPR/LGPD, artifact integrity, and API signature verification."
        linkLabel="Explore Security & Compliance"
      />
    </section>
  </main>
</BaseLayout>

<script>
  import CryptoJS from "crypto-js";

  const $ = (id) => document.getElementById(id);

  const toHex = (buffer) => {
    const bytes = new Uint8Array(buffer);
    return Array.from(bytes)
      .map((b) => b.toString(16).padStart(2, "0"))
      .join("");
  };

  async function digest(text, algorithm) {
    if (algorithm === "MD5") {
      return CryptoJS.MD5(text).toString(CryptoJS.enc.Hex);
    }

    const data = new TextEncoder().encode(text);
    const hashBuffer = await crypto.subtle.digest(algorithm, data);
    return toHex(hashBuffer);
  }

  $("genHashBtn").addEventListener("click", async () => {
    const input = $("hashInput").value || "";
    const algorithm = $("hashAlgorithm").value;
    const expected = ($("expectedHash").value || "").trim().toLowerCase();

    if (!input) {
      $("hashStatus").textContent = "Empty input";
      $("hashHint").textContent = "Add text to hash.";
      $("hashOutput").textContent = "";
      return;
    }

    try {
      const output = await digest(input, algorithm);
      $("hashOutput").textContent = output;

      if (!expected) {
        $("hashStatus").textContent = "Generated";
        $("hashHint").textContent = `${algorithm} hash generated successfully.`;
        return;
      }

      const match = output === expected;
      $("hashStatus").textContent = match ? "Match" : "Mismatch";
      $("hashHint").textContent = match
        ? "Output matches expected hash."
        : "Output does not match expected hash.";
    } catch {
      $("hashStatus").textContent = "Error";
      $("hashHint").textContent = "Failed to generate hash.";
      $("hashOutput").textContent = "";
    }
  });
</script>
