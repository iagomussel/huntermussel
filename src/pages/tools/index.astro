---
import Layout from "@/layouts/Layout.astro";

const toolsUrl = "https://huntermussel.com/tools/";

const categories = [
  {
    id: "ai",
    label: "AI Tools",
    badge: "new",
    description: "Prompt engineering, workflow optimization, and AI-powered utilities for the era of intelligent automation.",
    tools: [
      {
        name: "Prompt Optimizer",
        slug: "prompt-optimizer",
        desc: "Multi-step wizard that assembles production-ready prompts for Claude, GPT-4, Gemini and open-source models — deterministic, no API calls.",
        badge: "new",
        icon: `<path d="M9.663 17h4.673M12 3v1m6.364 1.636-.707.707M21 12h-1M4 12H3m3.343-5.657-.707-.707m2.828 9.9a5 5 0 1 1 7.072 0l-.548.547A3.374 3.374 0 0 0 14 18.469V19a2 2 0 1 1-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>`,
      },
    ],
  },
  {
    id: "encoding",
    label: "Encoding & Crypto",
    description: "Encode, decode, hash, and generate unique identifiers for data pipelines and API integrations.",
    tools: [
      {
        name: "Base64 Converter",
        slug: "base64-converter",
        desc: "Convert, validate, and repair Base64/Base64URL payloads fully client-side.",
        icon: `<rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6M9 12h6M9 15h4"/>`,
      },
      {
        name: "Hash Generator",
        slug: "hash-generator",
        desc: "Generate and verify MD5, SHA-1, SHA-256, SHA-384, and SHA-512 hashes instantly.",
        icon: `<line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/>`,
      },
      {
        name: "UUID Generator",
        slug: "uuid",
        desc: "Generate up to 100 UUID v4 values instantly. Toggle hyphens, copy all, or download as text.",
        icon: `<rect x="2" y="7" width="20" height="10" rx="2"/><path d="M7 12h.01M12 12h.01M17 12h.01"/>`,
      },
    ],
  },
  {
    id: "data",
    label: "Data & Formats",
    description: "Parse, convert, compare, and validate JSON, YAML, and other structured data formats used in APIs and config files.",
    tools: [
      {
        name: "YAML ↔ JSON",
        slug: "yaml-json",
        desc: "Bidirectional YAML and JSON converter with real-time validation and inline error reporting. No server, no logs.",
        icon: `<path d="M7 16V4m0 0L3 8m4-4 4 4M17 8v12m0 0 4-4m-4 4-4-4"/>`,
      },
      {
        name: "Diff Viewer",
        slug: "diff-viewer",
        desc: "Compare two texts side-by-side or unified — added, removed, and unchanged lines highlighted instantly.",
        icon: `<line x1="21" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="21" y1="18" x2="12" y2="18"/>`,
      },
    ],
  },
  {
    id: "devops",
    label: "DevOps",
    description: "Essential tools for infrastructure engineers — cron scheduling, file permissions, uptime calculations, and log analysis.",
    tools: [
      {
        name: "Cron Parser",
        slug: "cron-parser",
        desc: "Translate cron expressions into plain English and preview the next scheduled run times.",
        icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
      },
      {
        name: "Timestamp Converter",
        slug: "timestamp",
        desc: "Convert Unix timestamps (seconds or ms) to UTC, local time, and relative time — and back.",
        icon: `<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
      },
      {
        name: "chmod Calculator",
        slug: "chmod",
        desc: "Click checkboxes or type an octal to get symbolic notation and a ready-to-copy chmod command.",
        icon: `<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>`,
      },
      {
        name: "SLA Calculator",
        slug: "sla-calculator",
        desc: "Enter an uptime percentage and see exact downtime per day, week, month, and year.",
        icon: `<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>`,
      },
      {
        name: "Log Viewer",
        slug: "log-viewer",
        desc: "Parse, filter, and inspect structured log files directly in the browser.",
        icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="16" y2="17"/>`,
      },
    ],
  },
  {
    id: "security",
    label: "Security & Auth",
    description: "Inspect and audit authentication tokens, claims, and access control permissions without sending data to any server.",
    tools: [
      {
        name: "JWT Inspector",
        slug: "jwt-inspector",
        desc: "Decode, inspect, and audit JWT tokens — expiry countdown, claim explanations, and security warnings.",
        icon: `<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>`,
      },
    ],
  },
  {
    id: "code",
    label: "Code & Text",
    description: "Lint code in real time, test regex patterns, and write formatted documentation with live preview.",
    tools: [
      {
        name: "Regex Tester",
        slug: "regex-tester",
        desc: "Live regex matching with coloured capture groups, match positions, and one-click common patterns.",
        icon: `<path d="M3 3l18 0M3 9l18 0M3 15l10 0"/><circle cx="17" cy="15" r="3"/><path d="m20.2 18.2 1.8 1.8"/>`,
      },
      {
        name: "Online Linters",
        slug: "online-linters",
        desc: "Real-time code linter for JSON, YAML, JavaScript, and Markdown powered by Monaco Editor.",
        icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
      },
      {
        name: "Markdown Editor",
        slug: "markdown-editor",
        desc: "Live Markdown editor with preview, export, and formatting shortcuts.",
        icon: `<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>`,
      },
    ],
  },
  {
    id: "media",
    label: "Media & Files",
    description: "Optimize, convert, crop, resize, and dissect images in the browser — nothing is uploaded to any server.",
    tools: [
      {
        name: "Image Optimizer",
        slug: "image-optimizer",
        desc: "Convert images to WebP in-browser. Adjust quality, resize, batch download — zero server uploads.",
        badge: "popular",
        icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>`,
      },
      {
        name: "Image Crop",
        slug: "image-crop",
        desc: "Drag handles to crop any image. Lock aspect ratios, enter exact pixel coordinates, download as PNG — no uploads.",
        icon: `<path d="M6 2v14a2 2 0 0 0 2 2h14"/><path d="M18 22V8a2 2 0 0 0-2-2H2"/>`,
      },
      {
        name: "Image Resize",
        slug: "image-resize",
        desc: "Resize images by exact pixels, percentage, or fit-box. Batch process up to 20 files, export PNG/JPEG/WebP.",
        icon: `<polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>`,
      },
      {
        name: "Sprite Sheet Splitter",
        slug: "sprite-splitter",
        desc: "Extract individual sprites from a sheet using alpha transparency or a color-key background. Download as separate PNGs.",
        icon: `<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>`,
      },
      {
        name: "Sprite Asset Detector",
        slug: "sprite-detector",
        desc: "Visualize bounding boxes for every sprite on a sheet. Export an annotated PNG or a JSON atlas for Phaser, PixiJS, or Unity.",
        icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/><path d="M9 3v3M15 3v3M9 18v3M15 18v3M3 9h3M3 15h3M18 9h3M18 15h3"/>`,
      },
      {
        name: "Background Remover",
        slug: "background-remover",
        desc: "Remove or replace a solid background color. Click to sample, set tolerance, export transparent PNG — ideal for sprites and logos.",
        icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="m9 15 3-3 3 3"/><path d="M3 9h18"/>`,
      },
    ],
  },
  {
    id: "reference",
    label: "Reference & Planning",
    description: "Quick-access reference guides and estimation calculators for software development teams.",
    tools: [
      {
        name: "HTTP Status Codes",
        slug: "http-status",
        desc: "Search and filter all HTTP status codes with plain-English descriptions and REST API guidance.",
        icon: `<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>`,
      },
      {
        name: "Estimators",
        slug: "estimators",
        desc: "Project and effort estimation tools including Planning Poker and T-shirt sizing for engineering teams.",
        icon: `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/>`,
      },
    ],
  },
];

const allTools = categories.flatMap((c) => c.tools);
const totalTools = allTools.length;
const totalCategories = categories.length;

const faqItems = [
  {
    q: "What is Base64 encoding and when should I use it?",
    a: "Base64 is a binary-to-text encoding scheme that converts binary data into ASCII characters. It's widely used to safely transmit binary data (like images or files) over text-based protocols such as HTTP headers, JSON APIs, and email attachments. Use our Base64 Converter to encode or decode instantly in your browser.",
  },
  {
    q: "How do I decode and inspect a JWT token?",
    a: "A JWT (JSON Web Token) consists of three Base64URL-encoded parts: header, payload, and signature. You can decode the header and payload without the secret key using our JWT Inspector — it also shows claim meanings, expiry countdown, and security warnings like weak algorithms or missing claims.",
  },
  {
    q: "What does a cron expression like '0 9 * * 1-5' mean?",
    a: "That cron expression means 'run at 09:00 every weekday (Monday through Friday)'. Cron expressions have five fields: minute, hour, day-of-month, month, and day-of-week. Our Cron Parser translates any cron expression into plain English and shows the next 10 upcoming run times.",
  },
  {
    q: "How do I calculate chmod permissions?",
    a: "Unix chmod permissions use an octal notation (e.g. 755) representing read/write/execute rights for owner, group, and others. Our chmod Calculator lets you click checkboxes to build permissions visually or type an octal to get the symbolic notation (e.g. rwxr-xr-x) and a ready-to-copy chmod command.",
  },
  {
    q: "What is a Prompt Optimizer and how does it work?",
    a: "A Prompt Optimizer helps you write better prompts for AI models like Claude, GPT-4, and Gemini. Our tool walks you through 5 questions — target platform, task type, output format, response length, and your task description — then assembles a production-ready prompt using proven prompt engineering techniques like role assignment, output format specification, and model-specific formatting. It's entirely deterministic: no AI API calls, runs fully in your browser.",
  },
  {
    q: "How do I convert YAML to JSON (and back)?",
    a: "YAML and JSON are both widely used data serialization formats. YAML is human-readable and common in DevOps configuration files (Docker, Kubernetes, GitHub Actions), while JSON is the standard for APIs and web data. Our YAML ↔ JSON converter transforms between both formats instantly with real-time validation.",
  },
  {
    q: "Are these developer tools safe? Is my data private?",
    a: "Yes — every tool on this page runs entirely in your browser using Web APIs. No data is sent to any server. Your code, tokens, files, and text never leave your machine. This includes sensitive tools like the JWT Inspector and Hash Generator.",
  },
  {
    q: "What is SLA uptime and how is downtime calculated?",
    a: "SLA (Service Level Agreement) uptime refers to the guaranteed percentage of time a service will be available. '99.9% uptime' (three nines) means a maximum of 8.76 hours of downtime per year. Our SLA Calculator shows exact allowed downtime per day, week, month, and year for any uptime percentage.",
  },
];

const toolsSchema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Free Developer Tools — HunterMussel",
    url: toolsUrl,
    description:
      `Free browser-based developer tools organized by category: AI prompt engineering, encoding & crypto, data formats, DevOps, security, code & text, media, and reference. ${totalTools} tools across ${totalCategories} categories. No account, no uploads.`,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://huntermussel.com/" },
      { "@type": "ListItem", position: 2, name: "Tools", item: toolsUrl },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "Free Developer Tools by Category",
    url: toolsUrl,
    numberOfItems: totalTools,
    itemListElement: allTools.map((tool, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `https://huntermussel.com/tools/${tool.slug}/`,
      name: tool.name,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.q,
      acceptedAnswer: { "@type": "Answer", text: item.a },
    })),
  },
];
---

<Layout
  title="Free Developer Tools by Category: AI, Encoding, DevOps, Security & More"
  description={`${totalTools} free browser-based developer tools organized by category — AI prompt optimizer, Base64, JWT, JSON, Cron, regex, and more. No account, no uploads, everything runs in your browser.`}
  canonicalUrl={toolsUrl}
  keywords={[
    "free developer tools",
    "online developer utilities",
    "prompt optimizer tool",
    "base64 converter online",
    "jwt decoder online",
    "json formatter online",
    "cron expression parser",
    "regex tester online",
    "yaml to json converter",
    "chmod calculator",
    "hash generator online",
    "unix timestamp converter",
    "uuid generator online",
    "sla uptime calculator",
    "http status codes reference",
    "devops tools online",
    "ai prompt engineering tool",
    "browser developer tools",
    "client side tools no upload",
  ]}
  schema={toolsSchema}
>
  <div class="tools-page">
    <!-- Hero -->
    <div class="tools-hero">
      <div class="tools-container">
        <span class="tools-eyebrow">// tools</span>
        <h1 class="tools-title">Free Developer Tools</h1>
        <p class="tools-lead">
          {totalTools} client-side utilities across {totalCategories} categories — AI prompts, encoding, DevOps, security, and more.
          No account, no uploads, no tracking. Everything runs in your browser.
        </p>
        <div class="tools-stats">
          {categories.map((cat) => (
            <span class="tools-stat">
              <strong>{cat.tools.length}</strong> {cat.label}
            </span>
          ))}
        </div>
      </div>
    </div>

    <!-- Filter tabs -->
    <div class="tools-filter-wrap">
      <div class="tools-container">
        <div class="tools-filters" role="tablist" aria-label="Filter tools by category">
          <button class="filter-btn active" data-filter="all" role="tab" aria-selected="true">
            All <span class="filter-count">{totalTools}</span>
          </button>
          {categories.map((cat) => (
            <button class="filter-btn" data-filter={cat.id} role="tab" aria-selected="false">
              {cat.label}
              {cat.badge && <span class="filter-badge">{cat.badge}</span>}
              <span class="filter-count">{cat.tools.length}</span>
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- Category sections -->
    <div class="tools-container tools-body">
      {categories.map((cat) => (
        <section class="cat-section" data-category-section={cat.id}>
          <div class="cat-header">
            <div class="cat-header-left">
              <h2 class="cat-title">
                {cat.label}
                {cat.badge && <span class="cat-badge">{cat.badge}</span>}
              </h2>
              <p class="cat-desc">{cat.description}</p>
            </div>
            <span class="cat-count">{cat.tools.length} {cat.tools.length === 1 ? "tool" : "tools"}</span>
          </div>
          <div class="tools-grid">
            {cat.tools.map((tool) => (
              <a href={`/tools/${tool.slug}`} class={`tool-card${tool.badge ? " tool-card--new" : ""}`}>
                {tool.badge && <span class="tool-badge">{tool.badge}</span>}
                <span class="tool-cat">// {cat.id}</span>
                <div class="tool-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={tool.icon} />
                </div>
                <h3 class="tool-name">{tool.name}</h3>
                <p class="tool-desc">{tool.desc}</p>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    <!-- SEO Article + FAQ -->
    <div class="tools-article-wrap">
      <div class="tools-container">
        <div class="seo-grid">
          <article class="seo-card">
            <h2>Why use browser-based developer tools?</h2>
            <p>
              Browser-based tools run entirely in your machine using Web APIs like
              <code>SubtleCrypto</code>, <code>Canvas</code>, <code>FileReader</code>, and <code>TextEncoder</code>.
              Unlike server-side tools, your code, tokens, and files never leave your device —
              which is critical when working with JWTs, API keys, sensitive logs, or proprietary source code.
            </p>
            <ul>
              <li><strong>Privacy by design:</strong> Zero data transmission. Zero storage.</li>
              <li><strong>Works offline:</strong> Once loaded, tools keep working without internet.</li>
              <li><strong>No rate limits:</strong> Process as much data as your browser allows.</li>
              <li><strong>Instant:</strong> No round-trip latency. Results appear as you type.</li>
            </ul>
          </article>
          <article class="seo-card">
            <h2>What is a Prompt Optimizer?</h2>
            <p>
              A Prompt Optimizer is a structured tool that helps you apply prompt engineering best practices
              without having to memorize them. Instead of writing prompts from scratch, you answer 5 targeted
              questions about your use case and the tool assembles a production-ready prompt.
            </p>
            <p>
              Our Prompt Optimizer supports Claude, GPT-4, Gemini, and open-source models. It applies
              model-specific techniques: XML tags for Claude, system/user message separation for GPT,
              and instruction-following format for open-source models. The result is always deterministic —
              no AI API calls needed.
            </p>
          </article>
        </div>

        <section class="faq-section">
          <h2 class="faq-title">Frequently Asked Questions</h2>
          <dl class="faq-list">
            {faqItems.map((item) => (
              <div class="faq-item">
                <dt class="faq-q">{item.q}</dt>
                <dd class="faq-a">{item.a}</dd>
              </div>
            ))}
          </dl>
        </section>
      </div>
    </div>
  </div>
</Layout>

<style>
  .tools-page {
    min-height: 100vh;
  }

  /* ── Hero ── */
  .tools-hero {
    border-b: 1px solid hsl(var(--border));
    padding: 5rem 0 3rem;
    background: linear-gradient(180deg, hsl(var(--card) / 0.4) 0%, transparent 100%);
  }

  .tools-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .tools-eyebrow {
    display: block;
    font-family: var(--font-heading, "JetBrains Mono", monospace);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: hsl(var(--primary));
    margin-bottom: 0.75rem;
  }

  .tools-title {
    margin: 0 0 1rem;
    font-family: var(--font-heading, "JetBrains Mono", monospace);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    color: hsl(var(--foreground));
    letter-spacing: -0.02em;
  }

  .tools-lead {
    margin: 0 0 1.5rem;
    max-width: 60ch;
    font-size: 1rem;
    line-height: 1.6;
    color: hsl(var(--muted-foreground));
  }

  .tools-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
  }

  .tools-stat {
    font-size: 0.78rem;
    color: hsl(var(--muted-foreground));
  }

  .tools-stat strong {
    color: hsl(var(--primary));
    font-family: var(--font-heading, "JetBrains Mono", monospace);
  }

  /* ── Filter tabs ── */
  .tools-filter-wrap {
    position: sticky;
    top: 4rem;
    z-index: 10;
    background: hsl(var(--background) / 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid hsl(var(--border));
    padding: 0.6rem 0;
  }

  .tools-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    padding-bottom: 2px;
  }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
    padding: 0.25rem 0.55rem;
    border: 1px solid hsl(var(--border));
    border-radius: 999px;
    background: transparent;
    font-family: var(--font-heading, "JetBrains Mono", monospace);
    font-size: 0.68rem;
    font-weight: 600;
    color: hsl(var(--muted-foreground));
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
    white-space: nowrap;
  }

  .filter-btn:hover {
    border-color: hsl(var(--primary) / 0.4);
    color: hsl(var(--foreground));
    background: transparent;
    box-shadow: none;
    opacity: 1;
  }

  .filter-btn.active {
    border-color: hsl(var(--primary));
    color: hsl(var(--primary));
    background: hsl(var(--primary) / 0.08);
  }

  .filter-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.2rem;
    height: 1.2rem;
    padding: 0 0.25rem;
    border-radius: 999px;
    background: hsl(var(--muted));
    font-size: 0.6rem;
    color: hsl(var(--muted-foreground));
  }

  .filter-badge {
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: hsl(var(--primary));
    background: hsl(var(--primary) / 0.12);
    padding: 0.05rem 0.3rem;
    border-radius: 999px;
  }

  /* ── Body / category sections ── */
  .tools-body {
    padding-top: 2.5rem;
    padding-bottom: 1rem;
  }

  .cat-section {
    margin-bottom: 3rem;
  }

  .cat-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
