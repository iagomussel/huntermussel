---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ServiceCTA from "@/components/ServiceCTA.astro";
---

<BaseLayout
  title="Sprite Asset Detector | HunterMussel Tools"
  description="Visualize sprite bounding boxes on a sheet. Detect sprites by alpha or color key and see each asset's position and size overlaid on the original image — fully in-browser."
  canonicalPath="/tools/sprite-detector/"
  keywords={[
    "sprite asset detector",
    "sprite bounding box",
    "sprite sheet analyzer",
    "detect sprites online",
    "sprite atlas inspector",
    "game sprite tool",
    "alpha sprite detection",
    "color key sprite detector",
    "sprite coordinates browser",
    "client side sprite inspector",
  ]}
>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">tool / imaging</p>
      <h1>Sprite Asset Detector</h1>
      <p class="lead">
        Upload a sprite sheet and visualize bounding boxes for every detected asset.
        Uses alpha transparency or a color key to identify sprites — exports a JSON
        atlas or annotated preview image.
      </p>
      <a class="back-link" href="/tools/">Back to tools index</a>
    </section>

    <section class="sd-top">
      <!-- Drop zone -->
      <div id="dropZone" class="card drop-zone">
        <input id="fileInput" type="file" accept="image/png,image/gif,image/webp,image/bmp,image/jpeg" style="display:none" />
        <div class="drop-inner">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          <p class="drop-label">Drop a sprite sheet here or <span class="drop-link">browse</span></p>
          <p class="small">Any image format supported</p>
        </div>
      </div>

      <!-- Settings -->
      <aside class="card stack">
        <div>
          <label class="label">Detection Mode</label>
          <div class="mode-row">
            <label class="mode-opt">
              <input type="radio" name="mode" value="alpha" checked id="modeAlpha" />
              <span>Alpha</span>
            </label>
            <label class="mode-opt">
              <input type="radio" name="mode" value="color" id="modeColor" />
              <span>Color key</span>
            </label>
          </div>
        </div>

        <div id="colorKeyGroup" style="display:none">
          <label class="label" for="colorKey">Background Color</label>
          <div class="color-row">
            <input id="colorKey" type="color" value="#00ff00" />
            <input id="colorTolerance" type="range" min="0" max="128" value="15" />
            <span id="toleranceValue" class="small">±15</span>
          </div>
          <p class="small" style="color:var(--text-2); margin-top:0.3rem;">Click the preview image to sample a color.</p>
        </div>

        <div>
          <label class="label" for="minSizeInput">
            Min size: <span id="minSizeValue">4</span>px
          </label>
          <input id="minSizeInput" type="range" min="1" max="64" value="4" />
        </div>

        <div>
          <label class="label" for="edgeSmooth">
            Edge smoothing: <span id="edgeSmoothValue">3</span>px
          </label>
          <input id="edgeSmooth" type="range" min="0" max="32" value="3" />
          <p class="small" style="color:var(--text-2); margin-top:0.25rem;">
            Fades border pixels to transparent when downloading assets.
          </p>
        </div>

        <div>
          <label class="label">Overlay Color</label>
          <input id="overlayColor" type="color" value="#00ff88" style="width:40px; height:32px; border:none; padding:0; border-radius:0.35rem; cursor:pointer;" />
        </div>

        <div id="statusBox" class="result" style="display:none">
          <strong id="statusText">Idle</strong>
          <span id="statusHint" class="small"></span>
        </div>

        <div class="actions">
          <button id="detectBtn" type="button" disabled>Detect Sprites</button>
          <button id="clearBtn" type="button" class="secondary">Clear</button>
        </div>
      </aside>
    </section>

    <!-- Canvas preview -->
    <section id="canvasSection" style="display:none">
      <div class="canvas-header">
        <h2 id="canvasTitle" class="results-title">Image Preview</h2>
        <div class="actions">
          <button id="exportImageBtn" type="button" class="secondary">Export annotated PNG</button>
          <button id="exportJsonBtn" type="button" class="secondary">Export JSON atlas</button>
        </div>
      </div>
      <div class="canvas-wrap card">
        <canvas id="annotatedCanvas" style="max-width:100%; display:block;"></canvas>
      </div>
    </section>

    <!-- Asset list -->
    <section id="assetListSection" style="display:none">
      <div class="results-header">
        <h2 class="results-title">Detected Assets</h2>
        <div class="actions">
          <button id="downloadAllSpritesBtn" type="button" class="secondary">Download all as ZIP</button>
        </div>
      </div>
      <div id="assetGrid" class="asset-grid"></div>
      <div id="assetTable" class="asset-table"></div>
    </section>

    <section class="article">
      <article class="card">
        <h2>What It Does</h2>
        <p>
          Scans a sprite sheet pixel-by-pixel using a connected-component BFS algorithm to
          locate all distinct non-background regions. Each detected region gets a labeled
          bounding box drawn over the original image so you can visually verify the detection.
          The JSON export follows the standard sprite atlas format compatible with Phaser,
          PixiJS, and Unity.
        </p>
      </article>
      <article class="card">
        <h2>How To Use</h2>
        <ul>
          <li>Drop a sprite sheet onto the canvas.</li>
          <li>Choose <strong>Alpha</strong> for transparent PNGs or <strong>Color key</strong> for solid backgrounds.</li>
          <li>Click the canvas to sample a background color when using color-key mode.</li>
          <li>Set a minimum sprite size to filter out noise.</li>
          <li>Click <strong>Detect Sprites</strong> to see overlaid bounding boxes.</li>
          <li>Adjust <strong>Edge smoothing</strong> — downloaded assets will have the background removed with a soft alpha falloff at the border.</li>
          <li>Export the annotated image or the JSON atlas for use in your game engine.</li>
        </ul>
      </article>
      <ServiceCTA
        service="workflows-bpm"
        title="Need automated sprite pipeline integration?"
        description="HunterMussel designs workflow systems that connect asset detection, atlas generation, and delivery pipelines — eliminating manual steps at scale."
        linkLabel="Explore Workflows & BPM"
      />
    </section>
  </main>
</BaseLayout>

<style>
  .sd-top {
    display: grid;
    grid-template-columns: 1.4fr 0.6fr;
    gap: 1rem;
    margin-bottom: 1.4rem;
  }

  @media (max-width: 720px) {
    .sd-top { grid-template-columns: 1fr; }
  }

  .drop-zone {
    border: 2px dashed hsl(145 80% 50% / 0.3);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    min-height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .drop-zone.drag-over {
    border-color: var(--primary);
    background: var(--primary-soft);
  }

  .drop-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    padding: 1.5rem 1rem;
    color: var(--text-2);
    text-align: center;
    pointer-events: none;
  }

  .drop-label { margin: 0; font-weight: 600; color: var(--text-1); }
  .drop-link { color: var(--primary); text-decoration: underline; cursor: pointer; pointer-events: auto; }

  .mode-row { display: flex; gap: 1rem; margin-top: 0.35rem; }
  .mode-opt { display: flex; align-items: center; gap: 0.4rem; cursor: pointer; font-size: 0.85rem; }

  .color-row {
    display: grid;
    grid-template-columns: 40px 1fr auto;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.35rem;
  }

  .canvas-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .results-title {
    margin: 0;
    font-size: 1rem;
    font-family: "JetBrains Mono", monospace;
    color: var(--text-1);
  }

  .canvas-wrap {
    overflow: auto;
    padding: 0.75rem;
    margin-bottom: 1.4rem;
  }

  .canvas-wrap.picker-mode canvas {
    cursor: crosshair;
  }

  .results-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .asset-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .asset-card {
    border: 1px solid var(--line);
    border-radius: 0.65rem;
    background: var(--card);
    overflow: hidden;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .asset-card:hover {
    border-color: hsl(145 80% 50% / 0.25);
    box-shadow: 0 0 14px var(--glow);
  }

  .asset-thumb-wrap {
    width: 100%;
    height: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: repeating-conic-gradient(#3a3a3a 0% 25%, #2a2a2a 0% 50%) 0 0 / 12px 12px;
  }

  .asset-thumb { max-width: 100%; max-height: 100%; object-fit: contain; display: block; }

  .asset-info {
    padding: 0.4rem 0.6rem;
    display: grid;
    gap: 0.15rem;
  }

  .asset-label {
    font-size: 0.75rem;
    font-weight: 700;
    font-family: "JetBrains Mono", monospace;
    color: var(--text-1);
  }

  .asset-dims {
    font-size: 0.68rem;
    color: var(--text-2);
    font-family: "JetBrains Mono", monospace;
  }

  .asset-actions { padding: 0 0.6rem 0.6rem; }
  .asset-actions button { width: 100%; font-size: 0.78rem; padding: 0.3rem 0.4rem; }

  .asset-table {
    margin-bottom: 1.4rem;
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
    font-family: "JetBrains Mono", monospace;
  }

  th {
    text-align: left;
    padding: 0.5rem 0.75rem;
    background: var(--card);
    border: 1px solid var(--line);
    color: var(--text-2);
    font-weight: 700;
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  td {
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--line);
    color: var(--text-1);
  }

  tr:nth-child(even) td { background: hsl(145 5% 8%); }
</style>

<script src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js"></script>
<script>
  const $ = (id) => document.getElementById(id);

  const dropZone = $("dropZone");
  const fileInput = $("fileInput");
  const detectBtn = $("detectBtn");
  const clearBtn = $("clearBtn");
  const modeAlpha = $("modeAlpha");
  const modeColor = $("modeColor");
  const colorKeyGroup = $("colorKeyGroup");
  const colorKey = $("colorKey");
  const colorTolerance = $("colorTolerance");
  const toleranceValue = $("toleranceValue");
  const minSizeInput = $("minSizeInput");
  const minSizeValue = $("minSizeValue");
  const edgeSmooth = $("edgeSmooth");
  const edgeSmoothValue = $("edgeSmoothValue");
  const overlayColor = $("overlayColor");
  const statusBox = $("statusBox");
  const statusText = $("statusText");
  const statusHint = $("statusHint");
  const canvasSection = $("canvasSection");
  const annotatedCanvas = $("annotatedCanvas");
  const assetListSection = $("assetListSection");
  const assetGrid = $("assetGrid");
  const assetTable = $("assetTable");
  const exportImageBtn = $("exportImageBtn");
  const exportJsonBtn = $("exportJsonBtn");
  const downloadAllSpritesBtn = $("downloadAllSpritesBtn");
  const canvasTitle = $("canvasTitle");

  let currentImage = null;
  let detectedRects = [];
  let spriteBlobs = [];
  let sourceFileName = "sheet";

  const canvasWrap = annotatedCanvas.closest(".canvas-wrap");

  function syncColorMode() {
    colorKeyGroup.style.display = modeColor.checked ? "" : "none";
    canvasWrap.classList.toggle("picker-mode", modeColor.checked);
  }

  [modeAlpha, modeColor].forEach((r) => r.addEventListener("change", syncColorMode));

  colorTolerance.addEventListener("input", () => { toleranceValue.textContent = `±${colorTolerance.value}`; });
  minSizeInput.addEventListener("input", () => { minSizeValue.textContent = minSizeInput.value; });
  edgeSmooth.addEventListener("input", () => { edgeSmoothValue.textContent = edgeSmooth.value; });

  dropZone.addEventListener("click", (e) => {
    if (!e.target.closest("button")) fileInput.click();
  });
  dropZone.addEventListener("dragover", (e) => { e.preventDefault(); dropZone.classList.add("drag-over"); });
  dropZone.addEventListener("dragleave", () => dropZone.classList.remove("drag-over"));
  dropZone.addEventListener("drop", (e) => { e.preventDefault(); dropZone.classList.remove("drag-over"); loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener("change", () => { loadFile(fileInput.files[0]); fileInput.value = ""; });

  function loadFile(file) {
    if (!file || !file.type.startsWith("image/")) return;
    sourceFileName = file.name.replace(/\.[^.]+$/, "");
    const reader = new FileReader();
    reader.onload = (e) => {
      const img = new Image();
      img.onload = () => {
        currentImage = img;
        detectBtn.disabled = false;
        // Show raw preview immediately
        annotatedCanvas.width = img.naturalWidth;
        annotatedCanvas.height = img.naturalHeight;
        annotatedCanvas.getContext("2d").drawImage(img, 0, 0);
        canvasTitle.textContent = "Image Preview";
        canvasSection.style.display = "";
        setStatus("Image loaded", `${img.naturalWidth} × ${img.naturalHeight} px`);
      };
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);
  }

  annotatedCanvas.addEventListener("click", (e) => {
    if (!modeColor.checked || !currentImage) return;
    const rect = annotatedCanvas.getBoundingClientRect();
    const scaleX = annotatedCanvas.width / rect.width;
    const scaleY = annotatedCanvas.height / rect.height;
    const x = Math.floor((e.clientX - rect.left) * scaleX);
    const y = Math.floor((e.clientY - rect.top) * scaleY);
    const ctx = annotatedCanvas.getContext("2d");
    const [r, g, b] = ctx.getImageData(x, y, 1, 1).data;
    colorKey.value = "#" + [r, g, b].map((v) => v.toString(16).padStart(2, "0")).join("");
    setStatus(`Sampled ${colorKey.value}`, "Re-run detect to apply");
  });

  function setStatus(text, hint, show = true) {
    statusBox.style.display = show ? "" : "none";
    statusText.textContent = text;
    statusHint.textContent = hint;
  }

  function hexToRgb(hex) {
    const n = parseInt(hex.slice(1), 16);
    return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
  }

  function colorDistance(r1, g1, b1, r2, g2, b2) {
    return Math.sqrt((r1 - r2) ** 2 + (g1 - g2) ** 2 + (b1 - b2) ** 2);
  }

  detectBtn.addEventListener("click", () => {
    if (!currentImage) return;

    const offscreen = document.createElement("canvas");
    offscreen.width = currentImage.naturalWidth;
    offscreen.height = currentImage.naturalHeight;
    const ctx = offscreen.getContext("2d");
    ctx.drawImage(currentImage, 0, 0);
    const { data, width, height } = ctx.getImageData(0, 0, offscreen.width, offscreen.height);

    const alphaMode = modeAlpha.checked;
    const tolerance = parseInt(colorTolerance.value, 10);
    const minSize = parseInt(minSizeInput.value, 10);
    const [kr, kg, kb] = hexToRgb(colorKey.value);

    setStatus("Detecting…", "");

    function isForeground(x, y) {
      const i = (y * width + x) * 4;
      if (alphaMode) return data[i + 3] > 10;
      return colorDistance(data[i], data[i + 1], data[i + 2], kr, kg, kb) > tolerance;
    }

    const visited = new Uint8Array(width * height);
    const rects = [];

    for (let y = 0; y < height; y++) {
      for (let x = 0; x < width; x++) {
        const idx = y * width + x;
        if (visited[idx] || !isForeground(x, y)) continue;
        let minX = x, minY = y, maxX = x, maxY = y;
        const stack = [idx];
        visited[idx] = 1;
        while (stack.length) {
          const cur = stack.pop();
          const cx = cur % width;
          const cy = (cur / width) | 0;
          if (cx < minX) minX = cx; if (cx > maxX) maxX = cx;
          if (cy < minY) minY = cy; if (cy > maxY) maxY = cy;
          for (const [dx, dy] of [[-1, 0], [1, 0], [0, -1], [0, 1]]) {
            const nx = cx + dx, ny = cy + dy;
            if (nx < 0 || nx >= width || ny < 0 || ny >= height) continue;
            const ni = ny * width + nx;
            if (!visited[ni] && isForeground(nx, ny)) { visited[ni] = 1; stack.push(ni); }
          }
        }
        const w = maxX - minX + 1, h = maxY - minY + 1;
        if (w >= minSize && h >= minSize) rects.push({ x: minX, y: minY, w, h });
      }
    }

    detectedRects = rects;
    spriteBlobs = new Array(rects.length).fill(null);
    drawAnnotated(offscreen, rects);
    renderAssetGrid(offscreen, rects);
    renderTable(rects, width, height);
    setStatus(`Found ${rects.length} sprites`, `${width} × ${height} px source`);
    canvasTitle.textContent = "Annotated Preview";
    canvasSection.style.display = "";
    assetListSection.style.display = rects.length > 0 ? "" : "none";
  });

  function drawAnnotated(sourceCanvas, rects) {
    annotatedCanvas.width = sourceCanvas.width;
    annotatedCanvas.height = sourceCanvas.height;
    const ctx = annotatedCanvas.getContext("2d");
    ctx.drawImage(sourceCanvas, 0, 0);

    const oc = overlayColor.value;
    ctx.strokeStyle = oc;
    ctx.lineWidth = Math.max(1, Math.round(sourceCanvas.width / 512));
    ctx.fillStyle = oc + "22";

    rects.forEach((r, i) => {
      ctx.fillRect(r.x, r.y, r.w, r.h);
      ctx.strokeRect(r.x, r.y, r.w, r.h);
      ctx.fillStyle = oc;
      const fontSize = Math.max(8, Math.min(12, r.w / 4));
      ctx.font = `bold ${fontSize}px monospace`;
      ctx.fillText(String(i), r.x + 2, r.y + fontSize + 1);
      ctx.fillStyle = oc + "22";
    });
  }

  // Crop a rect from sourceCanvas and remove the background with alpha smoothing.
  // Returns a new canvas with the background cut out.
  function cropWithBgRemoval(sourceCanvas, rect) {
    const alphaMode = modeAlpha.checked;
    const tol = parseInt(colorTolerance.value, 10);
    const smooth = parseInt(edgeSmooth.value, 10);
    const [kr, kg, kb] = hexToRgb(colorKey.value);

    const sc = document.createElement("canvas");
    sc.width = rect.w; sc.height = rect.h;
    const sctx = sc.getContext("2d");
    sctx.drawImage(sourceCanvas, rect.x, rect.y, rect.w, rect.h, 0, 0, rect.w, rect.h);

    const imgData = sctx.getImageData(0, 0, rect.w, rect.h);
    const { data } = imgData;

    for (let i = 0; i < data.length; i += 4) {
      if (alphaMode) {
        // Preserve original alpha; apply smooth falloff near the transparent edge
        const a = data[i + 3];
        if (a <= 10) {
          data[i + 3] = 0;
        } else if (smooth > 0 && a < 10 + smooth * 8) {
          // Remap [10 .. 10+smooth*8] → [0 .. original]
          data[i + 3] = Math.round(((a - 10) / (smooth * 8)) * a);
        }
        // else keep as-is
      } else {
        const dist = colorDistance(data[i], data[i + 1], data[i + 2], kr, kg, kb);
        if (dist <= tol) {
          data[i + 3] = 0;
        } else if (smooth > 0 && dist <= tol + smooth) {
          // Linear ramp: 0 at the hard edge, full at smooth distance out
          data[i + 3] = Math.round(((dist - tol) / smooth) * 255);
        }
        // else fully opaque — leave data[i+3] as-is
      }
    }

    sctx.putImageData(imgData, 0, 0);
    return sc;
  }

  function renderAssetGrid(sourceCanvas, rects) {
    assetGrid.innerHTML = "";
    rects.forEach((r, i) => {
      const cropped = cropWithBgRemoval(sourceCanvas, r);
      cropped.toBlob((blob) => {
        const url = URL.createObjectURL(blob);
        spriteBlobs[i] = { blob, url };

        const card = document.createElement("div");
        card.className = "asset-card";
        card.innerHTML = `
          <div class="asset-thumb-wrap"><img class="asset-thumb" src="${url}" loading="lazy" /></div>
          <div class="asset-info">
            <div class="asset-label">#${i}</div>
            <div class="asset-dims">${r.w} × ${r.h} px</div>
            <div class="asset-dims">${r.x}, ${r.y}</div>
          </div>
          <div class="asset-actions"><button type="button" class="dl-btn secondary">Download</button></div>
        `;
        card.querySelector(".dl-btn").addEventListener("click", () => {
          downloadBlob(blob, `${sourceFileName}_sprite_${String(i).padStart(3, "0")}.png`);
        });
        assetGrid.appendChild(card);
      }, "image/png");
    });
  }

  function downloadBlob(blob, name) {
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = name;
    a.click();
    setTimeout(() => URL.revokeObjectURL(a.href), 5000);
  }

  downloadAllSpritesBtn.addEventListener("click", async () => {
    const ready = spriteBlobs.filter(Boolean);
    if (!ready.length) return;

    downloadAllSpritesBtn.disabled = true;
    downloadAllSpritesBtn.textContent = "Packing ZIP…";

    const zip = new JSZip();
    const folder = zip.folder(sourceFileName);

    await Promise.all(
      spriteBlobs.map((s, i) => {
        if (!s) return;
        return s.blob.arrayBuffer().then((buf) => {
          folder.file(`sprite_${String(i).padStart(3, "0")}.png`, buf);
        });
      })
    );

    const zipBlob = await zip.generateAsync({ type: "blob", compression: "STORE" });
    downloadBlob(zipBlob, `${sourceFileName}_sprites.zip`);

    downloadAllSpritesBtn.disabled = false;
    downloadAllSpritesBtn.textContent = "Download all as ZIP";
  });

  function renderTable(rects, sw, sh) {
    if (rects.length === 0) { assetTable.innerHTML = ""; return; }
    const rows = rects.map((r, i) => `<tr>
      <td>${i}</td>
      <td>${r.x}</td><td>${r.y}</td>
      <td>${r.w}</td><td>${r.h}</td>
      <td>${r.x + r.w - 1}</td><td>${r.y + r.h - 1}</td>
    </tr>`).join("");
    assetTable.innerHTML = `<table>
      <thead><tr><th>#</th><th>x</th><th>y</th><th>w</th><th>h</th><th>x2</th><th>y2</th></tr></thead>
      <tbody>${rows}</tbody>
    </table>`;
  }

  exportImageBtn.addEventListener("click", () => {
    annotatedCanvas.toBlob((blob) => {
      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = `${sourceFileName}_annotated.png`;
      a.click();
      setTimeout(() => URL.revokeObjectURL(a.href), 5000);
    }, "image/png");
  });

  exportJsonBtn.addEventListener("click", () => {
    const atlas = {
      meta: {
        image: `${sourceFileName}.png`,
        size: { w: currentImage?.naturalWidth ?? 0, h: currentImage?.naturalHeight ?? 0 },
        scale: 1,
      },
      frames: Object.fromEntries(
        detectedRects.map((r, i) => [
          `sprite_${String(i).padStart(3, "0")}`,
          { frame: { x: r.x, y: r.y, w: r.w, h: r.h }, rotated: false, trimmed: false,
            spriteSourceSize: { x: 0, y: 0, w: r.w, h: r.h },
            sourceSize: { w: r.w, h: r.h } },
        ])
      ),
    };
    const blob = new Blob([JSON.stringify(atlas, null, 2)], { type: "application/json" });
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = `${sourceFileName}_atlas.json`;
    a.click();
    setTimeout(() => URL.revokeObjectURL(a.href), 5000);
  });

  clearBtn.addEventListener("click", () => {
    currentImage = null;
    detectedRects = [];
    spriteBlobs.forEach((s) => s && URL.revokeObjectURL(s.url));
    spriteBlobs = [];
    detectBtn.disabled = true;
    canvasTitle.textContent = "Image Preview";
    canvasSection.style.display = "none";
    assetListSection.style.display = "none";
    assetGrid.innerHTML = "";
    assetTable.innerHTML = "";
    setStatus("", "", false);
  });
</script>
