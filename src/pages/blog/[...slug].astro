---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { ArrowLeft } from 'lucide-react';
import DisqusComments from '@/components/react/DisqusComments';
import BlogShareSection from '@/components/react/BlogShareSection';
import authors from '@/data/authors.json';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.status !== 'draft');
  return posts.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const formattedDate = entry.data.date ? new Date(entry.data.date).toLocaleDateString("en-US", {
  day: "2-digit",
  month: "long",
  year: "numeric",
}) : null;

const url = `https://huntermussel.com/blog/${entry.slug}`;
const authorKey = entry.data.authors?.[0];
const author = authorKey && authors[authorKey];
---

<Layout title={entry.data.title} description={entry.data.description} image={entry.data.image}>
  <div class="min-h-screen bg-background">
     <div class="absolute inset-0 grid-bg opacity-10 pointer-events-none" />
     
     <main class="container relative z-10 px-6 pt-32 pb-24">
       <article class="mx-auto max-w-3xl">
          <a
            href="/blog"
            class="mb-8 inline-flex items-center gap-2 font-body text-sm text-muted-foreground transition-colors hover:text-primary"
          >
            <ArrowLeft size={16} />
            Back to blog
          </a>
          
          {formattedDate && (
             <time class="block font-body text-sm text-muted-foreground">{formattedDate}</time>
          )}

          <h1 class="mt-2 font-heading text-3xl font-bold tracking-tight md:text-4xl">
            {entry.data.title}
          </h1>

          {entry.data.subtitle && (
            <p class="mt-4 font-body text-xl text-muted-foreground italic">
              {entry.data.subtitle}
            </p>
          )}

          {author && (
            <div class="mt-6 flex items-center gap-4 border-t border-border pt-4 mb-8">
              <img src={author.image_url} alt={author.name} class="h-10 w-10 rounded-full bg-primary/10 p-1" />
              <div>
                <p class="font-heading text-sm font-bold">{author.name}</p>
                <p class="font-body text-xs text-muted-foreground">{author.title}</p>
              </div>
            </div>
          )}

          {entry.data.tags && (
             <div class="mt-4 flex flex-wrap gap-2">
                {entry.data.tags.map(tag => (
                   <span class="rounded-full border border-border bg-muted/30 px-2.5 py-1 font-heading text-[10px] uppercase tracking-wider text-muted-foreground">
                      {tag}
                   </span>
                ))}
             </div>
          )}

          {entry.data.image && (
             <div class="mt-8 overflow-hidden rounded-xl border border-border">
                <img src={entry.data.image} alt={entry.data.title} class="w-full h-auto object-contain md:aspect-video md:object-cover" />
             </div>
          )}

          <div class="prose prose-invert prose-headings:font-heading prose-p:font-body prose-a:text-primary prose-strong:text-foreground mt-10 max-w-none">
             <Content />
          </div>

          <BlogShareSection client:load title={entry.data.title} url={url} />

          <DisqusComments client:only="react" title={entry.data.title} identifier={entry.slug} url={url} />
       </article>
     </main>
  </div>
</Layout>
