---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { ArrowRight } from "lucide-react";

const services = await getCollection("services");

const servicesUrl = "https://huntermussel.com/services/";
const servicesSchema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Services",
    url: servicesUrl,
    description:
      "HunterMussel services covering AI automation, DevOps engineering, cloud infrastructure, security, BPM, and custom software systems.",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://huntermussel.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Services",
        item: servicesUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "Services",
    url: servicesUrl,
    numberOfItems: services.length,
    itemListElement: services.map((entry, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `https://huntermussel.com/services/${entry.id}/`,
      name: entry.data.title,
    })),
  },
];
---

<Layout
  title="Services: AI Automation, DevOps, Cloud, and Custom Software"
  description="Explore HunterMussel services in AI automation, DevOps engineering, cloud infrastructure, workflow systems, security, and custom software delivery."
  canonicalUrl={servicesUrl}
  keywords={[
    "ai automation services",
    "devops consulting services",
    "devops practices",
    "devops best practices",
    "cloud infrastructure services",
    "custom software development services",
    "business process automation services",
    "containerization technologies",
    "continuous integration tools",
    "security compliance consulting",
    "ai deployment services",
    "workflow engineering services",
  ]}
  schema={servicesSchema}
  pageData={{ pageType: 'services_listing' }}
>
  <div class="min-h-screen bg-background">
    <div class="absolute inset-0 grid-bg opacity-10 pointer-events-none" />

    <main class="container relative z-10 px-6 pt-32 pb-24">
      <header class="mb-16 text-center">
        <span class="mb-4 inline-block font-heading text-xs font-medium uppercase tracking-widest text-primary">
          // services
        </span>
        <h1 class="mb-6 font-heading text-4xl font-bold tracking-tight md:text-6xl">
          Engineering services for <span class="gradient-text">complex systems</span>
        </h1>
        <p class="mx-auto max-w-3xl font-body text-xl leading-relaxed text-muted-foreground">
          HunterMussel helps teams design, automate, secure, and scale digital
          operations through AI systems, cloud infrastructure, DevOps, and
          workflow engineering.
        </p>
      </header>

      <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
        {services.map((entry) => (
          <article class="group flex h-full flex-col rounded-lg border border-border bg-card/50 p-6 transition-all hover:border-primary/30 hover:bg-card">
            <h2 class="mb-3 font-heading text-xl font-bold leading-tight transition-colors group-hover:text-primary">
              <a href={`/services/${entry.id}/`} class="block">
                {entry.data.title}
              </a>
            </h2>
            <p class="mb-5 flex-1 font-body text-sm leading-relaxed text-muted-foreground">
              {entry.data.description}
            </p>
            <a
              href={`/services/${entry.id}/`}
              class="inline-flex items-center gap-1 font-heading text-xs font-semibold text-primary transition-all group-hover:gap-2"
            >
              Explore service
              <ArrowRight size={14} />
            </a>
          </article>
        ))}
      </div>
    </main>
  </div>
</Layout>
