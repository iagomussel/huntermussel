---
import { getCollection, render } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import MermaidRenderer from '@/components/MermaidRenderer.astro';
import { ArrowLeft } from 'lucide-react';
import FAQSection from '@/components/react/FAQSection';
import { serviceFAQ, homeFAQ } from '@/data/faq';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const services = await getCollection('services');
const url = `https://huntermussel.com/services/${entry.id}/`;
const relatedServices = services.filter((item) => item.id !== entry.id).slice(0, 3);
const faqItems = serviceFAQ[entry.id] ?? homeFAQ.slice(0, 5);
const serviceSchema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: entry.data.title,
    description: entry.data.description,
    url,
    provider: {
      "@type": "Organization",
      name: "HunterMussel",
      url: "https://huntermussel.com/",
    },
    areaServed: "Worldwide",
    serviceType: entry.data.title,
    keywords: entry.data.keywords?.join(", "),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://huntermussel.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Services",
        item: "https://huntermussel.com/services/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: entry.data.title,
        item: url,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.image}
  canonicalUrl={url}
  keywords={entry.data.keywords}
  schema={serviceSchema}
  pageData={{
    pageType: 'service',
    pageTitle: entry.data.title,
    pageUrl: url,
  }}
>
  <div class="min-h-screen bg-background">
    <div class="absolute inset-0 grid-bg opacity-10 pointer-events-none" />

    <main class="container relative z-10 px-6 pt-32 pb-24">
      <a
        href="/services/"
        class="mb-12 inline-flex items-center gap-2 font-body text-sm text-muted-foreground transition-colors hover:text-primary"
      >
        <ArrowLeft size={16} />
        Back to services
      </a>

      <article class="mx-auto max-w-4xl">
      <header class="mb-16">
        <span class="mb-4 inline-block font-heading text-xs font-medium uppercase tracking-widest text-primary">
          // service
        </span>
        <h1 class="font-heading text-4xl font-bold tracking-tight md:text-6xl mb-6">
          {entry.data.title}
        </h1>
        <p class="font-body text-xl text-muted-foreground leading-relaxed max-w-2xl">
          {entry.data.description}
        </p>
      </header>

      <div class="prose prose-invert prose-headings:font-heading prose-p:font-body prose-a:text-primary prose-strong:text-foreground mt-10 max-w-none">
        <Content />
      </div>

      {relatedServices.length > 0 && (
        <section class="mt-20 border-t border-border pt-10">
          <h2 class="mb-6 font-heading text-2xl font-bold">Related services</h2>
          <div class="grid gap-6 md:grid-cols-3">
            {relatedServices.map((item) => (
              <article class="rounded-lg border border-border bg-card/40 p-5 transition-all hover:border-primary/30 hover:bg-card">
                <h3 class="font-heading text-lg font-semibold">
                  <a href={`/services/${item.id}/`} class="transition-colors hover:text-primary">
                    {item.data.title}
                  </a>
                </h3>
                <p class="mt-3 font-body text-sm leading-relaxed text-muted-foreground">
                  {item.data.description}
                </p>
              </article>
            ))}
          </div>
        </section>
      )}

      <div class="mt-20 text-center">
        <div class="rounded-2xl border border-primary/20 bg-primary/5 p-12 backdrop-blur-md">
          <h2 class="font-heading text-2xl font-bold mb-4">Ready to achieve similar results?</h2>
          <p class="font-body text-muted-foreground mb-8 max-w-lg mx-auto">
            Let's discuss how we can apply our expertise to your specific business challenges.
          </p>
          <a
            href="/#contact"
            class="inline-flex items-center justify-center rounded-md bg-primary px-8 py-3 font-heading text-sm font-semibold text-primary-foreground transition-all hover:shadow-[0_0_30px_hsl(145_80%_50%/0.3)]"
          >
            Start a Project
          </a>
        </div>
      </div>
      </article>
    </main>
  </div>
  <FAQSection client:load items={faqItems} title="Common Questions About This Service" />
  <MermaidRenderer />
</Layout>
