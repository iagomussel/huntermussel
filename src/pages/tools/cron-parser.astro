  /* ── Description row ── */
  .cp-desc-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1.1rem;
    margin-bottom: 0.75rem;
    background: #0e1219;
    border: 1px solid #1c2535;
    border-left: 3px solid #1aeb6a;
  }

  .cp-desc-icon {
    color: #1aeb6a;
    font-size: 0.6rem;
    flex-shrink: 0;
  }

  .cp-desc-text {
    font-family: "JetBrains Mono", monospace;
    font-size: 1rem;
    font-weight: 600;
    color: #f5f9ff;
    letter-spacing: 0.02em;
  }

  /* ── Non-standard warning ── */
  .cp-nonstandard-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 1rem;
    margin-bottom: 0.75rem;
    background: rgba(245,158,11,0.07);
    border: 1px solid rgba(245,158,11,0.25);
    border-left: 3px solid #f59e0b;
    border-radius: 0.5rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
