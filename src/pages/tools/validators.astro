---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Validators | HunterMussel Tools"
  description="Validate YAML, OpenAPI specs, and Terraform configuration quality."
  canonicalPath="/tools/validators/"
>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">tool / validation</p>
      <h1>Validators</h1>
      <p class="lead">
        Browser-based validators for YAML syntax, OpenAPI structural checks, and
        Terraform lint-style quality rules.
      </p>
      <a class="back-link" href="/tools/">Back to tools index</a>
    </section>

    <section class="tool-layout">
      <article class="card stack">
        <div>
          <label class="label" for="validatorType">Validator type</label>
          <select id="validatorType">
            <option value="yaml" selected>YAML validator</option>
            <option value="openapi">OpenAPI validator</option>
            <option value="terraform">Terraform lint</option>
          </select>
        </div>
        <div>
          <label class="label" for="validatorInput">Input</label>
          <textarea
            id="validatorInput"
            placeholder="Paste YAML, OpenAPI, or Terraform content..."
          ></textarea>
        </div>
        <div class="actions">
          <button id="runValidatorBtn" type="button">Run validation</button>
        </div>
      </article>

      <aside class="card stack">
        <div class="result">
          Status
          <strong id="validatorStatus">Waiting input</strong>
          <span id="validatorHint" class="small">Choose a validator and run.</span>
        </div>
        <div class="result">
          Findings
          <pre id="validatorOutput" class="mono"></pre>
        </div>
      </aside>
    </section>
  </main>
</BaseLayout>

<script type="module">
  import yaml from "js-yaml";

  const $ = (id) => document.getElementById(id);

  function setResult(status, hint, output = "") {
    $("validatorStatus").textContent = status;
    $("validatorHint").textContent = hint;
    $("validatorOutput").textContent = output;
  }

  function validateYaml(raw) {
    const parsed = yaml.load(raw);
    return `YAML valid.\nType: ${Array.isArray(parsed) ? "array" : typeof parsed}`;
  }

  function validateOpenApi(raw) {
    const parsed = raw.trim().startsWith("{") ? JSON.parse(raw) : yaml.load(raw);
    const findings = [];

    if (!parsed || typeof parsed !== "object") {
      findings.push("Document must be an object.");
    } else {
      if (!parsed.openapi) findings.push("Missing 'openapi' field.");
      if (!parsed.info || typeof parsed.info !== "object") {
        findings.push("Missing 'info' object.");
      } else {
        if (!parsed.info.title) findings.push("Missing 'info.title'.");
        if (!parsed.info.version) findings.push("Missing 'info.version'.");
      }
      if (!parsed.paths || typeof parsed.paths !== "object") {
        findings.push("Missing 'paths' object.");
      }
    }

    return findings.length === 0
      ? "OpenAPI structural checks passed."
      : `OpenAPI findings:\n- ${findings.join("\n- ")}`;
  }

  function lintTerraform(raw) {
    const findings = [];
    if (!/terraform\s*\{/.test(raw)) findings.push("Missing top-level terraform block.");
    if (!/required_providers\s*\{/.test(raw)) findings.push("Missing required_providers block.");
    if (!/required_version\s*=/.test(raw)) findings.push("Missing required_version pin.");
    if (!/provider\s+"[^"]+"\s*\{/.test(raw)) findings.push("No provider block found.");
    if (/0\.0\.0\.0\/0/.test(raw)) findings.push("Found 0.0.0.0/0 - review exposure.");
    if (/access_key\s*=|secret_key\s*=/.test(raw)) findings.push("Hardcoded credentials detected.");

    return findings.length === 0
      ? "Terraform lint checks passed."
      : `Terraform findings:\n- ${findings.join("\n- ")}`;
  }

  $("runValidatorBtn").addEventListener("click", () => {
    const type = $("validatorType").value;
    const input = $("validatorInput").value || "";

    if (!input.trim()) {
      setResult("Empty input", "Paste content before validating.");
      return;
    }

    try {
      let output = "";
      if (type === "yaml") output = validateYaml(input);
      if (type === "openapi") output = validateOpenApi(input);
      if (type === "terraform") output = lintTerraform(input);
      setResult("Validation completed", "Review findings below.", output);
    } catch (error) {
      setResult("Validation failed", "Parser error detected.", String(error));
    }
  });
</script>
