---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ServiceCTA from "@/components/ServiceCTA.astro";
---

<BaseLayout
  title="Image Crop Tool | HunterMussel Tools"
  description="Crop images interactively in your browser. Drag handles to select a region, enter exact pixel coordinates, lock aspect ratio, and download the cropped result — no uploads."
  canonicalPath="/tools/image-crop/"
  keywords={[
    "image crop tool online",
    "crop image browser",
    "free image cropper",
    "crop image to size",
    "image crop no upload",
    "crop png online",
    "crop jpg online",
    "aspect ratio crop",
    "drag to crop image",
    "client side image crop",
  ]}
>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">tool / imaging</p>
      <h1>Image Crop Tool</h1>
      <p class="lead">
        Drag a crop region over your image, set exact pixel coordinates, optionally lock
        an aspect ratio, and download the cropped result as PNG — entirely in your browser.
      </p>
      <a class="back-link" href="/tools/">Back to tools index</a>
    </section>

    <section class="crop-layout">
      <!-- Canvas area -->
      <div class="card canvas-card" id="canvasCard">
        <input id="fileInput" type="file" accept="image/*" style="display:none" />
        <div id="dropZone" class="drop-zone-inner">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          <p class="drop-label">Drop an image here or <span class="drop-link" id="browseBtn">browse</span></p>
          <p class="small">Any image format</p>
        </div>
        <div id="cropArea" style="display:none; position:relative; user-select:none; overflow:hidden;">
          <canvas id="imageCanvas" style="display:block; max-width:100%;"></canvas>
          <div id="cropOverlay" style="position:absolute; top:0; left:0; width:100%; height:100%; pointer-events:none;"></div>
          <svg id="cropSvg" style="position:absolute; top:0; left:0; width:100%; height:100%; overflow:visible;">
            <!-- Dark mask paths are drawn dynamically -->
            <rect id="cropRect" fill="none" stroke="#00ff88" stroke-width="1.5" stroke-dasharray="5 3" style="cursor:move;" />
            <!-- Handles -->
            <rect id="h-nw" class="handle" width="10" height="10" fill="#00ff88" style="cursor:nw-resize;" />
            <rect id="h-ne" class="handle" width="10" height="10" fill="#00ff88" style="cursor:ne-resize;" />
            <rect id="h-sw" class="handle" width="10" height="10" fill="#00ff88" style="cursor:sw-resize;" />
            <rect id="h-se" class="handle" width="10" height="10" fill="#00ff88" style="cursor:se-resize;" />
            <rect id="h-n" class="handle" width="10" height="10" fill="#00ff88" style="cursor:n-resize;" />
            <rect id="h-s" class="handle" width="10" height="10" fill="#00ff88" style="cursor:s-resize;" />
            <rect id="h-w" class="handle" width="10" height="10" fill="#00ff88" style="cursor:w-resize;" />
            <rect id="h-e" class="handle" width="10" height="10" fill="#00ff88" style="cursor:e-resize;" />
          </svg>
        </div>
      </div>

      <!-- Controls -->
      <aside class="card stack">
        <div>
          <label class="label">Aspect Ratio</label>
          <select id="aspectRatio">
            <option value="free">Free</option>
            <option value="1:1">1:1 Square</option>
            <option value="4:3">4:3</option>
            <option value="16:9">16:9</option>
            <option value="3:2">3:2</option>
            <option value="2:3">2:3 Portrait</option>
            <option value="9:16">9:16 Portrait</option>
          </select>
        </div>

        <div class="coords-grid">
          <div>
            <label class="small" for="cropX">X</label>
            <input id="cropX" type="number" min="0" value="0" />
          </div>
          <div>
            <label class="small" for="cropY">Y</label>
            <input id="cropY" type="number" min="0" value="0" />
          </div>
          <div>
            <label class="small" for="cropW">Width</label>
            <input id="cropW" type="number" min="1" value="100" />
          </div>
          <div>
            <label class="small" for="cropH">Height</label>
            <input id="cropH" type="number" min="1" value="100" />
          </div>
        </div>

        <div id="imageDims" class="result" style="display:none">
          <strong id="imageDimsText"></strong>
          <span id="cropDimsText" class="small"></span>
        </div>

        <div class="actions">
          <button id="cropBtn" type="button" disabled>Crop & Download</button>
          <button id="resetBtn" type="button" class="secondary">Reset crop</button>
          <button id="clearBtn" type="button" class="secondary">Clear</button>
        </div>
      </aside>
    </section>

    <section class="article">
      <article class="card">
        <h2>What It Does</h2>
        <p>
          Renders your image on an HTML Canvas, then overlays an interactive SVG crop
          region with draggable handles. You can drag the crop box, resize it from any
          corner or edge, or type exact pixel coordinates. Aspect ratio lock constrains
          the region shape as you drag. The final crop is exported as a PNG via Canvas API.
        </p>
      </article>
      <article class="card">
        <h2>How To Use</h2>
        <ul>
          <li>Drop or browse an image file.</li>
          <li>Optionally lock an aspect ratio from the dropdown.</li>
          <li>Drag the crop handles or type pixel values in the coordinate inputs.</li>
          <li>Click <strong>Crop &amp; Download</strong> to save the cropped PNG.</li>
          <li>Use <strong>Reset crop</strong> to select the full image again.</li>
        </ul>
      </article>
      <ServiceCTA
        service="workflows-bpm"
        title="Need automated image cropping in your content pipeline?"
        description="HunterMussel builds workflow automation that handles bulk image cropping, resizing, and delivery — eliminating manual processing entirely."
        linkLabel="Explore Workflows & BPM"
      />
    </section>
  </main>
</BaseLayout>

<style>
  .crop-layout {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 1rem;
    margin-bottom: 1.4rem;
    align-items: start;
  }

  @media (max-width: 720px) {
    .crop-layout { grid-template-columns: 1fr; }
  }

  .canvas-card {
    padding: 0.75rem;
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .drop-zone-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    padding: 2rem 1rem;
    color: var(--text-2);
    text-align: center;
    cursor: pointer;
    width: 100%;
    border: 2px dashed hsl(145 80% 50% / 0.3);
    border-radius: 0.5rem;
    transition: border-color 0.15s;
  }

  .drop-zone-inner:hover { border-color: var(--primary); }
  .drop-label { margin: 0; font-weight: 600; color: var(--text-1); }
  .drop-link { color: var(--primary); text-decoration: underline; cursor: pointer; }

  .coords-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .handle { rx: 2; ry: 2; }
</style>

<script type="module">
  const $ = (id) => document.getElementById(id);

  const fileInput = $("fileInput");
  const browseBtn = $("browseBtn");
  const dropZone = $("dropZone");
  const cropArea = $("cropArea");
  const imageCanvas = $("imageCanvas");
  const cropSvg = $("cropSvg");
  const cropRect = $("cropRect");
  const handles = { nw: $("h-nw"), ne: $("h-ne"), sw: $("h-sw"), se: $("h-se"), n: $("h-n"), s: $("h-s"), w: $("h-w"), e: $("h-e") };
  const aspectRatioSel = $("aspectRatio");
  const cropX = $("cropX"), cropY = $("cropY"), cropW = $("cropW"), cropH = $("cropH");
  const imageDims = $("imageDims"), imageDimsText = $("imageDimsText"), cropDimsText = $("cropDimsText");
  const cropBtn = $("cropBtn"), resetBtn = $("resetBtn"), clearBtn = $("clearBtn");

  let img = null, imgW = 0, imgH = 0;
  let crop = { x: 0, y: 0, w: 100, h: 100 }; // in IMAGE pixels
  let dragging = null, dragStart = null, cropStart = null;

  browseBtn.addEventListener("click", () => fileInput.click());
  dropZone.addEventListener("click", () => fileInput.click());
  document.addEventListener("dragover", (e) => e.preventDefault());
  document.addEventListener("drop", (e) => { e.preventDefault(); if (e.dataTransfer.files[0]) loadFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener("change", () => { loadFile(fileInput.files[0]); fileInput.value = ""; });

  function loadFile(file) {
    if (!file || !file.type.startsWith("image/")) return;
    const reader = new FileReader();
    reader.onload = (e) => {
      const image = new Image();
      image.onload = () => {
        img = image;
        imgW = image.naturalWidth;
        imgH = image.naturalHeight;
        imageCanvas.width = imgW;
        imageCanvas.height = imgH;
        imageCanvas.getContext("2d").drawImage(image, 0, 0);
        dropZone.style.display = "none";
        cropArea.style.display = "block";
        cropBtn.disabled = false;
        imageDims.style.display = "";
        imageDimsText.textContent = `Image: ${imgW} × ${imgH} px`;
        resetCrop();
      };
      image.src = e.target.result;
    };
    reader.readAsDataURL(file);
  }

  function resetCrop() {
    crop = { x: 0, y: 0, w: imgW, h: imgH };
    syncInputs();
    renderOverlay();
  }

  function syncInputs() {
    cropX.value = Math.round(crop.x);
    cropY.value = Math.round(crop.y);
    cropW.value = Math.round(crop.w);
    cropH.value = Math.round(crop.h);
    cropDimsText.textContent = `Crop: ${Math.round(crop.w)} × ${Math.round(crop.h)} px`;
  }

  function clampCrop() {
    crop.x = Math.max(0, Math.min(imgW - 1, crop.x));
    crop.y = Math.max(0, Math.min(imgH - 1, crop.y));
    crop.w = Math.max(1, Math.min(imgW - crop.x, crop.w));
    crop.h = Math.max(1, Math.min(imgH - crop.y, crop.h));
  }

  [cropX, cropY, cropW, cropH].forEach((inp) => {
    inp.addEventListener("input", () => {
      crop.x = parseInt(cropX.value) || 0;
      crop.y = parseInt(cropY.value) || 0;
      crop.w = parseInt(cropW.value) || 1;
      crop.h = parseInt(cropH.value) || 1;
      clampCrop();
      syncInputs();
      renderOverlay();
    });
  });

  // Scale between image coords and canvas display coords
  function getScale() {
    const displayW = imageCanvas.getBoundingClientRect().width;
    return displayW / imgW;
  }

  function renderOverlay() {
    const scale = getScale();
    const x = crop.x * scale, y = crop.y * scale, w = crop.w * scale, h = crop.h * scale;
    const HW = 10, HH = 10;

    cropRect.setAttribute("x", x);
    cropRect.setAttribute("y", y);
    cropRect.setAttribute("width", w);
    cropRect.setAttribute("height", h);

    const midX = x + w / 2, midY = y + h / 2;
    const positions = { nw: [x, y], ne: [x + w, y], sw: [x, y + h], se: [x + w, y + h], n: [midX, y], s: [midX, y + h], w: [x, midY], e: [x + w, midY] };
    for (const [key, [hx, hy]] of Object.entries(positions)) {
      handles[key].setAttribute("x", hx - HW / 2);
      handles[key].setAttribute("y", hy - HH / 2);
    }
  }

  // Drag logic
  function getImagePoint(e) {
    const rect = imageCanvas.getBoundingClientRect();
    const scale = getScale();
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
    return {
      x: (clientX - rect.left) / scale,
      y: (clientY - rect.top) / scale,
    };
  }

  cropSvg.addEventListener("mousedown", startDrag);
  cropSvg.addEventListener("touchstart", startDrag, { passive: false });

  function startDrag(e) {
    e.preventDefault();
    const target = e.target;
    const pt = getImagePoint(e);
    dragStart = pt;
    cropStart = { ...crop };

    if (target === cropRect) { dragging = "move"; return; }
    for (const [key, el] of Object.entries(handles)) {
      if (target === el) { dragging = key; return; }
    }
    // Start new crop
    dragging = "new";
    crop.x = pt.x; crop.y = pt.y; crop.w = 1; crop.h = 1;
    cropStart = { ...crop };
  }

  document.addEventListener("mousemove", onDrag);
  document.addEventListener("touchmove", onDrag, { passive: false });

  function getAspect() {
    const val = aspectRatioSel.value;
    if (val === "free") return null;
    const [aw, ah] = val.split(":").map(Number);
    return aw / ah;
  }

  function onDrag(e) {
    if (!dragging) return;
    e.preventDefault();
    const pt = getImagePoint(e);
    const dx = pt.x - dragStart.x, dy = pt.y - dragStart.y;
    const aspect = getAspect();

    if (dragging === "move") {
      crop.x = cropStart.x + dx;
      crop.y = cropStart.y + dy;
    } else if (dragging === "new") {
      const x0 = Math.min(dragStart.x, pt.x), y0 = Math.min(dragStart.y, pt.y);
      let w = Math.abs(pt.x - dragStart.x), h = Math.abs(pt.y - dragStart.y);
      if (aspect) { w = Math.max(w, h * aspect); h = w / aspect; }
      crop.x = x0; crop.y = y0; crop.w = w; crop.h = h;
    } else {
      let { x, y, w, h } = cropStart;
      if (dragging.includes("e")) { w = Math.max(1, cropStart.w + dx); }
      if (dragging.includes("w")) { x = cropStart.x + dx; w = Math.max(1, cropStart.w - dx); }
      if (dragging.includes("s")) { h = Math.max(1, cropStart.h + dy); }
      if (dragging.includes("n")) { y = cropStart.y + dy; h = Math.max(1, cropStart.h - dy); }
      if (aspect && (dragging === "se" || dragging === "nw" || dragging === "ne" || dragging === "sw")) {
        w = Math.max(w, h * aspect); h = w / aspect;
      }
      crop.x = x; crop.y = y; crop.w = w; crop.h = h;
    }

    clampCrop();
    syncInputs();
    renderOverlay();
  }

  document.addEventListener("mouseup", () => { dragging = null; });
  document.addEventListener("touchend", () => { dragging = null; });
  window.addEventListener("resize", renderOverlay);

  cropBtn.addEventListener("click", () => {
    if (!img) return;
    const out = document.createElement("canvas");
    out.width = Math.round(crop.w);
    out.height = Math.round(crop.h);
    out.getContext("2d").drawImage(img, Math.round(crop.x), Math.round(crop.y), Math.round(crop.w), Math.round(crop.h), 0, 0, out.width, out.height);
    out.toBlob((blob) => {
      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = "cropped.png";
      a.click();
      setTimeout(() => URL.revokeObjectURL(a.href), 5000);
    }, "image/png");
  });

  resetBtn.addEventListener("click", resetCrop);

  clearBtn.addEventListener("click", () => {
    img = null;
    cropArea.style.display = "none";
    dropZone.style.display = "";
    cropBtn.disabled = true;
    imageDims.style.display = "none";
  });
</script>
