---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Base64 Converter + Repair | HunterMussel Tools"
  description="Convert, validate, and repair Base64/Base64URL payloads fully client-side."
  canonicalPath="/tools/base64-converter/"
>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">tool / encoding</p>
      <h1>Base64 Converter + Repair</h1>
      <p class="lead">
        This tool normalizes payloads, fixes padding, validates decode, and
        returns a canonical Base64 output.
      </p>
      <a class="back-link" href="/tools/">Back to tools index</a>
    </section>

    <section class="tool-layout">
      <article class="card stack">
        <div>
          <label class="label" for="b64Input">Input</label>
          <textarea id="b64Input" placeholder="Paste plain text, Base64, Base64URL, or data URI..."></textarea>
        </div>
        <label class="check">
          <input id="returnUtf8" type="checkbox" />
          <span>Try UTF-8 decode preview</span>
        </label>
        <div class="actions">
          <button id="encodeBtn" type="button">Encode text</button>
          <button id="decodeBtn" type="button">Decode Base64</button>
          <button id="repairBtn" type="button">Repair Base64</button>
          <button id="copyOutBtn" class="secondary" type="button">Copy output</button>
        </div>
      </article>

      <aside class="card stack">
        <div class="result">
          Status
          <strong id="b64Status">Waiting input</strong>
          <span id="b64Hint" class="small">Choose encode, decode, or repair.</span>
        </div>
        <div class="result">
          Output
          <pre id="b64Output" class="mono"></pre>
        </div>
        <div class="result">
          Details
          <pre id="b64Meta" class="small"></pre>
        </div>
      </aside>
    </section>

    <section class="article">
      <article class="card">
        <h2>What It Does</h2>
        <p>
          The repair flow applies three core steps: normalize noisy input,
          correct padding/invalid characters, and validate by decoding and
          re-encoding to canonical Base64.
        </p>
      </article>
      <article class="card">
        <h2>Why It Matters</h2>
        <p>
          Integration failures often come from malformed Base64 payloads:
          URL-safe variants, missing padding, hidden whitespace, or broken data
          URIs. This tool removes that friction quickly.
        </p>
      </article>
      <article class="card">
        <h2>How To Use</h2>
        <ul>
          <li>Paste payload in the input field.</li>
          <li>Use <code>Repair Base64</code> for broken inputs.</li>
          <li>Use <code>Encode text</code> for plain text conversion.</li>
          <li>Use <code>Decode Base64</code> to read decoded text/bytes.</li>
        </ul>
      </article>
    </section>
  </main>
</BaseLayout>

<script type="module">
  import { repairBase64 } from "../lib/base64Repair";

  const $ = (id) => document.getElementById(id);

  const toUtf8Base64 = (text) => {
    const bytes = new TextEncoder().encode(text);
    let bin = "";
    bytes.forEach((b) => {
      bin += String.fromCharCode(b);
    });
    return btoa(bin);
  };

  const fromUtf8Base64 = (value) => {
    const repaired = repairBase64(value);
    if (!repaired.ok) throw new Error(repaired.error || "Invalid base64");
    const bytes = repaired.bytes || new Uint8Array();
    return new TextDecoder().decode(bytes);
  };

  function setOutput(status, hint, output, meta = "") {
    $("b64Status").textContent = status;
    $("b64Hint").textContent = hint;
    $("b64Output").textContent = output || "";
    $("b64Meta").textContent = meta;
  }

  $("encodeBtn").addEventListener("click", () => {
    const input = $("b64Input").value || "";
    const out = toUtf8Base64(input);
    setOutput("Encoded", "Text encoded to Base64.", out);
  });

  $("decodeBtn").addEventListener("click", () => {
    const input = $("b64Input").value || "";
    try {
      const out = fromUtf8Base64(input);
      setOutput("Decoded", "Base64 decoded as UTF-8.", out);
    } catch (e) {
      setOutput("Decode failed", "Input could not be decoded.", "", String(e));
    }
  });

  $("repairBtn").addEventListener("click", () => {
    const input = $("b64Input").value || "";
    const withUtf8 = $("returnUtf8").checked;
    const result = repairBase64(input, { returnUtf8Text: withUtf8 });

    if (!result.ok) {
      setOutput(
        "Repair failed",
        "Could not repair payload.",
        "",
        `error=${result.error || "unknown"}\nwarnings=\n- ${result.warnings.join("\n- ")}`
      );
      return;
    }

    const lines = [
      `variant=${result.variant}`,
      `bytes=${result.bytes?.length || 0}`,
      `dataUriPrefix=${result.dataUriPrefix || "none"}`,
      `warnings=\n- ${result.warnings.join("\n- ")}`,
    ];
    if (result.textUtf8) lines.push(`utf8Preview=${result.textUtf8.slice(0, 240)}`);

    setOutput(
      "Repaired",
      "Canonical Base64 generated.",
      result.repaired,
      lines.join("\n")
    );
  });

  $("copyOutBtn").addEventListener("click", async () => {
    const output = $("b64Output").textContent || "";
    if (!output) return;
    await navigator.clipboard.writeText(output);
    $("b64Hint").textContent = "Output copied to clipboard.";
  });
</script>
