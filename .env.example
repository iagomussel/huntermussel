# CDN origin for images and /img/* (no trailing slash). Astro uses PUBLIC_ASSETS_URL, or CLOUDFLARE_R2_PUBLIC_URL if unset.
# PUBLIC_ASSETS_URL=https://assets.huntermussel.com
# CLOUDFLARE_R2_PUBLIC_URL=https://assets.huntermussel.com

# R2 upload (npm run upload:assets) — same bucket must be exposed at CLOUDFLARE_R2_PUBLIC_URL
# CLOUDFLARE_R2_ACCOUNT_ID=
# CLOUDFLARE_R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET=
