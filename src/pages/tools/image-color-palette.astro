---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ServiceCTA from "@/components/ServiceCTA.astro";

const faqItems = [
  {
    q: "Is my photo uploaded to extract colors?",
    a: "No. The image is decoded in memory, downsampled for analysis, and never transmitted. Clipboard and PNG strip export also stay on your device.",
  },
  {
    q: "Why do swatches differ from Photoshop's dominant colors?",
    a: "This tool uses fast frequency counting with RGB quantization and a minimum distance between picks — not k-means. Results are great for mood boards and UI inspiration, not a lab-grade color science match.",
  },
  {
    q: "How do I copy a hex code?",
    a: "Click a swatch or its Copy button. Browsers may block clipboard access on non-HTTPS localhost or if permissions are denied — in that case select the hex text manually.",
  },
  {
    q: "What does minimum color separation do?",
    a: "It is the minimum Euclidean distance in RGB space between selected swatches. Higher values spread colors apart and reduce near-duplicate blues or grays.",
  },
];
---

<BaseLayout
  title="Image Color Palette Extractor — Dominant Colors & Hex Codes | HunterMussel Tools"
  description="Extract up to 12 dominant colors from any image in your browser. Quantized sampling, hex copy, optional palette strip PNG. Private — no uploads."
  canonicalPath="/tools/image-color-palette/"
  breadcrumbName="Image Color Palette"
  faqItems={faqItems}
  keywords={[
    "extract color palette from image online",
    "dominant colors from photo",
    "image hex palette generator",
    "brand colors from logo browser",
    "mood board color picker",
    "no upload palette extractor",
    "copy hex from image",
    "palette strip png download",
    "ui design color inspiration",
    "quantize image colors tool",
    "client side color extraction",
    "free image palette tool",
  ]}
>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">tool / imaging</p>
      <h1>Image Color Palette</h1>
      <p class="lead">
        Sample your image, quantize similar colors, and surface up to <strong>12</strong> representative swatches with
        one-click hex copy. Optional: download a horizontal palette strip as PNG for mood boards or design handoff.
      </p>
      <a class="back-link" href="/tools/">Back to tools index</a>
      <nav class="related-tools" aria-label="Related imaging tools">
        <span class="related-tools__label">Related</span>
        <a href="/tools/image-format-converter/">Format converter</a>
        <a href="/tools/image-optimizer/">WebP optimizer</a>
        <a href="/tools/svg-to-png/">SVG to PNG</a>
      </nav>
    </section>

    <section class="media-tool-grid">
      <div id="dropZone" class="card media-drop">
        <input id="fileInput" type="file" accept="image/*" style="display:none" />
        <div class="media-drop-inner">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="9" cy="9" r="2"/><circle cx="15" cy="9" r="2"/><circle cx="12" cy="15" r="2"/><path d="M12 3v2M5.6 5.6l1.4 1.4M3 12h2m14 0h2m-3.2-5.8L18.4 5.8"/>
          </svg>
          <p class="media-drop-label">Drop an image or <span class="media-drop-link">browse</span></p>
          <p class="small">JPG, PNG, WebP, GIF — analyzed locally at reduced resolution for speed.</p>
        </div>
        <p id="fileHint" class="small mono media-file-meta"></p>
      </div>

      <aside class="card stack">
        <div>
          <label class="label" for="numColors">Number of swatches</label>
          <input id="numColors" type="number" min="3" max="12" value="8" />
        </div>
        <div>
          <label class="label" for="minDist">Minimum color separation (0–120)</label>
          <input id="minDist" type="number" min="0" max="120" value="35" />
        </div>
        <p class="small" style="margin:0;">
          Higher separation spreads swatches apart in RGB space (fewer near-duplicates).
        </p>
        <div class="actions">
          <button id="extractBtn" type="button" disabled>Extract palette</button>
          <button id="dlStripBtn" type="button" class="secondary" disabled>Download strip PNG</button>
        </div>
        <p id="status" class="small" style="margin:0;"></p>
      </aside>
    </section>

    <section id="swatchSection" class="card swatch-panel" style="display:none;margin-bottom:1.4rem">
      <p class="label">Swatches</p>
      <div id="swatches" class="swatch-row"></div>
    </section>

    <section class="article">
      <article class="card">
        <h2>What it does</h2>
        <p>
          Surfaces the most frequent colors after light quantization, then greedily picks swatches that stay at least your
          chosen distance apart in RGB space. Fast, readable, and good for capturing the “feel” of logos, screenshots, and references.
        </p>
      </article>
      <article class="card">
        <h2>Privacy</h2>
        <p>
          Screenshots of dashboards or unreleased marketing should not hit third-party “extract colors” APIs. This page keeps
          pixels in-tab until you export a palette strip or copy hex values yourself.
        </p>
      </article>
      <article class="card">
        <h2>How extraction works</h2>
        <p>
          The image is downsampled in memory, pixels are quantized to reduce noise, then colors are sorted by frequency.
          Swatches are picked so each new color is at least your minimum distance from those already chosen.
        </p>
      </article>
      <article class="card">
        <h2>How to use</h2>
        <ul>
          <li>Load an image (any common raster format).</li>
          <li>Set swatch count (3–12) and minimum separation.</li>
          <li>Click <strong>Extract palette</strong>, copy hex codes, optionally <strong>Download strip PNG</strong>.</li>
        </ul>
      </article>
      <article class="card">
        <h2>Frequently asked questions</h2>
        <dl class="tool-faq-list">
          {faqItems.map((item) => (
            <div class="tool-faq-item">
              <dt>{item.q}</dt>
              <dd>{item.a}</dd>
            </div>
          ))}
        </dl>
      </article>
      <ServiceCTA
        service="intelligent-automation"
        title="Building design systems or themed UIs?"
        description="HunterMussel helps teams automate design-to-code workflows and intelligent tooling — from tokens to generated assets."
        linkLabel="Explore Intelligent Automation"
      />
    </section>
  </main>
</BaseLayout>

<style>
  .swatch-panel {
    overflow: hidden;
  }
  .swatch-row {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(5.5rem, 1fr));
    gap: 0.75rem;
  }
  @media (max-width: 400px) {
    .swatch-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .swatch {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.35rem;
    min-width: 0;
  }
  .swatch-color {
    height: 48px;
    border-radius: 0.5rem;
    border: 1px solid var(--line);
    cursor: pointer;
  }
  .swatch-hex {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    color: var(--text-2);
    text-align: center;
    user-select: all;
    word-break: break-all;
  }
  .swatch-copy {
    font-size: 0.68rem;
    padding: 0.25rem 0.4rem;
  }
</style>

<script type="module">
  const dropZone = document.getElementById("dropZone");
  const fileInput = document.getElementById("fileInput");
  const fileHint = document.getElementById("fileHint");
  const numColors = document.getElementById("numColors");
  const minDist = document.getElementById("minDist");
  const extractBtn = document.getElementById("extractBtn");
  const dlStripBtn = document.getElementById("dlStripBtn");
  const status = document.getElementById("status");
  const swatchSection = document.getElementById("swatchSection");
  const swatches = document.getElementById("swatches");

  let imageData = null;
  let stripBlob = null;
  let palette = [];

  function dist(a, b) {
    return Math.hypot(a.r - b.r, a.g - b.g, a.b - b.b);
  }

  function extractPalette(data, k, minD) {
    const { data: buf, width, height } = data;
    const buckets = new Map();
    const step = Math.max(1, Math.floor((width * height) / 8000));
    for (let y = 0; y < height; y += step) {
      for (let x = 0; x < width; x += step) {
        const i = (y * width + x) * 4;
        const a = buf[i + 3];
        if (a < 32) continue;
        const r = buf[i] & 0xf0;
        const g = buf[i + 1] & 0xf0;
        const b = buf[i + 2] & 0xf0;
        const key = (r << 16) | (g << 8) | b;
        buckets.set(key, (buckets.get(key) || 0) + 1);
      }
    }
    const sorted = [...buckets.entries()].sort((a, b) => b[1] - a[1]);
    const out = [];
    for (const [key] of sorted) {
      const r = (key >> 16) & 255;
      const g = (key >> 8) & 255;
      const b = key & 255;
      const c = { r, g, b };
      if (out.every((p) => dist(p, c) >= minD)) {
        out.push(c);
        if (out.length >= k) break;
      }
    }
    return out;
  }

  dropZone.addEventListener("click", (e) => {
    if (e.target.closest("button")) return;
    fileInput.click();
  });
  dropZone.addEventListener("dragover", (e) => {
    e.preventDefault();
    dropZone.classList.add("drag-over");
  });
  dropZone.addEventListener("dragleave", () => dropZone.classList.remove("drag-over"));
  dropZone.addEventListener("drop", (e) => {
    e.preventDefault();
    dropZone.classList.remove("drag-over");
    const f = e.dataTransfer.files[0];
    if (f && f.type.startsWith("image/")) loadImage(f);
  });
  fileInput.addEventListener("change", () => {
    const f = fileInput.files?.[0];
    if (f) loadImage(f);
    fileInput.value = "";
  });

  function loadImage(file) {
    imageData = null;
    stripBlob = null;
    palette = [];
    swatchSection.style.display = "none";
    dlStripBtn.disabled = true;
    fileHint.textContent = file.name;
    const reader = new FileReader();
    reader.onload = (e) => {
      const img = new Image();
      img.onload = () => {
        const maxSide = 256;
        let w = img.naturalWidth;
        let h = img.naturalHeight;
        const s = Math.min(maxSide / w, maxSide / h, 1);
        w = Math.max(1, Math.round(w * s));
        h = Math.max(1, Math.round(h * s));
        const canvas = document.createElement("canvas");
        canvas.width = w;
        canvas.height = h;
        const ctx = canvas.getContext("2d");
        ctx.drawImage(img, 0, 0, w, h);
        imageData = ctx.getImageData(0, 0, w, h);
        extractBtn.disabled = false;
        status.textContent = `${img.naturalWidth}×${img.naturalHeight} px (analyzed at ${w}×${h}).`;
      };
      img.onerror = () => {
        status.textContent = "Could not decode image.";
        extractBtn.disabled = true;
      };
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);
  }

  extractBtn.addEventListener("click", () => {
    if (!imageData) return;
    const k = Math.min(12, Math.max(3, parseInt(numColors.value, 10) || 8));
    const d = Math.min(120, Math.max(0, parseInt(minDist.value, 10) || 35));
    palette = extractPalette(imageData, k, d);
    swatches.innerHTML = "";
    palette.forEach((c) => {
      const hex =
        "#" +
        [c.r, c.g, c.b]
          .map((x) => x.toString(16).padStart(2, "0"))
          .join("");
      const wrap = document.createElement("div");
      wrap.className = "swatch";
      wrap.innerHTML = `
        <div class="swatch-color" style="background:${hex}" title="${hex}"></div>
        <span class="swatch-hex">${hex}</span>
        <button type="button" class="secondary swatch-copy">Copy</button>
      `;
      wrap.querySelector(".swatch-copy").addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(hex);
          status.textContent = `Copied ${hex}`;
        } catch {
          status.textContent = "Copy failed — select hex manually.";
        }
      });
      wrap.querySelector(".swatch-color").addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(hex);
          status.textContent = `Copied ${hex}`;
        } catch {
          status.textContent = "Copy failed — select hex manually.";
        }
      });
      swatches.appendChild(wrap);
    });
    swatchSection.style.display = "";

    const stripW = palette.length * 64;
    const stripH = 64;
    const c2 = document.createElement("canvas");
    c2.width = stripW;
    c2.height = stripH;
    const x = c2.getContext("2d");
    palette.forEach((c, i) => {
      x.fillStyle = `rgb(${c.r},${c.g},${c.b})`;
      x.fillRect(i * 64, 0, 64, stripH);
    });
    c2.toBlob((b) => {
      stripBlob = b;
      dlStripBtn.disabled = !b;
    }, "image/png");
    status.textContent = `${palette.length} swatches — click a color or Copy for hex.`;
  });

  dlStripBtn.addEventListener("click", () => {
    if (!stripBlob) return;
    const a = document.createElement("a");
    a.href = URL.createObjectURL(stripBlob);
    a.download = "palette-strip.png";
    a.click();
    setTimeout(() => URL.revokeObjectURL(a.href), 4000);
  });
</script>
