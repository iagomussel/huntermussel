  }

  .cp-ref-table code {
    background: hsl(145 80% 50% / 0.1);
    color: #1aeb6a;
    padding: 0.1rem 0.3rem;
    border-radius: 0.25rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
  }

  .cp-ref-examples {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .cp-ref-examples p {
    margin: 0;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    color: #8f9aa6;
  }

  .cp-ref-examples code {
    background: hsl(145 80% 50% / 0.1);
    color: #1aeb6a;
    padding: 0.1rem 0.35rem;
    border-radius: 0.25rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
  }
</style>

<script>
  // ── Constants ──────────────────────────────────────────────
  const WEEKDAY_NAMES = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];
  const MONTH_NAMES = ["","January","February","March","April","May","June","July","August","September","October","November","December"];

  // @-shorthand aliases → canonical 5-field expressions
  const ALIASES = {
    "@yearly":   "0 0 1 1 *",
    "@annually": "0 0 1 1 *",
    "@monthly":  "0 0 1 * *",
    "@weekly":   "0 0 * * 0",
    "@daily":    "0 0 * * *",
    "@midnight": "0 0 * * *",
    "@hourly":   "0 * * * *",
  };

  // ── Field parsing ──────────────────────────────────────────
  // Returns null (= "all"), or sorted array of valid integers.
  // Supports: *, N, N-M, */S, N/S, N-M/S, lists with commas.
  function expandField(field, min, max) {
    if (field === "*") return null;
    const values = new Set();
    for (const part of field.split(",")) {
      if (part.includes("/")) {
        const slashIdx = part.indexOf("/");
        const rangeStr = part.slice(0, slashIdx);
        const stepN = parseInt(part.slice(slashIdx + 1));
        if (isNaN(stepN) || stepN <= 0) throw new Error(`Invalid step in "${part}"`);

        let start, end;
        if (rangeStr === "*") {
          start = min; end = max;
        } else if (rangeStr.includes("-")) {
          [start, end] = rangeStr.split("-").map(Number);
        } else {
          // N/S → start=N, end=max (the non-standard "start/step" form)
          start = parseInt(rangeStr);
          end = max;
        }
        if (isNaN(start) || isNaN(end)) throw new Error(`Invalid range in "${part}"`);
        for (let i = start; i <= end; i += stepN) values.add(i);
      } else if (part.includes("-")) {
        const [a, b] = part.split("-").map(Number);
        if (isNaN(a) || isNaN(b) || a > b) throw new Error(`Invalid range "${part}"`);
        for (let i = a; i <= b; i++) values.add(i);
      } else {
        const n = parseInt(part);
        if (isNaN(n)) throw new Error(`Invalid value "${part}"`);
        values.add(n);
      }
    }
    for (const v of values) {
      if (v < min || v > max) throw new Error(`Value ${v} out of range ${min}–${max}`);
    }
    return [...values].sort((a, b) => a - b);
  }

  // Detect if any field uses the non-standard N/S notation
  function hasStartStep(expr) {
    return expr.trim().split(/\s+/).some(f =>
      f.split(",").some(p => {
        if (!p.includes("/")) return false;
        const base = p.split("/")[0];
        return base !== "*" && !base.includes("-");
      })
    );
  }

  function resolveExpr(raw) {
    const lower = raw.trim().toLowerCase();
    return ALIASES[lower] || raw.trim();
  }

  function validateAndParse(expr) {
    const parts = expr.trim().split(/\s+/);
    if (parts.length !== 5) throw new Error("Expected 5 space-separated fields");
    const [mf, hf, domf, monthf, dowf] = parts;
    return {
      mf, hf, domf, monthf, dowf,
      mins:   expandField(mf,     0,  59),
      hours:  expandField(hf,     0,  23),
      doms:   expandField(domf,   1,  31),
      months: expandField(monthf, 1,  12),
      dows:   expandField(dowf,   0,   6),
    };
  }

  // ── Next run times ─────────────────────────────────────────
  function getNextRuns(expr, count) {
    const { mf, hf, domf, dowf, mins, hours, doms, months, dows } = validateAndParse(expr);
    const domStar = domf === "*";
    const dowStar = dowf === "*";

    const results = [];
    const dt = new Date();
    dt.setSeconds(0, 0);
    dt.setMinutes(dt.getMinutes() + 1);

    let iters = 0;
    while (results.length < count && iters < 525600) {
      const monthOk = !months || months.includes(dt.getMonth() + 1);
      const hourOk  = !hours  || hours.includes(dt.getHours());
      const minOk   = !mins   || mins.includes(dt.getMinutes());
      const dom = dt.getDate(), dow = dt.getDay();
      let dayOk;
      if (domStar && dowStar)  dayOk = true;
      else if (domStar)        dayOk = !dows || dows.includes(dow);
      else if (dowStar)        dayOk = !doms || doms.includes(dom);
      else                     dayOk = (doms?.includes(dom)) || (dows?.includes(dow));

      if (monthOk && dayOk && hourOk && minOk) results.push(new Date(dt));
      dt.setMinutes(dt.getMinutes() + 1);
      iters++;
    }
    return results;
  }

  // ── Human-readable description ─────────────────────────────
  function nthSuffix(n) {
    const v = n % 100;
    if (v >= 11 && v <= 13) return n + "th";
    switch (n % 10) { case 1: return n+"st"; case 2: return n+"nd"; case 3: return n+"rd"; default: return n+"th"; }
  }

  function pad2(n) { return String(n).padStart(2,"0"); }

  // Describe a single cron field part (handles *, N, N-M, */S, N/S, N-M/S)
  function descPart(p, singular, names, max) {
    if (p === "*") return `every ${singular}`;
    if (p.includes("/")) {
      const si = p.indexOf("/");
      const base = p.slice(0, si);
      const step = parseInt(p.slice(si + 1));
      const nth = nthSuffix(step);
      if (base === "*") {
        return step === 1 ? `every ${singular}` : `every ${nth} ${singular}`;
      }
      // N-M/S or N/S
      const [start, end] = base.includes("-") ? base.split("-").map(Number) : [parseInt(base), max];
      const label = names ? `${singular} from ${names[start]||start} through ${names[end]||end}` : `${singular} from ${start} through ${end}`;
      return step === 1 ? `every ${label}` : `every ${nth} ${label}`;
    }
    if (p.includes("-")) {
      const [a, b] = p.split("-").map(Number);
      const na = names ? names[a]||a : a;
      const nb = names ? names[b]||b : b;
      return names
        ? `every ${singular} from ${na} through ${nb}`
        : `${na} through ${nb}`;
    }
    const n = parseInt(p);
    return names ? (names[n] || String(n)) : String(n);
  }

  // Per-field wrappers that handle comma lists
  function descMin(f) {
    if (f === "*") return null; // handled at sentence level
    return f.split(",").map(p => descPart(p, "minute", null, 59)).join(" and ");
  }
  function descHour(f) {
    if (f === "*") return null;
    return f.split(",").map(p => descPart(p, "hour", null, 23)).join(" and ");
  }
  function descDom(f) {
    if (f === "*") return null;
    return f.split(",").map(p => descPart(p, "day-of-month", null, 31)).join(" and ");
  }
  function descMonth(f) {
    if (f === "*") return null;
    return f.split(",").map(p => descPart(p, "month", MONTH_NAMES, 12)).join(" and ");
  }
  function descDow(f) {
    if (f === "*") return null;
    return f.split(",").map(p => descPart(p, "day-of-week", WEEKDAY_NAMES, 6)).join(" and ");
  }

  function describe(rawExpr) {
    const lower = rawExpr.trim().toLowerCase();
    if (lower === "@yearly" || lower === "@annually") return "At midnight on January 1st (once a year).";
    if (lower === "@monthly")  return "At midnight on the 1st of every month.";
    if (lower === "@weekly")   return "At midnight every Sunday.";
    if (lower === "@daily" || lower === "@midnight") return "Every day at midnight.";
    if (lower === "@hourly")   return "Every hour, on the hour.";
    if (lower === "@reboot")   return "At system reboot.";

    const expr = resolveExpr(rawExpr);
    const parts = expr.split(/\s+/);
    if (parts.length !== 5) return "Invalid expression";
    const [mf, hf, domf, monthf, dowf] = parts;
    const isStar = f => f === "*";
    const isNum  = f => /^\d+$/.test(f);

    // ── Quick named patterns ──
    if (isStar(mf)&&isStar(hf)&&isStar(domf)&&isStar(monthf)&&isStar(dowf)) return "Every minute.";
    if (mf==="0"&&hf==="*"&&isStar(domf)&&isStar(monthf)&&isStar(dowf)) return "Every hour, on the hour.";
    if (/^\*\/(\d+)$/.test(mf)&&isStar(hf)&&isStar(domf)&&isStar(monthf)&&isStar(dowf)) {
      const n = parseInt(mf.split("/")[1]);
      return n===1 ? "Every minute." : `Every ${n} minutes.`;
    }
    if (mf==="0"&&/^\*\/(\d+)$/.test(hf)&&isStar(domf)&&isStar(monthf)&&isStar(dowf)) {
      const n = parseInt(hf.split("/")[1]);
      return n===1 ? "Every hour, on the hour." : `Every ${n} hours.`;
    }
    // Simple time patterns (both numeric)
    if (isNum(mf) && isNum(hf)) {
      const t = `${pad2(+hf)}:${pad2(+mf)}`;
      if (isStar(domf)&&isStar(monthf)&&isStar(dowf)) return `Every day at ${t}.`;
      if (isStar(domf)&&isStar(monthf)&&isNum(dowf))  return `Every ${WEEKDAY_NAMES[+dowf]} at ${t}.`;
      if (isStar(domf)&&isStar(monthf)&&/^\d-\d$/.test(dowf)) {
        const [a,b]=dowf.split("-").map(Number);
        return `At ${t} from ${WEEKDAY_NAMES[a]} through ${WEEKDAY_NAMES[b]}.`;
      }
      if (isNum(domf)&&isStar(monthf)&&isStar(dowf)) return `On the ${nthSuffix(+domf)} of every month at ${t}.`;
      if (isStar(domf)&&isNum(monthf)&&isStar(dowf)) return `Every day in ${MONTH_NAMES[+monthf]} at ${t}.`;
    }

    // ── General sentence assembly (crontab.guru style) ──
    // "At minute X past [hour] on [dom] and on [dow] in [month]."
    const minD   = descMin(mf);
    const hourD  = descHour(hf);
    const domD   = descDom(domf);
    const monthD = descMonth(monthf);
    const dowD   = descDow(dowf);

    // Opening: minute clause
    let s = minD ? `At ${minD}` : "Every minute";

    // Hour clause
    if (hourD) s += ` past ${hourD}`;

    // Day clause — when both dom and dow are set, use "and on"
    if (domD && dowD)  s += ` on ${domD} and on ${dowD}`;
    else if (domD)     s += ` on ${domD}`;
    else if (dowD)     s += ` on ${dowD}`;

    // Month clause
    if (monthD) s += ` in ${monthD}`;

    return s + ".";
  }

  // ── Relative time ──────────────────────────────────────────
  function relativeTime(date) {
    const sec = Math.round((date - Date.now()) / 1000);
    if (sec < 60)  return "in < 1 min";
    const min = Math.round(sec / 60);
    if (min < 60)  return `in ${min} min`;
    const h = Math.round(min / 60);
    if (h < 24)    return `in ${h}h`;
    const d = Math.round(h / 24);
    return `in ${d}d`;
  }

  // ── DOM helpers ────────────────────────────────────────────
  const $ = id => document.getElementById(id);

  function setFieldBox(id, value) {
    const el = document.getElementById("field-" + id);
    const vEl = document.getElementById("fv-" + id);
    if (!el || !vEl) return;
    vEl.textContent = value;
    el.classList.toggle("active", value !== "*");
  }

  function renderRuns(runs, tzName) {
    const list = $("cp-run-list");
    if (!runs?.length) {
      list.innerHTML = '<li class="cp-run-placeholder">No upcoming runs found within one year.</li>';
      return;
    }
    const fmt = new Intl.DateTimeFormat(undefined, {
      timeZone: tzName,
      year: "numeric", month: "short", day: "2-digit",
      hour: "2-digit", minute: "2-digit", second: "2-digit",
      hour12: false,
    });
    list.innerHTML = runs.map((dt, i) =>
      `<li>
        <span class="cp-run-num">${String(i+1).padStart(2,"0")}</span>
        <span class="cp-run-abs">${fmt.format(dt)}</span>
        <span class="cp-run-rel">${relativeTime(dt)}</span>
      </li>`
    ).join("");
  }

  function showError(msg) {
    $("cp-desc-row").style.display = "none";
    $("cp-nonstandard-row").style.display = "none";
    $("cp-error-row").style.display = "";
    $("cp-error-msg").textContent = msg;
    $("cp-run-list").innerHTML = '<li class="cp-run-placeholder">Fix the expression to see run times.</li>';
  }

  function showDesc(text, nonStd) {
    $("cp-error-row").style.display = "none";
    $("cp-desc-row").style.display = "";
    $("cp-description").textContent = text;
    $("cp-nonstandard-row").style.display = nonStd ? "" : "none";
  }

  // ── Main parse + render ────────────────────────────────────
  function parseAndRender() {
    const raw = $("cronInput").value.trim() || "* * * * *";
    const tz  = $("tzSelect").value;

    $("cp-runs-tz").textContent = tz;
    document.querySelectorAll(".cp-preset").forEach(btn =>
      btn.classList.toggle("active", btn.dataset.expr === raw)
    );

    const expr = resolveExpr(raw);
    const parts = expr.split(/\s+/);
    if (parts.length === 5) {
      ["min","hour","dom","month","dow"].forEach((id, i) => setFieldBox(id, parts[i]));
    } else {
      ["min","hour","dom","month","dow"].forEach(id => setFieldBox(id, "?"));
    }

    try {
      const nonStd = hasStartStep(expr);
      showDesc(describe(raw), nonStd);
      renderRuns(getNextRuns(expr, 10), tz);
    } catch (err) {
      showError(String(err.message || err));
    }
  }

  // ── Event listeners ────────────────────────────────────────
  $("cronInput").addEventListener("input", parseAndRender);
  $("tzSelect").addEventListener("change", parseAndRender);
  document.querySelectorAll(".cp-preset").forEach(btn =>
    btn.addEventListener("click", () => { $("cronInput").value = btn.dataset.expr; parseAndRender(); })
  );

  // ── Initial render ─────────────────────────────────────────
  $("cronInput").value = "* * * * *";
  parseAndRender();
</script>
