---
import BaseLayout from "../layouts/BaseLayout.astro";

const tools = [
  {
    name: "Base64 Converter + Repair",
    href: "/tools/base64-converter/",
    description:
      "Encode, decode, validate, and repair malformed Base64/Base64URL payloads.",
    type: "Encoding",
  },
  {
    name: "Hash Generator",
    href: "/tools/hash-generator/",
    description:
      "Generate and verify MD5, SHA-1, SHA-256, SHA-384, and SHA-512 hashes.",
    type: "Hashing",
  },
  {
    name: "JSON Formatter / Validator",
    href: "/tools/json-formatter/",
    description:
      "Format, minify, and validate JSON with clear parser error feedback.",
    type: "Validation",
  },
  {
    name: "Utility Calculators",
    href: "/tools/calculators/",
    description:
      "Quick calculators for time conversion, byte units, and infra monthly cost.",
    type: "Calculator",
  },
  {
    name: "Markdown Editor (Yoopta)",
    href: "/tools/markdown-editor/",
    description:
      "Client-side editor powered by Yoopta with markdown serialization output.",
    type: "Editor",
  },
  {
    name: "Validators",
    href: "/tools/validators/",
    description:
      "Validate YAML, OpenAPI basics, and run Terraform lint-style checks.",
    type: "Validation",
  },
  {
    name: "Estimators",
    href: "/tools/estimators/",
    description:
      "Estimate cloud monthly cost and infrastructure sizing requirements.",
    type: "Estimator",
  },
  {
    name: "Online Linters",
    href: "/tools/online-linters/",
    description:
      "Run lightweight syntax and quality lint checks directly in the browser.",
    type: "Linting",
  },
  {
    name: "Pipeline Simulator",
    href: "/tools/pipeline-simulator/",
    description:
      "Model stage duration and failure probabilities to simulate delivery risk.",
    type: "Simulation",
  },
  {
    name: "Log Viewer",
    href: "/tools/log-viewer/",
    description:
      "Parse, filter, and summarize logs with level counts and quick search.",
    type: "Observability",
  },
];
---

<BaseLayout
  title="HunterMussel Tools"
  description="Practical tools for process management, AI implementation, and DevOps execution."
  canonicalPath="/tools/"
>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">/tools</p>
      <h1>HunterMussel Tools</h1>
      <p class="lead">
        Practical engineering tools for encoding, validation, conversion, and
        content authoring. All pages are fully client-side.
      </p>
      <a class="back-link" href="/">Back to main site</a>
    </section>

    <section class="tool-grid">
      {tools.map((tool) => (
        <article class="card">
          <h2>{tool.name}</h2>
          <span class="pill">{tool.type}</span>
          <p>{tool.description}</p>
          <a class="back-link" href={tool.href}>Open tool</a>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>
