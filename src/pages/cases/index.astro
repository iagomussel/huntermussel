---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { ArrowRight } from "lucide-react";

const cases = (await getCollection("cases")).sort(
  (a, b) => b.data.date?.valueOf() - a.data.date?.valueOf()
);

const casesUrl = "https://huntermussel.com/cases/";
const casesSchema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Case Studies",
    url: casesUrl,
    description:
      "Case studies covering AI automation, custom software delivery, technical SEO, cloud infrastructure, and DevOps engineering.",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://huntermussel.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Case Studies",
        item: casesUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "Case Studies",
    url: casesUrl,
    numberOfItems: cases.length,
    itemListElement: cases.map((entry, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `https://huntermussel.com/cases/${entry.id}/`,
      name: entry.data.title,
    })),
  },
];
---

<Layout
  title="Case Studies: AI Automation, DevOps, and Software Delivery"
  description="Explore HunterMussel case studies in AI automation, logistics optimization, CRM intelligence, healthcare scheduling, LMS platforms, and high-performance websites."
  canonicalUrl={casesUrl}
  keywords={[
    "software development case studies",
    "ai automation case studies",
    "devops case studies",
    "technical seo case study",
    "custom software project examples",
    "logistics optimization case study",
    "crm ai case study",
    "lms development case study",
  ]}
  schema={casesSchema}
  pageData={{ pageType: 'cases_listing' }}
>
  <div class="min-h-screen bg-background">
    <div class="absolute inset-0 grid-bg opacity-10 pointer-events-none" />

    <main class="container relative z-10 px-6 pt-32 pb-24">
      <header class="mb-16 text-center">
        <span class="mb-4 inline-block font-heading text-xs font-medium uppercase tracking-widest text-primary">
          // case studies
        </span>
        <h1 class="mb-6 font-heading text-4xl font-bold tracking-tight md:text-6xl">
          Systems shipped for <span class="gradient-text">real operations</span>
        </h1>
        <p class="mx-auto max-w-3xl font-body text-xl leading-relaxed text-muted-foreground">
          Technical case studies covering AI automation, custom software delivery,
          cloud infrastructure, and operational systems built to scale.
        </p>
      </header>

      <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
        {cases.map((entry) => (
          <article class="group flex h-full flex-col overflow-hidden rounded-lg border border-border bg-card/50 transition-all hover:border-primary/30 hover:bg-card">
            {entry.data.image && (
              <div class="aspect-video overflow-hidden border-b border-border">
                <img
                  src={entry.data.image}
                  alt={entry.data.title}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              </div>
            )}
            <div class="flex flex-1 flex-col p-6">
              <div class="mb-4 flex items-center justify-between text-xs text-muted-foreground">
                {entry.data.date && (
                  <time datetime={entry.data.date.toISOString()}>
                    {entry.data.date.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                      timeZone: "UTC",
                    })}
                  </time>
                )}
                {entry.data.tags && entry.data.tags.length > 0 && (
                  <span class="rounded-full border border-border bg-muted/30 px-2 py-0.5">
                    {entry.data.tags[0]}
                  </span>
                )}
              </div>
              <h2 class="mb-3 font-heading text-xl font-bold leading-tight transition-colors group-hover:text-primary">
                <a href={`/cases/${entry.id}/`} class="block">
                  {entry.data.title}
                </a>
              </h2>
              <p class="mb-5 flex-1 font-body text-sm leading-relaxed text-muted-foreground">
                {entry.data.description}
              </p>
              <a
                href={`/cases/${entry.id}/`}
                class="inline-flex items-center gap-1 font-heading text-xs font-semibold text-primary transition-all group-hover:gap-2"
              >
                Read case study
                <ArrowRight size={14} />
              </a>
            </div>
          </article>
        ))}
      </div>
    </main>
  </div>
</Layout>
