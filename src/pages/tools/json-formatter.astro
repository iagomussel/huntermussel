---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ServiceCTA from "@/components/ServiceCTA.astro";
---

<BaseLayout
  title="JSON Formatter / Validator | HunterMussel Tools"
  description="Format, validate, and minify JSON with syntax highlighting, line numbers, stats, and download — fully in-browser."
  canonicalPath="/tools/json-formatter/"
  keywords={[
    "json formatter online",
    "json validator",
    "json beautifier",
    "json minifier",
    "format json online",
    "json pretty print",
    "json lint",
    "json syntax checker",
    "free json formatter",
  ]}
>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">tool / json</p>
      <h1>JSON Formatter</h1>
      <p class="lead">
        Format, validate, and minify JSON with syntax highlighting, inline error
        reporting, and one-click download. Everything runs in your browser.
      </p>
      <a class="back-link" href="/tools/">← Back to tools</a>
    </section>

    <!-- Toolbar -->
    <div class="jf-toolbar card">
      <div class="jf-opts">
        <label class="jf-opt-label" for="indentSel">
          Indent
          <select id="indentSel">
            <option value="2" selected>2 spaces</option>
            <option value="4">4 spaces</option>
            <option value="tab">Tab</option>
          </select>
        </label>
        <label class="jf-check">
          <input id="sortKeys" type="checkbox" />
          <span>Sort keys</span>
        </label>
        <label class="jf-check">
          <input id="unicode" type="checkbox" />
          <span>Escape Unicode</span>
        </label>
      </div>
      <div class="actions">
        <button id="formatBtn" type="button">Format</button>
        <button id="minifyBtn" type="button" class="secondary">Minify</button>
        <button id="validateBtn" type="button" class="secondary">Validate</button>
        <button id="copyBtn" type="button" class="secondary">Copy</button>
        <button id="downloadBtn" type="button" class="secondary">Download .json</button>
        <button id="clearBtn" type="button" class="secondary">Clear</button>
      </div>
    </div>

    <!-- Status bar -->
    <div id="statusBar" class="jf-status" style="display:none">
      <span id="statusBadge" class="jf-badge"></span>
      <span id="statusMsg" class="jf-status-msg"></span>
      <span id="statsArea" class="jf-stats"></span>
    </div>

    <!-- Editor panels -->
    <div class="jf-editor">
      <!-- Input -->
      <div class="jf-panel card">
        <div class="jf-panel-head">
          <span>Input</span>
          <span id="inSize" class="jf-size"></span>
        </div>
        <textarea
          id="jsonInput"
          class="jf-textarea"
          spellcheck="false"
          placeholder='{"name":"hunter","enabled":true,"tags":["ai","devops"]}'
        ></textarea>
      </div>

      <!-- Output -->
      <div class="jf-panel card">
        <div class="jf-panel-head">
          <span>Output</span>
          <span id="outSize" class="jf-size"></span>
        </div>
        <div class="jf-output-wrap" id="outputWrap">
          <div class="jf-lines" id="lineNumbers" aria-hidden="true"></div>
          <pre id="jsonOutput" class="jf-output"></pre>
        </div>
        <div id="errorBox" class="jf-error" style="display:none">
          <span class="jf-error-icon">✕</span>
          <pre id="errorMsg" class="jf-error-msg"></pre>
        </div>
      </div>
    </div>

    <section class="article">
      <article class="card">
        <h2>Syntax Highlighting</h2>
        <p>Keys, strings, numbers, booleans, and null are each colour-coded so
        structure is scannable at a glance — especially useful for deep or wide
        payloads.</p>
      </article>
      <article class="card">
        <h2>Error Reporting</h2>
        <p>Parse errors include the browser's native position hint (line and
        column where available), so you know exactly where to fix without
        counting characters manually.</p>
      </article>
      <article class="card">
        <h2>How To Use</h2>
        <ul>
          <li>Paste or type JSON into the left panel.</li>
          <li>Click <strong>Format</strong> — output renders with highlighting and line numbers.</li>
          <li>Use <strong>Minify</strong> to strip whitespace for transport.</li>
          <li>Use <strong>Sort keys</strong> to alphabetically order object keys.</li>
          <li>Download the result as a <code>.json</code> file or copy to clipboard.</li>
        </ul>
      </article>
      <ServiceCTA
        service="ci-cd-devops"
        title="Working with JSON payloads across CI/CD pipelines?"
        description="HunterMussel designs high-performance delivery pipelines with automated JSON schema validation, contract testing, and API quality gates built in from day one."
        linkLabel="Explore CI/CD & DevOps Engineering"
      />
    </section>
  </main>
</BaseLayout>

<style>
  /* ── Toolbar ── */
  .jf-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    padding: 0.75rem 1rem;
  }

  .jf-opts {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .jf-opt-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--text-2);
  }

  .jf-opt-label select {
    width: auto;
    padding: 0.3rem 0.5rem;
    font-size: 0.78rem;
    font-family: "JetBrains Mono", monospace;
  }

  .jf-check {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    color: var(--text-2);
    cursor: pointer;
  }

  .jf-check input {
    width: auto;
    accent-color: var(--primary);
    cursor: pointer;
  }

  /* ── Status bar ── */
  .jf-status {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid var(--line);
    background: var(--muted);
    margin-bottom: 0.75rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
  }

  .jf-badge {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .jf-badge.ok {
    background: hsl(145 60% 15%);
    color: hsl(145 80% 60%);
    border: 1px solid hsl(145 80% 30%);
  }

  .jf-badge.err {
    background: hsl(0 60% 15%);
    color: hsl(0 70% 65%);
    border: 1px solid hsl(0 60% 30%);
  }

  .jf-badge.info {
    background: var(--primary-soft);
    color: var(--primary);
    border: 1px solid hsl(145 80% 50% / 0.2);
  }

  .jf-status-msg {
    color: var(--text-2);
    flex: 1;
  }

  .jf-stats {
    color: var(--text-2);
    margin-left: auto;
  }

  /* ── Editor ── */
  .jf-editor {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 1.4rem;
  }

  @media (max-width: 800px) {
    .jf-editor { grid-template-columns: 1fr; }
  }

  .jf-panel {
    display: flex;
    flex-direction: column;
    padding: 0;
    overflow: hidden;
    min-height: 420px;
  }

  .jf-panel-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--line);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-2);
    background: var(--muted);
  }

  .jf-size {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    color: var(--primary);
  }

  .jf-textarea {
    flex: 1;
    resize: none !important;
    border: none !important;
    border-radius: 0 !important;
    background: var(--card) !important;
    color: var(--text-1) !important;
    font-family: "JetBrains Mono", monospace !important;
    font-size: 0.82rem !important;
    line-height: 1.6 !important;
    padding: 0.75rem !important;
    min-height: 380px;
  }

  .jf-textarea:focus {
    outline: none !important;
    box-shadow: none !important;
    border: none !important;
  }

  /* ── Output with line numbers ── */
  .jf-output-wrap {
    display: flex;
    flex: 1;
    overflow: auto;
    background: var(--card);
  }

  .jf-lines {
    flex-shrink: 0;
    padding: 0.75rem 0.5rem 0.75rem 0.75rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--text-2);
    text-align: right;
    user-select: none;
    border-right: 1px solid var(--line);
    background: var(--muted);
    min-width: 2.5rem;
    white-space: pre;
  }

  .jf-output {
    flex: 1;
    margin: 0;
    padding: 0.75rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.82rem;
    line-height: 1.6;
    white-space: pre;
    color: var(--text-1);
    tab-size: 2;
    overflow: visible;
  }

  /* ── Syntax colours ── */
  .jk { color: hsl(145 80% 55%); }    /* key      → green  */
  .js { color: hsl(195 80% 65%); }    /* string   → cyan   */
  .ji { color: hsl(30 90% 65%); }     /* number   → orange */
  .jb { color: hsl(280 70% 70%); }    /* boolean  → purple */
  .jn { color: hsl(0 65% 60%); }      /* null     → red    */

  /* ── Error box ── */
  .jf-error {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.65rem 0.75rem;
    background: hsl(0 60% 8%);
    border-top: 1px solid hsl(0 60% 25%);
  }

  .jf-error-icon {
    color: hsl(0 70% 60%);
    font-weight: 800;
    font-family: "JetBrains Mono", monospace;
    flex-shrink: 0;
  }

  .jf-error-msg {
    margin: 0;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    color: hsl(0 70% 65%);
    white-space: pre-wrap;
    word-break: break-all;
  }
</style>

<script type="module">
  const $ = (id) => document.getElementById(id);

  // ── Helpers ──────────────────────────────────────────────
  function getIndent() {
    const v = $("indentSel").value;
    return v === "tab" ? "\t" : Number(v);
  }

  function formatSize(bytes) {
    if (bytes < 1024) return `${bytes} B`;
    if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
    return `${(bytes / (1024 * 1024)).toFixed(2)} MB`;
  }

  function countStats(obj, depth = 0) {
    let keys = 0, strings = 0, numbers = 0, arrays = 0, booleans = 0, nulls = 0, maxDepth = depth;
    if (Array.isArray(obj)) {
      arrays++;
      obj.forEach(v => {
        const s = countStats(v, depth + 1);
        keys += s.keys; strings += s.strings; numbers += s.numbers;
        arrays += s.arrays; booleans += s.booleans; nulls += s.nulls;
        maxDepth = Math.max(maxDepth, s.maxDepth);
      });
    } else if (obj !== null && typeof obj === "object") {
      for (const [, v] of Object.entries(obj)) {
        keys++;
        const s = countStats(v, depth + 1);
        keys += s.keys; strings += s.strings; numbers += s.numbers;
        arrays += s.arrays; booleans += s.booleans; nulls += s.nulls;
        maxDepth = Math.max(maxDepth, s.maxDepth);
      }
    } else if (typeof obj === "string") strings++;
    else if (typeof obj === "number") numbers++;
    else if (typeof obj === "boolean") booleans++;
    else if (obj === null) nulls++;
    return { keys, strings, numbers, arrays, booleans, nulls, maxDepth };
  }

  function sortObjKeys(v) {
    if (Array.isArray(v)) return v.map(sortObjKeys);
    if (v !== null && typeof v === "object") {
      return Object.fromEntries(
        Object.entries(v).sort(([a], [b]) => a.localeCompare(b)).map(([k, val]) => [k, sortObjKeys(val)])
      );
    }
    return v;
  }

  // ── Syntax highlighter ───────────────────────────────────
  function highlight(json) {
    const esc = json
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;");
    return esc.replace(
      /("(?:\\u[a-fA-F0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(?:true|false)\b|\bnull\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g,
      (m) => {
        if (m.startsWith('"')) {
          return m.endsWith(":") || m.endsWith('":')
            ? `<span class="jk">${m}</span>`
            : `<span class="js">${m}</span>`;
        }
        if (m === "true" || m === "false") return `<span class="jb">${m}</span>`;
        if (m === "null") return `<span class="jn">${m}</span>`;
        return `<span class="ji">${m}</span>`;
      }
    );
  }

  function renderOutput(text) {
    const lines = text.split("\n");
    $("lineNumbers").textContent = lines.map((_, i) => i + 1).join("\n");
    $("jsonOutput").innerHTML = highlight(text);
    $("outSize").textContent = formatSize(new TextEncoder().encode(text).length);
    $("errorBox").style.display = "none";
  }

  function showError(err) {
    $("jsonOutput").innerHTML = "";
    $("lineNumbers").textContent = "";
    $("outSize").textContent = "";
    $("errorBox").style.display = "";
    $("errorMsg").textContent = String(err);
  }

  function showStatus(type, msg, stats = "") {
    const bar = $("statusBar");
    bar.style.display = "";
    const badge = $("statusBadge");
    badge.textContent = type === "ok" ? "Valid" : type === "err" ? "Error" : "Info";
    badge.className = "jf-badge " + (type === "ok" ? "ok" : type === "err" ? "err" : "info");
    $("statusMsg").textContent = msg;
    $("statsArea").textContent = stats;
  }

  function parseAndProcess(transform) {
    const raw = $("jsonInput").value || "";
    $("inSize").textContent = raw ? formatSize(new TextEncoder().encode(raw).length) : "";
    if (!raw.trim()) {
      showStatus("info", "No input.");
      return;
    }
    try {
      let parsed = JSON.parse(raw);
      if ($("sortKeys").checked) parsed = sortObjKeys(parsed);
      const replacer = $("unicode").checked ? (k, v) => v : null;
      const result = transform(parsed, replacer);
      renderOutput(result);
      const s = countStats(parsed);
      showStatus("ok", "Valid JSON",
        `keys: ${s.keys} · strings: ${s.strings} · numbers: ${s.numbers} · depth: ${s.maxDepth}`);
    } catch (err) {
      showError(err);
      showStatus("err", String(err));
    }
  }

  // ── Button handlers ──────────────────────────────────────
  $("formatBtn").addEventListener("click", () => {
    parseAndProcess((p, r) => JSON.stringify(p, r, getIndent()));
  });

  $("minifyBtn").addEventListener("click", () => {
    parseAndProcess((p, r) => JSON.stringify(p, r));
  });

  $("validateBtn").addEventListener("click", () => {
    const raw = $("jsonInput").value || "";
    $("inSize").textContent = raw ? formatSize(new TextEncoder().encode(raw).length) : "";
    if (!raw.trim()) { showStatus("info", "No input."); return; }
    try {
      const parsed = JSON.parse(raw);
      $("errorBox").style.display = "none";
      const s = countStats(parsed);
      showStatus("ok", "Valid JSON — no errors found.",
        `keys: ${s.keys} · strings: ${s.strings} · numbers: ${s.numbers} · depth: ${s.maxDepth}`);
    } catch (err) {
      showError(err);
      showStatus("err", String(err));
    }
  });

  $("copyBtn").addEventListener("click", async () => {
    const text = $("jsonOutput").textContent || "";
    if (!text) return;
    await navigator.clipboard.writeText(text);
    showStatus("info", "Output copied to clipboard.");
  });

  $("downloadBtn").addEventListener("click", () => {
    const text = $("jsonOutput").textContent || "";
    if (!text) return;
    const blob = new Blob([text], { type: "application/json" });
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = "output.json";
    a.click();
    setTimeout(() => URL.revokeObjectURL(a.href), 5000);
  });

  $("clearBtn").addEventListener("click", () => {
    $("jsonInput").value = "";
    $("jsonOutput").innerHTML = "";
    $("lineNumbers").textContent = "";
    $("inSize").textContent = "";
    $("outSize").textContent = "";
    $("statusBar").style.display = "none";
    $("errorBox").style.display = "none";
  });

  // Auto-update input size on type
  $("jsonInput").addEventListener("input", () => {
    const raw = $("jsonInput").value || "";
    $("inSize").textContent = raw ? formatSize(new TextEncoder().encode(raw).length) : "";
  });
</script>
