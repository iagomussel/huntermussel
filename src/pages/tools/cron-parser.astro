    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 0.9rem 1.1rem;
    margin-bottom: 0.75rem;
    background: #0e1219;
    border: 1px solid #1c2535;
  }

  .cp-input-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8f9aa6;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .cp-input {
    flex: 1;
    min-width: 200px;
    font-family: "JetBrains Mono", monospace !important;
    font-size: 1.25rem !important;
    letter-spacing: 0.08em;
    color: #f5f9ff !important;
    background: #090b11 !important;
    border: 1px solid #1c2535 !important;
    border-radius: 0.4rem !important;
    padding: 0.55rem 0.85rem !important;
    transition: border-color 0.15s;
  }

  .cp-input:focus {
    outline: none !important;
    border-color: #1aeb6a !important;
    box-shadow: 0 0 0 2px hsl(145 80% 50% / 0.12) !important;
  }

  .cp-tz-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .cp-tz-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8f9aa6;
    white-space: nowrap;
  }

  .cp-tz-select {
    font-family: "JetBrains Mono", monospace !important;
    font-size: 0.8rem !important;
    background: #090b11 !important;
    color: #f5f9ff !important;
    border: 1px solid #1c2535 !important;
    border-radius: 0.4rem;
    padding: 0.45rem 0.65rem !important;
    width: auto !important;
  }

  /* ── Field breakdown ── */
  .cp-fields {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    padding: 0;
    margin-bottom: 0.75rem;
    background: #0e1219;
    border: 1px solid #1c2535;
    border-radius: 0.5rem;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .cp-fields { grid-template-columns: repeat(3, 1fr); }
  }

  .cp-field {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    padding: 1rem 0.5rem;
    border-right: 1px solid #1c2535;
    text-align: center;
    transition: background 0.15s, border-color 0.15s;
  }

  .cp-field:last-child {
    border-right: none;
  }

  .cp-field.active {
    background: hsl(145 80% 50% / 0.07);
    border-color: hsl(145 80% 50% / 0.35);
    outline: 1px solid hsl(145 80% 50% / 0.35);
    outline-offset: -1px;
  }

  .cp-field-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #8f9aa6;
  }

  .cp-field-value {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.1rem;
    font-weight: 700;
    color: #f5f9ff;
    word-break: break-all;
  }

  .cp-field.active .cp-field-value {
    color: #1aeb6a;
  }

  .cp-field-range {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem;
    color: #8f9aa6;
