---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Cron Expression Parser | HunterMussel Tools"
  description="Parse cron expressions into human-readable descriptions and preview the next 10 scheduled run times with timezone support. Fully in-browser."
  canonicalPath="/tools/cron-parser/"
>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">tool / devops</p>
      <h1>Cron Parser</h1>
      <p class="lead">
        Paste a cron expression — get a human-readable description and the next
        scheduled run times.
      </p>
      <a class="back-link" href="/tools/">← Back to tools</a>
    </section>

    <!-- Input row -->
    <div class="cp-input-row card">
      <label class="cp-input-label" for="cronInput">Cron Expression</label>
      <input
        id="cronInput"
        type="text"
        class="cp-input"
        placeholder="* * * * *"
        autocomplete="off"
        spellcheck="false"
      />
      <div class="cp-tz-wrap">
        <label class="cp-tz-label" for="tzSelect">Timezone</label>
        <select id="tzSelect" class="cp-tz-select">
          <option value="UTC">UTC</option>
          <option value="America/New_York">America/New_York</option>
          <option value="America/Chicago">America/Chicago</option>
          <option value="America/Denver">America/Denver</option>
          <option value="America/Los_Angeles">America/Los_Angeles</option>
          <option value="Europe/London">Europe/London</option>
          <option value="Europe/Paris">Europe/Paris</option>
          <option value="Europe/Berlin">Europe/Berlin</option>
          <option value="Asia/Tokyo">Asia/Tokyo</option>
          <option value="Asia/Shanghai">Asia/Shanghai</option>
          <option value="Australia/Sydney">Australia/Sydney</option>
        </select>
      </div>
    </div>

    <!-- Field breakdown -->
    <div class="cp-fields card">
      <div class="cp-field" id="field-min">
        <span class="cp-field-label">Minute</span>
        <span class="cp-field-value" id="fv-min">*</span>
        <span class="cp-field-range">0–59</span>
      </div>
      <div class="cp-field" id="field-hour">
        <span class="cp-field-label">Hour</span>
        <span class="cp-field-value" id="fv-hour">*</span>
        <span class="cp-field-range">0–23</span>
      </div>
      <div class="cp-field" id="field-dom">
        <span class="cp-field-label">Day</span>
        <span class="cp-field-value" id="fv-dom">*</span>
        <span class="cp-field-range">1–31</span>
      </div>
      <div class="cp-field" id="field-month">
        <span class="cp-field-label">Month</span>
        <span class="cp-field-value" id="fv-month">*</span>
        <span class="cp-field-range">1–12</span>
      </div>
      <div class="cp-field" id="field-dow">
        <span class="cp-field-label">Weekday</span>
        <span class="cp-field-value" id="fv-dow">*</span>
        <span class="cp-field-range">0–6 (Sun=0)</span>
      </div>
    </div>

    <!-- Description + error -->
    <div id="cp-desc-row" class="cp-desc-row card">
      <span class="cp-desc-icon">&#9632;</span>
      <span id="cp-description" class="cp-desc-text">Every minute</span>
    </div>
    <div id="cp-error-row" class="cp-error-row card" style="display:none">
      <span class="cp-err-icon">&#x2715;</span>
      <span id="cp-error-msg" class="cp-err-text"></span>
    </div>

    <!-- Quick presets -->
    <div class="cp-presets card">
      <p class="cp-presets-label">Quick Presets</p>
      <div class="cp-preset-grid" id="presetGrid">
        <button class="cp-preset" data-expr="* * * * *">Every minute</button>
        <button class="cp-preset" data-expr="*/5 * * * *">Every 5 minutes</button>
        <button class="cp-preset" data-expr="0 * * * *">Every hour</button>
        <button class="cp-preset" data-expr="0 0 * * *">Every day at midnight</button>
        <button class="cp-preset" data-expr="0 9 * * 1-5">Weekdays at 9am</button>
        <button class="cp-preset" data-expr="0 0 * * 0">Every Sunday at midnight</button>
        <button class="cp-preset" data-expr="0 0 1 * *">First of every month</button>
        <button class="cp-preset" data-expr="0 0 * * 1">Every Monday at midnight</button>
      </div>
    </div>

    <!-- Next runs -->
    <div class="cp-runs card">
      <div class="cp-runs-head">
        <span class="cp-runs-title">Next 10 Run Times</span>
        <span id="cp-runs-tz" class="cp-runs-tz">UTC</span>
      </div>
      <ol id="cp-run-list" class="cp-run-list">
        <li class="cp-run-placeholder">Enter a valid cron expression above.</li>
      </ol>
    </div>

    <!-- Field reference -->
    <details class="cp-ref card">
      <summary class="cp-ref-summary">Field Reference</summary>
      <div class="cp-ref-body">
        <table class="cp-ref-table">
          <thead>
            <tr>
              <th>Field</th>
              <th>Position</th>
              <th>Allowed values</th>
              <th>Special chars</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Minute</td>
              <td>1st</td>
              <td>0–59</td>
              <td rowspan="5"><code>*</code> any &nbsp; <code>,</code> list &nbsp; <code>-</code> range &nbsp; <code>/</code> step</td>
            </tr>
            <tr>
              <td>Hour</td>
              <td>2nd</td>
              <td>0–23</td>
            </tr>
            <tr>
              <td>Day of month</td>
              <td>3rd</td>
              <td>1–31</td>
            </tr>
            <tr>
              <td>Month</td>
              <td>4th</td>
              <td>1–12</td>
            </tr>
            <tr>
              <td>Day of week</td>
              <td>5th</td>
              <td>0–6 (Sun=0, Sat=6)</td>
            </tr>
          </tbody>
        </table>
        <div class="cp-ref-examples">
          <p><code>*/15 * * * *</code> — every 15 minutes</p>
          <p><code>0 8-18 * * 1-5</code> — every hour from 8am to 6pm on weekdays</p>
          <p><code>30 6 1,15 * *</code> — at 06:30 on the 1st and 15th of every month</p>
          <p><code>0 0 * 1,7 *</code> — at midnight every day in January and July</p>
        </div>
      </div>
    </details>
  </main>
</BaseLayout>

<style>
  /* ── Input row ── */
  .cp-input-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 0.9rem 1.1rem;
    margin-bottom: 0.75rem;
    background: #0e1219;
    border: 1px solid #1c2535;
  }

  .cp-input-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8f9aa6;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .cp-input {
    flex: 1;
    min-width: 200px;
    font-family: "JetBrains Mono", monospace !important;
    font-size: 1.25rem !important;
    letter-spacing: 0.08em;
    color: #f5f9ff !important;
    background: #090b11 !important;
    border: 1px solid #1c2535 !important;
    border-radius: 0.4rem !important;
    padding: 0.55rem 0.85rem !important;
    transition: border-color 0.15s;
  }

  .cp-input:focus {
    outline: none !important;
    border-color: #1aeb6a !important;
    box-shadow: 0 0 0 2px hsl(145 80% 50% / 0.12) !important;
  }

  .cp-tz-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .cp-tz-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8f9aa6;
    white-space: nowrap;
  }

  .cp-tz-select {
    font-family: "JetBrains Mono", monospace !important;
    font-size: 0.8rem !important;
    background: #090b11 !important;
    color: #f5f9ff !important;
    border: 1px solid #1c2535 !important;
    border-radius: 0.4rem;
    padding: 0.45rem 0.65rem !important;
    width: auto !important;
  }

  /* ── Field breakdown ── */
  .cp-fields {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    padding: 0;
    margin-bottom: 0.75rem;
    background: #0e1219;
    border: 1px solid #1c2535;
    border-radius: 0.5rem;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .cp-fields { grid-template-columns: repeat(3, 1fr); }
  }

  .cp-field {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    padding: 1rem 0.5rem;
    border-right: 1px solid #1c2535;
    text-align: center;
    transition: background 0.15s, border-color 0.15s;
  }

  .cp-field:last-child {
    border-right: none;
  }

  .cp-field.active {
    background: hsl(145 80% 50% / 0.07);
    border-color: hsl(145 80% 50% / 0.35);
    outline: 1px solid hsl(145 80% 50% / 0.35);
    outline-offset: -1px;
  }

  .cp-field-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #8f9aa6;
  }

  .cp-field-value {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.1rem;
    font-weight: 700;
    color: #f5f9ff;
    word-break: break-all;
  }

  .cp-field.active .cp-field-value {
    color: #1aeb6a;
  }

  .cp-field-range {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem;
    color: #8f9aa6;
    opacity: 0.7;
  }

  /* ── Description row ── */
  .cp-desc-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1.1rem;
    margin-bottom: 0.75rem;
    background: #0e1219;
    border: 1px solid #1c2535;
    border-left: 3px solid #1aeb6a;
  }

  .cp-desc-icon {
    color: #1aeb6a;
    font-size: 0.6rem;
    flex-shrink: 0;
  }

  .cp-desc-text {
    font-family: "JetBrains Mono", monospace;
    font-size: 1rem;
    font-weight: 600;
    color: #f5f9ff;
    letter-spacing: 0.02em;
  }

  /* ── Error row ── */
  .cp-error-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.1rem;
    margin-bottom: 0.75rem;
    background: hsl(0 60% 8%);
    border: 1px solid hsl(0 60% 25%);
    border-left: 3px solid hsl(0 70% 60%);
  }

  .cp-err-icon {
    color: hsl(0 70% 60%);
    font-weight: 800;
    font-family: "JetBrains Mono", monospace;
    flex-shrink: 0;
  }

  .cp-err-text {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.82rem;
    color: hsl(0 70% 65%);
  }

  /* ── Presets ── */
  .cp-presets {
    padding: 0.9rem 1.1rem;
    margin-bottom: 0.75rem;
    background: #0e1219;
    border: 1px solid #1c2535;
  }

  .cp-presets-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #8f9aa6;
    margin: 0 0 0.65rem;
  }

  .cp-preset-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .cp-preset {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.35rem 0.7rem;
    background: #090b11;
    color: #8f9aa6;
    border: 1px solid #1c2535;
    border-radius: 0.35rem;
    cursor: pointer;
    transition: color 0.12s, border-color 0.12s, background 0.12s;
  }

  .cp-preset:hover {
    color: #1aeb6a;
    border-color: hsl(145 80% 50% / 0.5);
    background: hsl(145 80% 50% / 0.06);
  }

  .cp-preset.active {
    color: #1aeb6a;
    border-color: #1aeb6a;
    background: hsl(145 80% 50% / 0.1);
  }

  /* ── Next runs ── */
  .cp-runs {
    padding: 0;
    margin-bottom: 0.75rem;
    background: #0e1219;
    border: 1px solid #1c2535;
    overflow: hidden;
  }

  .cp-runs-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.55rem 1rem;
    border-bottom: 1px solid #1c2535;
    background: hsl(214 16% 10% / 0.8);
  }

  .cp-runs-title {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #8f9aa6;
  }

  .cp-runs-tz {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.68rem;
    color: #1aeb6a;
    font-weight: 600;
  }

  .cp-run-list {
    list-style: none;
    margin: 0;
    padding: 0.25rem 0;
  }

  .cp-run-list li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid #1c2535;
    font-family: "JetBrains Mono", monospace;
  }

  .cp-run-list li:last-child {
    border-bottom: none;
  }

  .cp-run-placeholder {
    color: #8f9aa6;
    font-size: 0.82rem;
    font-family: "JetBrains Mono", monospace;
    padding: 1rem !important;
    justify-content: center !important;
  }

  .cp-run-num {
    font-size: 0.65rem;
    font-weight: 700;
    color: #8f9aa6;
    min-width: 1.6rem;
    text-align: right;
    flex-shrink: 0;
  }

  .cp-run-abs {
    font-size: 0.85rem;
    font-weight: 600;
    color: #f5f9ff;
    flex: 1;
  }

  .cp-run-rel {
    font-size: 0.75rem;
    color: #1aeb6a;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Field reference ── */
  .cp-ref {
    padding: 0;
    background: #0e1219;
    border: 1px solid #1c2535;
    margin-bottom: 1.4rem;
    overflow: hidden;
    border-radius: 0.5rem;
  }

  .cp-ref-summary {
    padding: 0.75rem 1.1rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8f9aa6;
    cursor: pointer;
    user-select: none;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: color 0.12s;
  }

  .cp-ref-summary::before {
    content: "▶";
    font-size: 0.6rem;
    transition: transform 0.15s;
  }

  details[open] .cp-ref-summary::before {
    transform: rotate(90deg);
  }

  .cp-ref-summary:hover {
    color: #f5f9ff;
  }

  .cp-ref-body {
    padding: 0.75rem 1.1rem 1rem;
    border-top: 1px solid #1c2535;
  }

  .cp-ref-table {
    width: 100%;
    border-collapse: collapse;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    color: #f5f9ff;
    margin-bottom: 1rem;
  }

  .cp-ref-table th {
    text-align: left;
    padding: 0.45rem 0.75rem;
    background: #090b11;
    color: #8f9aa6;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    border-bottom: 1px solid #1c2535;
  }

  .cp-ref-table td {
    padding: 0.4rem 0.75rem;
    border-bottom: 1px solid #1c2535;
    color: #f5f9ff;
  }

  .cp-ref-table tr:last-child td {
    border-bottom: none;
  }

  .cp-ref-table code {
    background: hsl(145 80% 50% / 0.1);
    color: #1aeb6a;
    padding: 0.1rem 0.3rem;
    border-radius: 0.25rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
  }

  .cp-ref-examples {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .cp-ref-examples p {
    margin: 0;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    color: #8f9aa6;
  }

  .cp-ref-examples code {
    background: hsl(145 80% 50% / 0.1);
    color: #1aeb6a;
    padding: 0.1rem 0.35rem;
    border-radius: 0.25rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
  }
</style>

<script type="module">
  // ── Constants ──────────────────────────────────────────────
  const WEEKDAY_NAMES = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"];
  const MONTH_NAMES = [
    "", "January", "February", "March", "April", "May", "June",
    "July", "August", "September", "October", "November", "December"
  ];

  // ── Field parsing ──────────────────────────────────────────
  function expandField(field, min, max) {
    if (field === "*") return null; // null means "all"
    const values = new Set();
    for (const part of field.split(",")) {
      if (part.includes("/")) {
        const [range, step] = part.split("/");
        const stepN = parseInt(step);
        if (isNaN(stepN) || stepN <= 0) throw new Error(`Invalid step: ${step}`);
        const [start, end] =
          range === "*" ? [min, max] : range.split("-").map(Number);
        for (let i = range === "*" ? min : start; i <= (end !== undefined ? end : max); i += stepN) {
          values.add(i);
        }
      } else if (part.includes("-")) {
        const [a, b] = part.split("-").map(Number);
        if (isNaN(a) || isNaN(b) || a > b) throw new Error(`Invalid range: ${part}`);
        for (let i = a; i <= b; i++) values.add(i);
      } else {
        const n = parseInt(part);
        if (isNaN(n)) throw new Error(`Invalid value: ${part}`);
        values.add(n);
      }
    }
    // Validate all values are within bounds
    for (const v of values) {
      if (v < min || v > max) throw new Error(`Value ${v} out of range ${min}–${max}`);
    }
    return [...values].sort((a, b) => a - b);
  }

  function validateAndParse(expr) {
    const parts = expr.trim().split(/\s+/);
    if (parts.length !== 5) throw new Error("Expected 5 space-separated fields");
    const [mf, hf, domf, monthf, dowf] = parts;
    return {
      mf, hf, domf, monthf, dowf,
      mins: expandField(mf, 0, 59),
      hours: expandField(hf, 0, 23),
      doms: expandField(domf, 1, 31),
      months: expandField(monthf, 1, 12),
      dows: expandField(dowf, 0, 6),
    };
  }

  // ── Next run times ─────────────────────────────────────────
  function getNextRuns(expr, count) {
    const { mf, hf, domf, dowf, mins, hours, doms, months, dows } = validateAndParse(expr);

    const domStar = domf === "*";
    const dowStar = dowf === "*";

    const results = [];
    let dt = new Date();
    dt.setSeconds(0, 0);
    dt.setMinutes(dt.getMinutes() + 1);

    let iters = 0;
    while (results.length < count && iters < 525600) {
      const m = dt.getMinutes();
      const h = dt.getHours();
      const dom = dt.getDate();
      const month = dt.getMonth() + 1;
      const dow = dt.getDay();

      const monthOk = !months || months.includes(month);
      const hourOk = !hours || hours.includes(h);
      const minOk = !mins || mins.includes(m);

      let dayOk;
      if (domStar && dowStar) dayOk = true;
      else if (domStar) dayOk = !dows || dows.includes(dow);
      else if (dowStar) dayOk = !doms || doms.includes(dom);
      else dayOk = (doms && doms.includes(dom)) || (dows && dows.includes(dow));

      if (monthOk && dayOk && hourOk && minOk) {
        results.push(new Date(dt));
      }
      dt.setMinutes(dt.getMinutes() + 1);
      iters++;
    }
    return results;
  }

  // ── Human-readable description ─────────────────────────────
  function ordinal(n) {
    const s = ["th", "st", "nd", "rd"];
    const v = n % 100;
    return n + (s[(v - 20) % 10] || s[v] || s[0]);
  }

  function padTime(h, m) {
    return `${String(h).padStart(2, "0")}:${String(m).padStart(2, "0")}`;
  }

  function describe(expr) {
    const parts = expr.trim().split(/\s+/);
    if (parts.length !== 5) return "Invalid expression";
    const [mf, hf, domf, monthf, dowf] = parts;

    // Every minute
    if (mf === "*" && hf === "*" && domf === "*" && monthf === "*" && dowf === "*") {
      return "Every minute";
    }

    // Every N minutes: */N * * * *
    if (/^\*\/\d+$/.test(mf) && hf === "*" && domf === "*" && monthf === "*" && dowf === "*") {
      const n = parseInt(mf.split("/")[1]);
      return n === 1 ? "Every minute" : `Every ${n} minutes`;
    }

    // Every hour on the hour: 0 * * * *
    if (mf === "0" && hf === "*" && domf === "*" && monthf === "*" && dowf === "*") {
      return "Every hour, on the hour";
    }

    // Every N hours: 0 */N * * *
    if (mf === "0" && /^\*\/\d+$/.test(hf) && domf === "*" && monthf === "*" && dowf === "*") {
      const n = parseInt(hf.split("/")[1]);
      return n === 1 ? "Every hour, on the hour" : `Every ${n} hours`;
    }

    const isSimpleNum = (f) => /^\d+$/.test(f);

    const h = isSimpleNum(hf) ? parseInt(hf) : null;
    const m = isSimpleNum(mf) ? parseInt(mf) : null;
    const timeStr = h !== null && m !== null ? `at ${padTime(h, m)}` : null;

    // Every day at HH:MM: M H * * *
    if (timeStr && domf === "*" && monthf === "*" && dowf === "*") {
      return `Every day ${timeStr}`;
    }

    // Specific weekday(s): M H * * D
    if (timeStr && domf === "*" && monthf === "*" && isSimpleNum(dowf)) {
      const day = WEEKDAY_NAMES[parseInt(dowf)] || `weekday ${dowf}`;
      return `Every ${day} ${timeStr}`;
    }

    // Weekday range: M H * * D-D
    if (timeStr && domf === "*" && monthf === "*" && /^\d-\d$/.test(dowf)) {
      const [da, db] = dowf.split("-").map(Number);
      const dayA = WEEKDAY_NAMES[da] || da;
      const dayB = WEEKDAY_NAMES[db] || db;
      return `${timeStr} every ${dayA} through ${dayB}`;
    }

    // Specific day of month: M H D * *
    if (timeStr && isSimpleNum(domf) && monthf === "*" && dowf === "*") {
      return `On the ${ordinal(parseInt(domf))} of every month ${timeStr}`;
    }

    // Specific month: M H * M *
    if (timeStr && domf === "*" && isSimpleNum(monthf) && dowf === "*") {
      const mon = MONTH_NAMES[parseInt(monthf)] || monthf;
      return `Every day in ${mon} ${timeStr}`;
    }

    // Specific day and month: M H D M *
    if (timeStr && isSimpleNum(domf) && isSimpleNum(monthf) && dowf === "*") {
      const mon = MONTH_NAMES[parseInt(monthf)] || monthf;
      return `On ${ordinal(parseInt(domf))} of ${mon} ${timeStr}`;
    }

    // First of month midnight shortcut
    if (mf === "0" && hf === "0" && domf === "1" && monthf === "*" && dowf === "*") {
      return "At midnight on the 1st of every month";
    }

    // Fallback: describe each field
    const parts2 = [];
    if (mf !== "*") parts2.push(`minute: ${mf}`);
    if (hf !== "*") parts2.push(`hour: ${hf}`);
    if (domf !== "*") parts2.push(`day of month: ${domf}`);
    if (monthf !== "*") parts2.push(`month: ${monthf}`);
    if (dowf !== "*") parts2.push(`weekday: ${dowf}`);
    return parts2.length ? "Runs when " + parts2.join(", ") : "Every minute";
  }

  // ── Relative time ──────────────────────────────────────────
  function relativeTime(date) {
    const diffMs = date - Date.now();
    const diffSec = Math.round(diffMs / 1000);
    if (diffSec < 60) return "in < 1 min";
    const diffMin = Math.round(diffSec / 60);
    if (diffMin < 60) return `in ${diffMin} min`;
    const diffH = Math.round(diffMin / 60);
    if (diffH < 24) return `in ${diffH} hour${diffH !== 1 ? "s" : ""}`;
    const diffD = Math.round(diffH / 24);
    return `in ${diffD} day${diffD !== 1 ? "s" : ""}`;
  }

  // ── DOM helpers ────────────────────────────────────────────
  const $ = (id) => document.getElementById(id);

  function setFieldBox(id, value) {
    const el = document.getElementById("field-" + id);
    const valEl = document.getElementById("fv-" + id);
    if (!el || !valEl) return;
    valEl.textContent = value;
    if (value !== "*") {
      el.classList.add("active");
    } else {
      el.classList.remove("active");
    }
  }

  function renderRuns(runs, tzName) {
    const list = $("cp-run-list");
    if (!runs || runs.length === 0) {
      list.innerHTML = '<li class="cp-run-placeholder">No upcoming runs found within one year.</li>';
      return;
    }
    const fmt = new Intl.DateTimeFormat(undefined, {
      timeZone: tzName,
      year: "numeric",
      month: "short",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: false,
    });
    list.innerHTML = runs
      .map((dt, i) => {
        const abs = fmt.format(dt);
        const rel = relativeTime(dt);
        return `<li>
          <span class="cp-run-num">${String(i + 1).padStart(2, "0")}</span>
          <span class="cp-run-abs">${abs}</span>
          <span class="cp-run-rel">${rel}</span>
        </li>`;
      })
      .join("");
  }

  function showError(msg) {
    $("cp-desc-row").style.display = "none";
    $("cp-error-row").style.display = "";
    $("cp-error-msg").textContent = msg;
    $("cp-run-list").innerHTML = '<li class="cp-run-placeholder">Fix the expression to see run times.</li>';
  }

  function showDesc(text) {
    $("cp-error-row").style.display = "none";
    $("cp-desc-row").style.display = "";
    $("cp-description").textContent = text;
  }

  // ── Main parse + render ────────────────────────────────────
  function parseAndRender() {
    const expr = $("cronInput").value.trim() || "* * * * *";
    const tz = $("tzSelect").value;

    // Update timezone badge
    $("cp-runs-tz").textContent = tz;

    // Update preset active state
    document.querySelectorAll(".cp-preset").forEach((btn) => {
      btn.classList.toggle("active", btn.dataset.expr === expr);
    });

    const parts = expr.split(/\s+/);
    if (parts.length === 5) {
      setFieldBox("min", parts[0]);
      setFieldBox("hour", parts[1]);
      setFieldBox("dom", parts[2]);
      setFieldBox("month", parts[3]);
      setFieldBox("dow", parts[4]);
    } else {
      ["min", "hour", "dom", "month", "dow"].forEach((id) => setFieldBox(id, "?"));
    }

    try {
      const desc = describe(expr);
      showDesc(desc);
      const runs = getNextRuns(expr, 10);
      renderRuns(runs, tz);
    } catch (err) {
      showError(String(err.message || err));
    }
  }

  // ── Event listeners ────────────────────────────────────────
  $("cronInput").addEventListener("input", parseAndRender);
  $("tzSelect").addEventListener("change", parseAndRender);

  document.querySelectorAll(".cp-preset").forEach((btn) => {
    btn.addEventListener("click", () => {
      $("cronInput").value = btn.dataset.expr;
      parseAndRender();
    });
  });

  // ── Initial render ─────────────────────────────────────────
  $("cronInput").value = "* * * * *";
  parseAndRender();
</script>
