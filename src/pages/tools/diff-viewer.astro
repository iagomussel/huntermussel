---
import BaseLayout from "@/layouts/BaseLayout.astro";
import DiffWorkbench from "@/components/react/tools/diff-viewer/DiffWorkbench";
import ServiceCTA from "@/components/ServiceCTA.astro";
---

<BaseLayout
  title="Diff Viewer | HunterMussel Tools"
  description="Compare two texts with a VS Code-style diff editor, side-by-side or inline review, syntax-aware highlighting, file uploads, and patch export. Runs entirely in your browser."
  canonicalPath="/tools/diff-viewer/"
  keywords={[
    "diff viewer online",
    "text diff tool",
    "code diff viewer",
    "side by side diff",
    "file comparison tool",
    "online diff checker",
    "diff editor browser",
    "unified diff viewer",
    "free diff tool",
  ]}
>
  <main class="page diff-page">
    <section class="hero diff-hero">
      <p class="eyebrow">tool / editor</p>
      <h1>Diff Viewer</h1>
      <p class="lead">
        A Monaco-powered diff workbench with editable panes, inline or split review,
        syntax-aware rendering, collapsed unchanged regions, and real patch export.
      </p>
      <a class="back-link" href="/tools/">← Back to tools</a>
    </section>

    <DiffWorkbench client:only="react" />

    <section class="article">
      <ServiceCTA
        service="ci-cd-devops"
        title="Tired of manual code review bottlenecks slowing down deployments?"
        description="HunterMussel builds automated deployment pipelines with PR review automation, change impact analysis, and one-click rollback — so your team ships faster with confidence."
        linkLabel="Explore CI/CD & DevOps Engineering"
      />
    </section>
  </main>
</BaseLayout>

<style>
  .diff-page {
    max-width: min(1600px, calc(100vw - 1.5rem));
    padding-bottom: 5rem;
  }

  .diff-hero {
    max-width: 72ch;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 700px) {
    .diff-page {
      max-width: calc(100vw - 1rem);
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }
  }
</style>
