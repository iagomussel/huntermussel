---
import Layout from "@/layouts/Layout.astro";

const toolsUrl = "https://huntermussel.com/tools/";
const toolsList = [
  { name: "Base64 Converter", slug: "base64-converter" },
  { name: "Hash Generator", slug: "hash-generator" },
  { name: "JSON Formatter", slug: "json-formatter" },
  { name: "Image Optimizer", slug: "image-optimizer" },
  { name: "Markdown Editor", slug: "markdown-editor" },
  { name: "Estimators", slug: "estimators" },
  { name: "Log Viewer", slug: "log-viewer" },
  { name: "JWT Inspector", slug: "jwt-inspector" },
  { name: "Cron Parser", slug: "cron-parser" },
  { name: "Online Linters", slug: "online-linters" },
  { name: "Diff Viewer", slug: "diff-viewer" },
];
const toolsSchema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Free Developer Tools — HunterMussel",
    url: toolsUrl,
    description:
      "Free client-side developer tools: Base64, Hash Generator, JSON Formatter, Image Optimizer, Markdown Editor, JWT Inspector, Cron Parser, and more. No account, no uploads.",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://huntermussel.com/" },
      { "@type": "ListItem", position: 2, name: "Tools", item: toolsUrl },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "Developer Tools",
    url: toolsUrl,
    numberOfItems: toolsList.length,
    itemListElement: toolsList.map((tool, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `https://huntermussel.com/tools/${tool.slug}/`,
      name: tool.name,
    })),
  },
];
---

<Layout
  title="Free Developer Tools: Base64, Hash, JSON, JWT, Cron & More"
  description="Free client-side developer tools for encoding, hashing, formatting, imaging, and more. No account, no uploads — everything runs in your browser."
  canonicalUrl={toolsUrl}
  keywords={[
    "free developer tools",
    "base64 converter online",
    "hash generator tool",
    "json formatter online",
    "jwt inspector tool",
    "cron parser tool",
    "image optimizer browser",
    "markdown editor online",
    "online linter tool",
    "diff viewer online",
    "developer utilities",
  ]}
  schema={toolsSchema}
>
  <div class="tools-page">
    <!-- Hero -->
    <div class="tools-hero">
      <div class="tools-container">
        <span class="tools-eyebrow">// tools</span>
        <h1 class="tools-title">Free Developer Tools</h1>
        <p class="tools-lead">
          Client-side utilities for encoding, hashing, imaging, and more.
          No account, no uploads, no tracking — everything runs in your browser.
        </p>
      </div>
    </div>

    <!-- Grid -->
    <div class="tools-container tools-grid-wrap">
      <div class="tools-grid">

        <a href="/tools/base64-converter" class="tool-card">
          <span class="tool-cat">// encoding</span>
          <div class="tool-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6M9 12h6M9 15h4"/>
            </svg>
          </div>
          <h2 class="tool-name">Base64 Converter</h2>
          <p class="tool-desc">Convert, validate, and repair Base64/Base64URL payloads fully client-side.</p>
        </a>

        <a href="/tools/hash-generator" class="tool-card">
          <span class="tool-cat">// hashing</span>
          <div class="tool-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/>
              <line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/>
            </svg>
          </div>
          <h2 class="tool-name">Hash Generator</h2>
          <p class="tool-desc">Generate and verify MD5, SHA-1, SHA-256, SHA-384, and SHA-512 hashes.</p>
        </a>

        <a href="/tools/json-formatter" class="tool-card">
          <span class="tool-cat">// json</span>
          <div class="tool-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <h2 class="tool-name">JSON Formatter</h2>
          <p class="tool-desc">Format, validate, and minify JSON payloads with syntax highlighting.</p>
        </a>

        <a href="/tools/image-optimizer" class="tool-card tool-card--new">
          <span class="tool-cat">// imaging</span>
          <span class="tool-badge">new</span>
          <div class="tool-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
          </div>
          <h2 class="tool-name">Image Optimizer</h2>
          <p class="tool-desc">Convert images to WebP in-browser. Adjust quality, resize, batch download.</p>
        </a>

        <a href="/tools/markdown-editor" class="tool-card">
          <span class="tool-cat">// writing</span>
          <div class="tool-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
          </div>
          <h2 class="tool-name">Markdown Editor</h2>
          <p class="tool-desc">Live Markdown editor with preview, export, and formatting shortcuts.</p>
        </a>

        <a href="/tools/estimators" class="tool-card">
          <span class="tool-cat">// planning</span>
          <div class="tool-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/>
              <line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/>
            </svg>
          </div>
          <h2 class="tool-name">Estimators</h2>
          <p class="tool-desc">Project and effort estimation tools for engineering teams.</p>
        </a>

        <a href="/tools/log-viewer" class="tool-card">
          <span class="tool-cat">// devops</span>
          <div class="tool-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/>
              <line x1="8" y1="17" x2="16" y2="17"/><polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <h2 class="tool-name">Log Viewer</h2>
          <p class="tool-desc">Parse, filter, and inspect structured log files directly in the browser.</p>
        </a>

        <a href="/tools/jwt-inspector" class="tool-card tool-card--new">
          <span class="tool-cat">// security</span>
          <span class="tool-badge">new</span>
          <div class="tool-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <h2 class="tool-name">JWT Inspector</h2>
          <p class="tool-desc">Decode, inspect, and audit JWT tokens — expiry countdown, claim explanations, and security warnings.</p>
        </a>

        <a href="/tools/cron-parser" class="tool-card tool-card--new">
          <span class="tool-cat">// devops</span>
          <span class="tool-badge">new</span>
          <div class="tool-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h2 class="tool-name">Cron Parser</h2>
          <p class="tool-desc">Translate cron expressions into plain English and preview the next scheduled run times.</p>
        </a>

        <a href="/tools/online-linters" class="tool-card tool-card--new">
          <span class="tool-cat">// linting</span>
          <span class="tool-badge">new</span>
          <div class="tool-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h2 class="tool-name">Online Linters</h2>
          <p class="tool-desc">A full-featured, real-time code linter for JSON, YAML, JavaScript, and Markdown powered by Monaco Editor.</p>
        </a>

        <a href="/tools/diff-viewer" class="tool-card tool-card--new">
          <span class="tool-cat">// text</span>
          <span class="tool-badge">new</span>
          <div class="tool-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
              <path d="M3 3l7.07 16.97 2.51-7.39 7.39-2.51L3 3z"/>
            </svg>
          </div>
          <h2 class="tool-name">Diff Viewer</h2>
          <p class="tool-desc">Compare two texts side-by-side or unified — added, removed, and unchanged lines highlighted instantly.</p>
        </a>

        <a href="/tools/regex-tester" class="tool-card tool-card--new">
          <span class="tool-cat">// text</span>
          <span class="tool-badge">new</span>
          <div class="tool-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 3l18 0M3 9l18 0M3 15l10 0"/><circle cx="17" cy="15" r="3"/><path d="m20.2 18.2 1.8 1.8"/>
            </svg>
          </div>
          <h2 class="tool-name">Regex Tester</h2>
          <p class="tool-desc">Live regex matching with coloured capture groups, match positions, and one-click patterns for email, URL, CPF, CNPJ.</p>
        </a>

        <a href="/tools/yaml-json" class="tool-card tool-card--new">
          <span class="tool-cat">// devops</span>
          <span class="tool-badge">new</span>
          <div class="tool-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 16V4m0 0L3 8m4-4 4 4M17 8v12m0 0 4-4m-4 4-4-4"/>
            </svg>
          </div>
          <h2 class="tool-name">YAML ↔ JSON</h2>
          <p class="tool-desc">Bidirectional YAML and JSON converter with real-time validation and inline error reporting. No server, no logs.</p>
        </a>

        <a href="/tools/timestamp" class="tool-card tool-card--new">
          <span class="tool-cat">// devops</span>
          <span class="tool-badge">new</span>
          <div class="tool-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h2 class="tool-name">Timestamp Converter</h2>
          <p class="tool-desc">Convert Unix timestamps (seconds or ms) to UTC, local time, and relative time. Converts back too.</p>
        </a>

        <a href="/tools/chmod" class="tool-card tool-card--new">
          <span class="tool-cat">// devops</span>
          <span class="tool-badge">new</span>
          <div class="tool-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <h2 class="tool-name">chmod Calculator</h2>
          <p class="tool-desc">Click checkboxes or type an octal to get symbolic notation and a ready-to-copy chmod command. Security warnings included.</p>
        </a>

        <a href="/tools/sla-calculator" class="tool-card tool-card--new">
          <span class="tool-cat">// devops</span>
          <span class="tool-badge">new</span>
          <div class="tool-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
            </svg>
          </div>
          <h2 class="tool-name">SLA Calculator</h2>
          <p class="tool-desc">Enter an uptime percentage and see exact downtime per day, week, month, and year. Comparison table for the standard nines.</p>
        </a>

        <a href="/tools/http-status" class="tool-card tool-card--new">
          <span class="tool-cat">// reference</span>
          <span class="tool-badge">new</span>
          <div class="tool-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <h2 class="tool-name">HTTP Status Codes</h2>
          <p class="tool-desc">Search and filter all HTTP status codes with plain-English descriptions and REST API usage guidance.</p>
        </a>

        <a href="/tools/uuid" class="tool-card tool-card--new">
          <span class="tool-cat">// encoding</span>
          <span class="tool-badge">new</span>
          <div class="tool-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="20" height="10" rx="2"/><path d="M7 12h.01M12 12h.01M17 12h.01"/>
            </svg>
          </div>
          <h2 class="tool-name">UUID Generator</h2>
          <p class="tool-desc">Generate up to 100 UUID v4 values instantly. Toggle hyphens, copy all, or download as a text file.</p>
        </a>

      </div>
    </div>
  </div>
</Layout>

<style>
  .tools-page {
    min-height: 100vh;
  }

  .tools-hero {
    border-b: 1px solid hsl(var(--border));
    padding: 5rem 0 3rem;
    background: linear-gradient(180deg, hsl(var(--card) / 0.4) 0%, transparent 100%);
  }

  .tools-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .tools-eyebrow {
    display: block;
    font-family: var(--font-heading, "JetBrains Mono", monospace);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: hsl(var(--primary));
    margin-bottom: 0.75rem;
  }

  .tools-title {
    margin: 0 0 1rem;
    font-family: var(--font-heading, "JetBrains Mono", monospace);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    color: hsl(var(--foreground));
    letter-spacing: -0.02em;
  }

  .tools-lead {
    margin: 0;
    max-width: 56ch;
    font-size: 1rem;
    line-height: 1.6;
    color: hsl(var(--muted-foreground));
  }

  .tools-grid-wrap {
    padding-top: 3rem;
    padding-bottom: 5rem;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
  }

  .tool-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.25rem;
    border: 1px solid hsl(var(--border));
    border-radius: 0.75rem;
    background: hsl(var(--card) / 0.5);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, background 0.15s, box-shadow 0.15s, transform 0.15s;
  }

  .tool-card:hover {
    border-color: hsl(var(--primary) / 0.3);
    background: hsl(var(--card));
    box-shadow: 0 0 20px hsl(var(--primary) / 0.08);
    transform: translateY(-2px);
  }

  .tool-cat {
    font-family: var(--font-heading, "JetBrains Mono", monospace);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
  }

  .tool-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-family: var(--font-heading, "JetBrains Mono", monospace);
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: hsl(var(--primary-foreground));
    background: hsl(var(--primary));
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
  }

  .tool-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid hsl(var(--border));
    border-radius: 0.5rem;
    background: hsl(var(--muted) / 0.5);
    color: hsl(var(--primary));
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .tool-card:hover .tool-icon {
    border-color: hsl(var(--primary) / 0.3);
    box-shadow: 0 0 12px hsl(var(--primary) / 0.15);
  }

  .tool-name {
    margin: 0;
    font-family: var(--font-heading, "JetBrains Mono", monospace);
    font-size: 0.9rem;
    font-weight: 600;
    color: hsl(var(--foreground));
    line-height: 1.3;
  }

  .tool-desc {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.55;
    color: hsl(var(--muted-foreground));
  }

  @media (max-width: 480px) {
    .tools-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
