---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Pipeline Simulator | HunterMussel Tools"
  description="Simulate CI/CD pipeline runtime and failure rates with stage-level probabilities."
  canonicalPath="/tools/pipeline-simulator/"
>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">tool / simulation</p>
      <h1>Pipeline Simulator</h1>
      <p class="lead">
        Model your pipeline by stage duration and failure probability to estimate
        expected success rate and average runtime.
      </p>
      <a class="back-link" href="/tools/">Back to tools index</a>
    </section>

    <section class="tool-layout">
      <article class="card stack">
        <p class="small">One stage per line: <code>name,duration_minutes,failure_percent</code></p>
        <div>
          <label class="label" for="pipelineStages">Pipeline stages</label>
          <textarea id="pipelineStages">build,8,3
test,14,8
security-scan,6,5
deploy,5,2</textarea>
        </div>
        <div>
          <label class="label" for="pipelineRuns">Simulation runs</label>
          <input id="pipelineRuns" type="number" min="100" step="100" value="5000" />
        </div>
        <div class="actions">
          <button id="runPipelineSimBtn" type="button">Run simulation</button>
        </div>
      </article>

      <aside class="card stack">
        <div class="result">
          Results
          <pre id="pipelineOut" class="mono"></pre>
        </div>
      </aside>
    </section>

    <section class="article">
      <article class="card">
        <h2>What It Does</h2>
        <p>
          Runs a Monte Carlo simulation across your pipeline stages. Each run
          rolls a random failure check per stage based on your failure percentage,
          accumulating duration until a stage fails or the pipeline succeeds.
        </p>
      </article>
      <article class="card">
        <h2>Why It Matters</h2>
        <p>
          Even small per-stage failure rates compound across a multi-stage pipeline.
          This tool makes that math visible so you can prioritize reliability
          improvements where they have the most impact.
        </p>
      </article>
      <article class="card">
        <h2>How To Use</h2>
        <ul>
          <li>Enter each stage as <code>name,minutes,failure%</code> on its own line.</li>
          <li>Set the number of simulation runs (5000+ for stable results).</li>
          <li>Click <strong>Run simulation</strong> to see success rate and avg runtime.</li>
        </ul>
      </article>
    </section>
  </main>
</BaseLayout>

<script>
  const $ = (id) => document.getElementById(id);

  function parseStages(raw) {
    return raw
      .split(/\r?\n/)
      .map((line) => line.trim())
      .filter(Boolean)
      .map((line) => {
        const [name, duration, failure] = line.split(",").map((v) => v.trim());
        return {
          name,
          duration: Number(duration || 0),
          failure: Number(failure || 0) / 100,
        };
      });
  }

  $("runPipelineSimBtn").addEventListener("click", () => {
    try {
      const stages = parseStages(($("pipelineStages")).value || "");
      const runs = Math.max(100, Number(($("pipelineRuns")).value || 1000));
      if (!stages.length) throw new Error("No valid stages found.");

      let success = 0;
      let totalMinutes = 0;

      for (let i = 0; i < runs; i += 1) {
        let runMinutes = 0;
        let failed = false;
        for (const stage of stages) {
          runMinutes += stage.duration;
          if (Math.random() < stage.failure) {
            failed = true;
            break;
          }
        }
        if (!failed) success += 1;
        totalMinutes += runMinutes;
      }

      const successRate = (success / runs) * 100;
      const avgMinutes = totalMinutes / runs;
      const dailyCapacity = Math.floor((24 * 60) / avgMinutes);

      $("pipelineOut").textContent = [
        `Runs: ${runs}`,
        `Success rate: ${successRate.toFixed(2)}%`,
        `Failure rate: ${(100 - successRate).toFixed(2)}%`,
        `Average runtime: ${avgMinutes.toFixed(2)} minutes`,
        `Approx max runs/day per worker: ${dailyCapacity}`,
      ].join("\n");
    } catch (error) {
      $("pipelineOut").textContent = `Simulation failed:\n${String(error)}`;
    }
  });
</script>
