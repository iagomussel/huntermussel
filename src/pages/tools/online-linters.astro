---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Online Linters | HunterMussel Tools"
  description="Run lightweight online lint checks for JSON, YAML, JavaScript, and Markdown."
  canonicalPath="/tools/online-linters/"
>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">tool / linting</p>
      <h1>Online Linters</h1>
      <p class="lead">
        Quick browser linting for common payloads and text quality rules.
      </p>
      <a class="back-link" href="/tools/">Back to tools index</a>
    </section>

    <section class="tool-layout">
      <article class="card stack">
        <label class="label" for="linterType">Linter type</label>
        <select id="linterType">
          <option value="json" selected>JSON</option>
          <option value="yaml">YAML</option>
          <option value="javascript">JavaScript syntax</option>
          <option value="markdown">Markdown quality</option>
        </select>
        <label class="label" for="linterInput">Input</label>
        <textarea id="linterInput" placeholder="Paste content to lint..."></textarea>
        <button id="runLinterBtn" type="button">Run linter</button>
      </article>
      <aside class="card stack">
        <div class="result">
          Status
          <strong id="linterStatus">Waiting input</strong>
          <span id="linterHint" class="small">Pick linter and run checks.</span>
        </div>
        <pre id="linterOut" class="mono"></pre>
      </aside>
    </section>
  </main>
</BaseLayout>

<script type="module">
  import yaml from "js-yaml";

  const $ = (id) => document.getElementById(id);
  const set = (status, hint, out = "") => {
    $("linterStatus").textContent = status;
    $("linterHint").textContent = hint;
    $("linterOut").textContent = out;
  };

  function lintMarkdown(input) {
    const findings = [];
    const lines = input.split(/\r?\n/);
    if (!/^#\s+/.test(lines[0] || "")) findings.push("Missing top-level H1 heading.");
    if (lines.some((l) => l.length > 140)) findings.push("Found lines longer than 140 chars.");
    if (/\t/.test(input)) findings.push("Tab characters found; prefer spaces.");
    if (!/\[.+\]\(.+\)/.test(input)) findings.push("No markdown links detected.");
    return findings;
  }

  $("runLinterBtn").addEventListener("click", () => {
    const type = $("linterType").value;
    const input = $("linterInput").value || "";
    if (!input.trim()) {
      set("Empty input", "Provide content first.");
      return;
    }
    try {
      if (type === "json") {
        JSON.parse(input);
        set("Passed", "JSON syntax is valid.");
        return;
      }
      if (type === "yaml") {
        yaml.load(input);
        set("Passed", "YAML syntax is valid.");
        return;
      }
      if (type === "javascript") {
        // Syntax-only check
        new Function(input);
        set("Passed", "JavaScript syntax check passed.");
        return;
      }
      if (type === "markdown") {
        const findings = lintMarkdown(input);
        set(
          findings.length ? "Warnings found" : "Passed",
          "Markdown quality checks completed.",
          findings.length ? `- ${findings.join("\n- ")}` : "No markdown quality warnings."
        );
      }
    } catch (err) {
      set("Failed", "Linting error found.", String(err));
    }
  });
</script>
