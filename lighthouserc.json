{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": ["http://localhost/"],
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "color-contrast": ["error", { "minScore": 0.9 }],
        "errors-in-console": ["error", { "minScore": 0.9 }],
        "first-contentful-paint": "off",
        "network-dependency-tree-insight": "off",
        "render-blocking-insight": ["warn", { "maxLength": 5 }],
        "render-blocking-resources": ["warn", { "maxLength": 5 }],
        "unused-css-rules": ["warn", { "maxLength": 5 }],
        "unused-javascript": ["warn", { "maxLength": 5 }]
      }
    }
  }
}
