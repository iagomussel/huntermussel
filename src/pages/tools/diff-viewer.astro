---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Diff Viewer | HunterMussel Tools"
  description="Compare two texts with a GitHub-style diff — character-level highlights, hunk context, side-by-side and unified views. Runs entirely in your browser."
  canonicalPath="/tools/diff-viewer/"
>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">tool / text</p>
      <h1>Diff Viewer</h1>
      <p class="lead">
        Compare two texts with a GitHub-style diff — character-level highlights,
        hunk headers, and side-by-side or unified view.
      </p>
      <a class="back-link" href="/tools/">← Back to tools</a>
    </section>

    <!-- Input panel -->
    <div class="dv-inputs card">
      <div class="dv-input-grid">
        <div class="dv-input-col">
          <div class="dv-input-head">
            <span class="dv-label dv-label--del">Original</span>
            <span id="leftLines" class="dv-linecount">0 lines</span>
          </div>
          <textarea id="leftInput" class="dv-textarea" spellcheck="false" placeholder="Paste original text here…"></textarea>
        </div>
        <div class="dv-input-col">
          <div class="dv-input-head">
            <span class="dv-label dv-label--ins">Modified</span>
            <span id="rightLines" class="dv-linecount">0 lines</span>
          </div>
          <textarea id="rightInput" class="dv-textarea" spellcheck="false" placeholder="Paste modified text here…"></textarea>
        </div>
      </div>
    </div>

    <!-- Toolbar -->
    <div class="dv-toolbar">
      <div class="dv-toolbar-left">
        <div class="dv-seg" id="viewToggle" role="group">
          <button class="dv-seg-btn is-active" data-view="unified" type="button">Unified</button>
          <button class="dv-seg-btn" data-view="split" type="button">Split</button>
        </div>
        <label class="dv-check">
          <input id="ignoreWs" type="checkbox" />
          <span>Ignore whitespace</span>
        </label>
        <label class="dv-check">
          <input id="contextSel" type="number" min="0" max="20" value="3" style="width:3rem" />
          <span>context lines</span>
        </label>
      </div>
      <div class="dv-toolbar-right">
        <span id="diffStats" class="dv-stats"></span>
        <button id="sampleBtn" type="button" class="dv-btn dv-btn--ghost">Sample</button>
        <button id="copyBtn" type="button" class="dv-btn dv-btn--ghost">Copy</button>
        <button id="downloadBtn" type="button" class="dv-btn dv-btn--ghost">Download .diff</button>
      </div>
    </div>

    <!-- Diff output -->
    <div id="diffOutput" class="dv-output card">
      <div class="dv-empty">Paste text above to see the diff.</div>
    </div>
  </main>
</BaseLayout>

<style>
  /* ── Inputs ── */
  .dv-inputs { padding: 0; overflow: hidden; }

  .dv-input-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .dv-input-col { display: flex; flex-direction: column; }
  .dv-input-col + .dv-input-col { border-left: 1px solid #1c2535; }

  .dv-input-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.55rem 0.85rem;
    border-bottom: 1px solid #1c2535;
    background: #0a0d14;
  }

  .dv-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .dv-label--del { color: #f87171; }
  .dv-label--ins { color: #1aeb6a; }

  .dv-linecount {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    color: #8f9aa6;
  }

  .dv-textarea {
    flex: 1;
    min-height: 180px;
    padding: 0.75rem;
    background: #090b11;
    color: #f5f9ff;
    border: none;
    outline: none;
    resize: vertical;
    font-family: "JetBrains Mono", "SFMono-Regular", Consolas, monospace;
    font-size: 0.82rem;
    line-height: 1.6;
    tab-size: 2;
  }
  .dv-textarea::placeholder { color: #3a4455; }
  .dv-textarea:focus { background: #0a0e18; }

  /* ── Toolbar ── */
  .dv-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.65rem;
    padding: 0.6rem 0;
  }

  .dv-toolbar-left,
  .dv-toolbar-right {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: wrap;
  }

  .dv-seg {
    display: inline-flex;
    border: 1px solid #1c2535;
    border-radius: 8px;
    overflow: hidden;
  }

  .dv-seg-btn {
    padding: 0.35rem 0.8rem;
    background: #0e1219;
    color: #8f9aa6;
    border: none;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
  }
  .dv-seg-btn + .dv-seg-btn { border-left: 1px solid #1c2535; }
  .dv-seg-btn.is-active { background: #1aeb6a; color: #090b11; }
  .dv-seg-btn:hover:not(.is-active) { background: #151e2a; color: #f5f9ff; }

  .dv-check {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    color: #8f9aa6;
    cursor: pointer;
  }
  .dv-check input[type="checkbox"] { accent-color: #1aeb6a; cursor: pointer; }
  .dv-check input[type="number"] {
    background: #0e1219;
    border: 1px solid #1c2535;
    border-radius: 5px;
    color: #f5f9ff;
    padding: 0.2rem 0.4rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    text-align: center;
  }

  .dv-stats {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    color: #8f9aa6;
  }
  .dv-stats .s-add { color: #1aeb6a; font-weight: 700; }
  .dv-stats .s-del { color: #f87171; font-weight: 700; }

  .dv-btn {
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    border: 1px solid #1c2535;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    font-weight: 700;
    cursor: pointer;
    transition: border-color 0.12s, background 0.12s, color 0.12s;
  }
  .dv-btn--ghost { background: #0e1219; color: #8f9aa6; }
  .dv-btn--ghost:hover { background: #151e2a; color: #f5f9ff; border-color: rgba(26,235,106,0.3); }

  /* ── Output ── */
  .dv-output {
    padding: 0;
    overflow: hidden;
    overflow-x: auto;
  }

  .dv-empty {
    padding: 3rem;
    text-align: center;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.85rem;
    color: #3a4455;
  }

  /* ── Diff table ── */
  .diff-table {
    width: 100%;
    border-collapse: collapse;
    font-family: "JetBrains Mono", "SFMono-Regular", Consolas, monospace;
    font-size: 0.8rem;
    line-height: 1.55;
    table-layout: fixed;
  }

  .diff-table col.col-num  { width: 52px; }
  .diff-table col.col-sign { width: 26px; }
  .diff-table col.col-code { width: auto; }
  .diff-table col.col-gap  { width: 1px; }

  /* Gutter cells */
  .diff-table td.ln {
    width: 52px;
    min-width: 52px;
    text-align: right;
    padding: 0 0.6rem 0 0.4rem;
    color: #3d4f65;
    user-select: none;
    white-space: nowrap;
    vertical-align: top;
    border-right: 1px solid #1c2535;
  }

  .diff-table td.sign {
    width: 26px;
    min-width: 26px;
    text-align: center;
    padding: 0 0.2rem;
    font-weight: 700;
    user-select: none;
    vertical-align: top;
  }

  .diff-table td.code {
    padding: 0 0.85rem;
    white-space: pre;
    overflow: hidden;
    text-overflow: ellipsis;
    color: #cdd9e5;
    vertical-align: top;
    word-break: break-all;
    white-space: pre-wrap;
  }

  /* Gap column for split view */
  .diff-table td.gap {
    width: 1px;
    padding: 0;
    background: #1c2535;
  }

  /* Equal lines */
  tr.eq td.ln { background: #090b11; }
  tr.eq td.sign { color: transparent; background: #090b11; }
  tr.eq td.code { background: #090b11; }

  /* Deleted lines */
  tr.del td.ln   { background: rgba(248,81,73,0.08); color: #f87171; border-right-color: rgba(248,81,73,0.25); }
  tr.del td.sign { background: rgba(248,81,73,0.12); color: #f87171; }
  tr.del td.code { background: rgba(248,81,73,0.08); color: #fca5a5; }

  /* Added lines */
  tr.ins td.ln   { background: rgba(26,235,106,0.07); color: #1aeb6a; border-right-color: rgba(26,235,106,0.2); }
  tr.ins td.sign { background: rgba(26,235,106,0.1);  color: #1aeb6a; }
  tr.ins td.code { background: rgba(26,235,106,0.07); color: #bbf7d0; }

  /* Empty placeholder (split view) */
  tr.placeholder td { background: #07090f; }
  tr.placeholder td.code { background: repeating-linear-gradient(45deg, #07090f, #07090f 4px, #08090f 4px, #08090f 8px); }

  /* Character-level highlights */
  .ch-del { background: rgba(248,81,73,0.35); border-radius: 2px; }
  .ch-ins { background: rgba(26,235,106,0.3);  border-radius: 2px; }

  /* Hunk header */
  tr.hunk td {
    background: rgba(33,136,255,0.07);
    color: #6ea8d8;
    padding: 0.25rem 0.85rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    font-weight: 600;
    border-top: 1px solid rgba(33,136,255,0.15);
    border-bottom: 1px solid rgba(33,136,255,0.15);
  }

  /* Expand collapsed context */
  tr.expand td {
    background: #0a0d14;
    text-align: center;
    padding: 0.3rem;
    cursor: pointer;
  }
  tr.expand td:hover { background: #0d1220; }
  tr.expand span {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    color: #6ea8d8;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  tr.expand span::before { content: "↕"; }

  @media (max-width: 700px) {
    .dv-input-grid { grid-template-columns: 1fr; }
    .dv-input-col + .dv-input-col { border-left: none; border-top: 1px solid #1c2535; }
    .dv-toolbar { flex-direction: column; align-items: flex-start; }
  }
</style>

<script type="module">
  // ── Helpers ──────────────────────────────────────────────────────────────

  function esc(s) {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  }

  // LCS line diff
  function lineDiff(a, b) {
    const m = a.length, n = b.length;
    // For very large inputs, cap to avoid browser hang
    if (m > 3000 || n > 3000) {
      return [
        ...a.map(t => ({ type: 'delete', text: t })),
        ...b.map(t => ({ type: 'insert', text: t })),
      ];
    }
    const dp = new Array(m + 1).fill(null).map(() => new Int32Array(n + 1));
    for (let i = 1; i <= m; i++) {
      for (let j = 1; j <= n; j++) {
        dp[i][j] = a[i-1] === b[j-1]
          ? dp[i-1][j-1] + 1
          : Math.max(dp[i-1][j], dp[i][j-1]);
      }
    }
    const result = [];
    let i = m, j = n;
    while (i > 0 || j > 0) {
      if (i > 0 && j > 0 && a[i-1] === b[j-1]) {
        result.unshift({ type: 'equal', text: a[i-1] });
        i--; j--;
      } else if (j > 0 && (i === 0 || dp[i][j-1] >= dp[i-1][j])) {
        result.unshift({ type: 'insert', text: b[j-1] });
        j--;
      } else {
        result.unshift({ type: 'delete', text: a[i-1] });
        i--;
      }
    }
    return result;
  }

  // Character-level LCS diff (for short lines)
  function charDiff(a, b) {
    if (a.length > 300 || b.length > 300) return null;
    const dp = new Array(a.length + 1).fill(null).map(() => new Int32Array(b.length + 1));
    for (let i = 1; i <= a.length; i++)
      for (let j = 1; j <= b.length; j++)
        dp[i][j] = a[i-1] === b[j-1] ? dp[i-1][j-1] + 1 : Math.max(dp[i-1][j], dp[i][j-1]);
    const r = [];
    let i = a.length, j = b.length;
    while (i > 0 || j > 0) {
      if (i > 0 && j > 0 && a[i-1] === b[j-1]) { r.unshift({ t: 'eq', c: a[i-1] }); i--; j--; }
      else if (j > 0 && (i === 0 || dp[i][j-1] >= dp[i-1][j])) { r.unshift({ t: 'ins', c: b[j-1] }); j--; }
      else { r.unshift({ t: 'del', c: a[i-1] }); i--; }
    }
    return r;
  }

  function renderCharDiff(chars, side) {
    return chars.map(c => {
      const e = esc(c.c);
      if (c.t === 'eq') return e;
      if (side === 'del' && c.t === 'del') return `<mark class="ch-del">${e}</mark>`;
      if (side === 'ins' && c.t === 'ins') return `<mark class="ch-ins">${e}</mark>`;
      return '';
    }).join('');
  }

  // Assign line numbers to each diff entry
  function assignNums(diff) {
    let ol = 1, nl = 1;
    return diff.map(d => {
      const e = { ...d };
      if (d.type === 'delete')      { e.ol = ol++; e.nl = null; }
      else if (d.type === 'insert') { e.ol = null; e.nl = nl++; }
      else                          { e.ol = ol++; e.nl = nl++; }
      return e;
    });
  }

  // Group numbered diff into hunks with context
  function buildHunks(numbered, ctx) {
    if (!numbered.length) return [];
    const changed = new Set(numbered.flatMap((d, i) => d.type !== 'equal' ? [i] : []));
    if (!changed.size) return [];

    const include = new Set();
    for (const i of changed)
      for (let j = Math.max(0, i - ctx); j <= Math.min(numbered.length - 1, i + ctx); j++)
        include.add(j);

    const hunks = [];
    let cur = null;
    for (let i = 0; i < numbered.length; i++) {
      if (include.has(i)) {
        if (!cur) cur = { lines: [], skippedBefore: i };
        cur.lines.push(numbered[i]);
        cur.endIdx = i;
      } else {
        if (cur) { hunks.push(cur); cur = null; }
      }
    }
    if (cur) hunks.push(cur);
    return hunks;
  }

  // Pair up consecutive delete/insert runs for char-level diff
  function pairRuns(lines) {
    const out = [];
    let i = 0;
    while (i < lines.length) {
      if (lines[i].type === 'equal') { out.push(lines[i]); i++; continue; }
      const dels = [], ins = [];
      while (i < lines.length && lines[i].type !== 'equal') {
        if (lines[i].type === 'delete') dels.push(lines[i]);
        else ins.push(lines[i]);
        i++;
      }
      const pairs = Math.min(dels.length, ins.length);
      for (let k = 0; k < pairs; k++) {
        const cd = charDiff(dels[k].text, ins[k].text);
        dels[k] = { ...dels[k], charDiff: cd };
        ins[k]  = { ...ins[k],  charDiff: cd };
      }
      out.push(...dels, ...ins);
    }
    return out;
  }

  // ── Render ───────────────────────────────────────────────────────────────

  function renderUnified(hunks, totalSkipped) {
    let html = '<table class="diff-table"><colgroup><col class="col-num"><col class="col-num"><col class="col-sign"><col class="col-code"></colgroup><tbody>';

    for (const hunk of hunks) {
      const first = hunk.lines[0];
      const oldStart = hunk.lines.find(l => l.ol)?.ol ?? '?';
      const newStart = hunk.lines.find(l => l.nl)?.nl ?? '?';
      const oldCount = hunk.lines.filter(l => l.ol).length;
      const newCount = hunk.lines.filter(l => l.nl).length;
      html += `<tr class="hunk"><td colspan="4">@@ -${oldStart},${oldCount} +${newStart},${newCount} @@</td></tr>`;

      const paired = pairRuns(hunk.lines);
      for (const d of paired) {
        if (d.type === 'equal') {
          html += `<tr class="eq"><td class="ln">${d.ol}</td><td class="ln">${d.nl}</td><td class="sign"> </td><td class="code">${esc(d.text)}</td></tr>`;
        } else if (d.type === 'delete') {
          const content = d.charDiff ? renderCharDiff(d.charDiff, 'del') : esc(d.text);
          html += `<tr class="del"><td class="ln">${d.ol}</td><td class="ln"></td><td class="sign">−</td><td class="code">${content}</td></tr>`;
        } else {
          const content = d.charDiff ? renderCharDiff(d.charDiff, 'ins') : esc(d.text);
          html += `<tr class="ins"><td class="ln"></td><td class="ln">${d.nl}</td><td class="sign">+</td><td class="code">${content}</td></tr>`;
        }
      }
    }

    html += '</tbody></table>';
    return html;
  }

  function renderSplit(hunks) {
    let html = '<table class="diff-table"><colgroup><col class="col-num"><col class="col-sign"><col class="col-code"><col class="col-gap"><col class="col-num"><col class="col-sign"><col class="col-code"></colgroup><tbody>';

    for (const hunk of hunks) {
      const oldStart = hunk.lines.find(l => l.ol)?.ol ?? '?';
      const newStart = hunk.lines.find(l => l.nl)?.nl ?? '?';
      html += `<tr class="hunk"><td colspan="7">@@ -${oldStart} +${newStart} @@</td></tr>`;

      // Build slots: each slot = { left, right }
      const slots = [];
      let i = 0;
      const lines = hunk.lines;
      while (i < lines.length) {
        if (lines[i].type === 'equal') { slots.push({ left: lines[i], right: lines[i] }); i++; continue; }
        const dels = [], ins = [];
        while (i < lines.length && lines[i].type !== 'equal') {
          if (lines[i].type === 'delete') dels.push(lines[i]);
          else ins.push(lines[i]);
          i++;
        }
        const pairs = Math.min(dels.length, ins.length);
        for (let k = 0; k < pairs; k++) {
          const cd = charDiff(dels[k].text, ins[k].text);
          dels[k] = { ...dels[k], charDiff: cd };
          ins[k]  = { ...ins[k],  charDiff: cd };
        }
        const max = Math.max(dels.length, ins.length);
        for (let k = 0; k < max; k++)
          slots.push({ left: dels[k] ?? null, right: ins[k] ?? null });
      }

      for (const { left, right } of slots) {
        const lType = left ? left.type : 'placeholder';
        const rType = right ? right.type : 'placeholder';
        const lClass = left ? (left.type === 'equal' ? 'eq' : 'del') : 'placeholder';
        const rClass = right ? (right.type === 'equal' ? 'eq' : 'ins') : 'placeholder';

        const lNum  = left  ? (left.ol  ?? '') : '';
        const rNum  = right ? (right.nl ?? '') : '';
        const lSign = left  ? (left.type === 'delete' ? '−' : ' ') : '';
        const rSign = right ? (right.type === 'insert' ? '+' : ' ') : '';

        const lContent = left
          ? (left.charDiff ? renderCharDiff(left.charDiff, 'del') : esc(left.text))
          : '';
        const rContent = right
          ? (right.charDiff ? renderCharDiff(right.charDiff, 'ins') : esc(right.text))
          : '';

        html += `<tr>`;
        html += `<td class="ln ${lClass}">${lNum}</td><td class="sign ${lClass}">${lSign}</td><td class="code ${lClass}">${lContent}</td>`;
        html += `<td class="gap"></td>`;
        html += `<td class="ln ${rClass}">${rNum}</td><td class="sign ${rClass}">${rSign}</td><td class="code ${rClass}">${rContent}</td>`;
        html += `</tr>`;
      }
    }

    html += '</tbody></table>';
    return html;
  }

  // ── Main diff runner ──────────────────────────────────────────────────────

  const leftEl   = document.getElementById('leftInput');
  const rightEl  = document.getElementById('rightInput');
  const outputEl = document.getElementById('diffOutput');
  const statsEl  = document.getElementById('diffStats');
  const leftLc   = document.getElementById('leftLines');
  const rightLc  = document.getElementById('rightLines');
  const ignoreWs = document.getElementById('ignoreWs');
  const ctxSel   = document.getElementById('contextSel');
  const viewToggle = document.getElementById('viewToggle');

  let currentView = 'unified';

  function getLines(text) {
    return text === '' ? [] : text.split('\n');
  }

  function normalize(line) {
    return ignoreWs.checked ? line.trim().replace(/\s+/g, ' ') : line;
  }

  function runDiff() {
    const aRaw = getLines(leftEl.value);
    const bRaw = getLines(rightEl.value);
    const a = aRaw.map(normalize);
    const b = bRaw.map(normalize);

    leftLc.textContent  = `${aRaw.length} line${aRaw.length !== 1 ? 's' : ''}`;
    rightLc.textContent = `${bRaw.length} line${bRaw.length !== 1 ? 's' : ''}`;

    if (!leftEl.value && !rightEl.value) {
      outputEl.innerHTML = '<div class="dv-empty">Paste text above to see the diff.</div>';
      statsEl.innerHTML = '';
      return;
    }

    // Diff using potentially normalized text, but display raw text
    const rawDiff = lineDiff(a, b);
    // Map back to raw lines
    let ai = 0, bi = 0;
    const diff = rawDiff.map(d => {
      if (d.type === 'delete')      return { type: 'delete', text: aRaw[ai++] ?? d.text };
      else if (d.type === 'insert') return { type: 'insert', text: bRaw[bi++] ?? d.text };
      else                          return { type: 'equal',  text: aRaw[ai++] ?? d.text, _b: bi++ };
    });

    const added   = diff.filter(d => d.type === 'insert').length;
    const deleted = diff.filter(d => d.type === 'delete').length;
    const equal   = diff.filter(d => d.type === 'equal').length;

    statsEl.innerHTML =
      `<span class="s-add">+${added} added</span> &nbsp; ` +
      `<span class="s-del">−${deleted} removed</span> &nbsp; ` +
      `<span>${equal} unchanged</span>`;

    if (!added && !deleted) {
      outputEl.innerHTML = '<div class="dv-empty" style="color:#1aeb6a">✓ Files are identical.</div>';
      return;
    }

    const ctx = parseInt(ctxSel.value) || 3;
    const numbered = assignNums(diff);
    const hunks = buildHunks(numbered, ctx);

    outputEl.innerHTML = currentView === 'unified'
      ? renderUnified(hunks)
      : renderSplit(hunks);
  }

  // Debounce
  let timer;
  function schedule() { clearTimeout(timer); timer = setTimeout(runDiff, 280); }

  leftEl.addEventListener('input', schedule);
  rightEl.addEventListener('input', schedule);
  ignoreWs.addEventListener('change', runDiff);
  ctxSel.addEventListener('change', runDiff);

  viewToggle.addEventListener('click', e => {
    const btn = e.target.closest('.dv-seg-btn');
    if (!btn) return;
    viewToggle.querySelectorAll('.dv-seg-btn').forEach(b => b.classList.remove('is-active'));
    btn.classList.add('is-active');
    currentView = btn.dataset.view;
    runDiff();
  });

  // Copy
  document.getElementById('copyBtn').addEventListener('click', () => {
    const aRaw = getLines(leftEl.value);
    const bRaw = getLines(rightEl.value);
    const diff = lineDiff(aRaw, bRaw);
    let ai = 0, bi = 0;
    const text = diff.map(d => {
      if (d.type === 'delete')      return `- ${aRaw[ai++]}`;
      else if (d.type === 'insert') return `+ ${bRaw[bi++]}`;
      else                          { ai++; bi++; return `  ${d.text}`; }
    }).join('\n');
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('copyBtn');
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = orig, 1500);
    });
  });

  // Download
  document.getElementById('downloadBtn').addEventListener('click', () => {
    const aRaw = getLines(leftEl.value);
    const bRaw = getLines(rightEl.value);
    const diff = lineDiff(aRaw, bRaw);
    let ai = 0, bi = 0;
    const text = `--- original\n+++ modified\n` + diff.map(d => {
      if (d.type === 'delete')      return `- ${aRaw[ai++]}`;
      else if (d.type === 'insert') return `+ ${bRaw[bi++]}`;
      else                          { ai++; bi++; return `  ${d.text}`; }
    }).join('\n');
    const a = document.createElement('a');
    a.href = URL.createObjectURL(new Blob([text], { type: 'text/plain' }));
    a.download = 'changes.diff';
    a.click();
  });

  // Sample data
  document.getElementById('sampleBtn').addEventListener('click', () => {
    leftEl.value = `{
  "name": "api-gateway",
  "version": "1.4.2",
  "port": 3000,
  "timeout": 5000,
  "retries": 2,
  "auth": {
    "provider": "jwt",
    "secret": "changeme"
  },
  "rateLimit": {
    "enabled": false,
    "max": 100,
    "window": "1m"
  },
  "logging": {
    "level": "info",
    "format": "text"
  },
  "upstreams": [
    { "name": "users",  "url": "http://users-svc:8080" },
    { "name": "orders", "url": "http://orders-svc:8080" }
  ]
}`;
    rightEl.value = `{
  "name": "api-gateway",
  "version": "1.5.0",
  "port": 8080,
  "timeout": 8000,
  "retries": 3,
  "auth": {
    "provider": "oauth2",
    "secret": "changeme",
    "issuer": "https://auth.example.com"
  },
  "rateLimit": {
    "enabled": true,
    "max": 200,
    "window": "1m"
  },
  "logging": {
    "level": "warn",
    "format": "json",
    "destination": "stdout"
  },
  "upstreams": [
    { "name": "users",    "url": "http://users-svc:8080" },
    { "name": "orders",   "url": "http://orders-svc:8080" },
    { "name": "payments", "url": "http://payments-svc:8080" }
  ],
  "healthCheck": {
    "enabled": true,
    "path": "/health",
    "interval": "30s"
  }
}`;
    runDiff();
  });
</script>
