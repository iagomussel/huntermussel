---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { ArrowRight } from 'lucide-react';

const posts = (await getCollection('blog'))
  .filter(post => post.data.status === 'published')
  .sort((a, b) => b.data.date?.valueOf() - a.data.date?.valueOf());

const blogUrl = 'https://huntermussel.com/blog/';
const blogSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Blog — HunterMussel',
    url: blogUrl,
    description: 'Articles on AI automation, process management, DevOps, and cloud infrastructure.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://huntermussel.com/' },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: blogUrl },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Blog Posts',
    url: blogUrl,
    numberOfItems: posts.length,
    itemListElement: posts.map((post, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://huntermussel.com/blog/${post.slug}/`,
      name: post.data.title,
    })),
  },
];
---

<Layout
  title="Blog: AI Automation, DevOps & Process Management"
  description="Articles on AI automation, process management, DevOps engineering, and cloud infrastructure by HunterMussel."
  canonicalUrl={blogUrl}
  keywords={[
    'ai automation blog',
    'devops articles',
    'devops best practices',
    'devops practices',
    'continuous integration tools',
    'containerization technologies',
    'process management blog',
    'cloud infrastructure blog',
    'software engineering blog',
    'technical seo blog',
  ]}
  schema={blogSchema}
>
  <div class="min-h-screen bg-background">
    <div class="absolute inset-0 grid-bg opacity-10 pointer-events-none" />
    <main class="container relative z-10 px-6 pt-32 pb-24">
      <header class="mb-16 text-center">
        <span class="mb-4 inline-block font-heading text-xs font-medium uppercase tracking-widest text-primary">// blog</span>
        <h1 class="font-heading text-4xl font-bold tracking-tight md:text-6xl mb-6">
          Latest <span class="gradient-text">Insights</span>
        </h1>
        <p class="font-body text-xl text-muted-foreground leading-relaxed max-w-2xl mx-auto">
          Articles on process management, AI automation, and DevOps.
        </p>
      </header>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <article class="group relative overflow-hidden rounded-lg border border-border bg-card/50 transition-all hover:border-primary/30 hover:bg-card flex flex-col h-full">
            {post.data.image && (
              <div class="aspect-video w-full overflow-hidden border-b border-border">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              </div>
            )}
            <div class="flex flex-1 flex-col p-6">
              <div class="mb-4 flex items-center justify-between text-xs text-muted-foreground">
                {post.data.date && (
                  <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                )}
                {post.data.tags && post.data.tags.length > 0 && (
                  <span class="rounded-full border border-border bg-muted/30 px-2 py-0.5">
                    {post.data.tags[0]}
                  </span>
                )}
              </div>
              <h2 class="mb-3 font-heading text-xl font-bold leading-tight group-hover:text-primary transition-colors">
                <a href={`/blog/${post.slug}/`} class="block">
                  {post.data.title}
                </a>
              </h2>
              <p class="mb-6 flex-1 font-body text-sm text-muted-foreground line-clamp-3">
                {post.data.description}
              </p>
              <a
                href={`/blog/${post.slug}/`}
                class="inline-flex items-center gap-1 font-heading text-xs font-semibold text-primary transition-all group-hover:gap-2"
              >
                Read article
                <ArrowRight size={14} />
              </a>
            </div>
          </article>
        ))}
      </div>
    </main>
  </div>
</Layout>
